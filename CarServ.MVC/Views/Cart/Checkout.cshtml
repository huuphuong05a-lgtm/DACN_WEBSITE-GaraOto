@model CarServ.MVC.Models.CheckoutViewModel
@{
    ViewData["Title"] = "Thanh Toán";
    var cartItems = ViewData["CartItems"] as IEnumerable<CarServ.MVC.Models.Cart> ?? new List<CarServ.MVC.Models.Cart>();
    var subtotal = ViewData["Subtotal"] as decimal? ?? 0;
    var shippingFee = ViewData["ShippingFee"] as decimal? ?? 0;
    var totalAmount = ViewData["TotalAmount"] as decimal? ?? 0;
}

<!-- Page Header Start -->
<div class="container-fluid page-header mb-5 p-0" style="background-image: url(/img/carousel-bg-1.jpg);">
    <div class="container-fluid page-header-inner py-5">
        <div class="container text-center pb-5">
            <h1 class="display-3 text-white mb-3 animated slideInDown">Thanh Toán</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb justify-content-center text-uppercase">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Trang Chủ</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Cart")">Giỏ Hàng</a></li>
                    <li class="breadcrumb-item text-white active" aria-current="page">Thanh Toán</li>
                </ol>
            </nav>
        </div>
    </div>
</div>
<!-- Page Header End -->

<!-- Checkout Start -->
<div class="container-xxl py-5 checkout-page">
    <div class="container">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <form asp-action="ProcessCheckout" method="post" class="checkout-form">
            @foreach (var cartId in Model.SelectedCartIds)
            {
                <input type="hidden" name="SelectedCartIds" value="@cartId" />
            }
            <div class="row g-4 align-items-start">
                <div class="col-lg-8">
                    <div class="checkout-section">
                        <div class="checkout-section-header">
                            <h5><i class="fa fa-user me-2"></i>Thông Tin Khách Hàng</h5>
                        </div>
                        <div class="checkout-section-body">
                            <div class="row g-3">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="CustomerName" class="form-label"></label>
                                    <input asp-for="CustomerName" class="form-control" />
                                    <span asp-validation-for="CustomerName" class="text-danger"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="CustomerPhone" class="form-label"></label>
                                    <input asp-for="CustomerPhone" class="form-control" />
                                    <span asp-validation-for="CustomerPhone" class="text-danger"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="CustomerEmail" class="form-label"></label>
                                    <input asp-for="CustomerEmail" type="email" class="form-control" />
                                    <span asp-validation-for="CustomerEmail" class="text-danger"></span>
                                </div>
                                <div class="col-12 mb-3">
                                    <label asp-for="PaymentMethod" class="form-label">Phương thức thanh toán <span class="text-danger">*</span></label>
                                    <div class="checkout-payment-options">
                                        <label class="checkout-payment-option">
                                            <input asp-for="PaymentMethod" type="radio" value="COD" />
                                            <span class="checkout-payment-icon"><i class="fa fa-money-bill-wave"></i></span>
                                            <span>
                                                <strong>Thanh toán khi nhận hàng</strong>
                                                <small>Thanh toán trực tiếp sau khi đơn được xác nhận.</small>
                                            </span>
                                        </label>
                                        <label class="checkout-payment-option">
                                            <input asp-for="PaymentMethod" type="radio" value="VNPay" />
                                            <span class="checkout-payment-icon"><i class="fa fa-credit-card"></i></span>
                                            <span>
                                                <strong>VNPAY</strong>
                                                <small>Chuyển đến cổng thanh toán online sau khi đặt hàng.</small>
                                            </span>
                                        </label>
                                    </div>
                                    <span asp-validation-for="PaymentMethod" class="text-danger"></span>
                                </div>
                                <div class="col-12 mb-3">
                                    <label asp-for="ShippingAddress" class="form-label"></label>
                                    <textarea asp-for="ShippingAddress" class="form-control" rows="3" placeholder="Số nhà, đường, phường/xã, quận/huyện, tỉnh/thành phố"></textarea>
                                    <span asp-validation-for="ShippingAddress" class="text-danger"></span>
                                </div>
                                <div class="col-12 mb-3">
                                    <label asp-for="Notes" class="form-label"></label>
                                    <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Ghi chú thêm (nếu có)"></textarea>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="checkout-section">
                        <div class="checkout-section-header">
                            <h5><i class="fa fa-shopping-cart me-2"></i>Đơn Hàng Của Bạn</h5>
                        </div>
                        <div class="checkout-section-body">
                            <div class="checkout-order-list">
                                @foreach (var item in cartItems)
                                {
                                    if (item.Product != null)
                                    {
                                        var price = item.Product.SalePrice ?? item.Product.Price ?? 0;
                                        var itemTotal = price * (item.Quantity ?? 1);
                                        <div class="checkout-order-item">
                                            @if (!string.IsNullOrEmpty(item.Product.ImageUrl))
                                            {
                                                <img src="@item.Product.ImageUrl" alt="@item.Product.ProductName">
                                            }
                                            else
                                            {
                                                <img src="~/img/product-1.jpg" alt="@item.Product.ProductName">
                                            }
                                            <div class="checkout-order-info">
                                                <h6>@item.Product.ProductName</h6>
                                                @if (!string.IsNullOrEmpty(item.Product.Sku))
                                                {
                                                    <small>SKU: @item.Product.Sku</small>
                                                }
                                                <span>Số lượng: @(item.Quantity ?? 1)</span>
                                            </div>
                                            <div class="checkout-order-price">
                                                <span>@price.ToString("N0") đ</span>
                                                <strong>@itemTotal.ToString("N0") đ</strong>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="checkout-summary-wrap">
                        <div class="checkout-section checkout-summary">
                            <div class="checkout-section-header">
                                <h5><i class="fa fa-calculator me-2"></i>Tóm Tắt</h5>
                            </div>
                            <div class="summary-details">
                                <div class="checkout-summary-row">
                                    <span>Tạm tính</span>
                                    <strong>@subtotal.ToString("N0") đ</strong>
                                </div>
                                <div class="checkout-summary-row">
                                    <span>Phí vận chuyển</span>
                                    <strong>@shippingFee.ToString("N0") đ</strong>
                                </div>
                                <div class="checkout-summary-total">
                                    <span>Tổng cộng</span>
                                    <strong>@totalAmount.ToString("N0") đ</strong>
                                </div>
                                <button type="submit" class="btn btn-primary btn-submit-checkout">
                                    <i class="fa fa-check me-2"></i>Đặt Hàng
                                </button>
                                <a href="@Url.Action("Index", "Cart")" class="btn btn-outline-secondary checkout-back-btn">
                                    <i class="fa fa-arrow-left me-2"></i>Quay Lại Giỏ Hàng
                                </a>
                                <p class="checkout-secure-note">
                                    <i class="fa fa-shield-alt me-2"></i>Thông tin thanh toán của bạn được xử lý an toàn.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>
<!-- Checkout End -->

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

