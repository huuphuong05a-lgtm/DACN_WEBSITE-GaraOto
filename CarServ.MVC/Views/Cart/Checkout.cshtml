@model CarServ.MVC.Models.CheckoutViewModel
@{
    ViewData["Title"] = "Thanh Toán";
    var cartItems = ViewData["CartItems"] as IEnumerable<CarServ.MVC.Models.Cart> ?? new List<CarServ.MVC.Models.Cart>();
    var subtotal = ViewData["Subtotal"] as decimal? ?? 0;
    var shippingFee = ViewData["ShippingFee"] as decimal? ?? 0;
    var totalAmount = ViewData["TotalAmount"] as decimal? ?? 0;
}

<!-- Page Header Start -->
<div class="container-fluid page-header mb-5 p-0" style="background-image: url(/img/carousel-bg-1.jpg);">
    <div class="container-fluid page-header-inner py-5">
        <div class="container text-center pb-5">
            <h1 class="display-3 text-white mb-3 animated slideInDown">Thanh Toán</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb justify-content-center text-uppercase">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Trang Chủ</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Cart")">Giỏ Hàng</a></li>
                    <li class="breadcrumb-item text-white active" aria-current="page">Thanh Toán</li>
                </ol>
            </nav>
        </div>
    </div>
</div>
<!-- Page Header End -->

<!-- Checkout Start -->
<div class="container-xxl py-5">
    <div class="container">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <form asp-action="ProcessCheckout" method="post">
            <div class="row">
                <div class="col-lg-8">
                    <div class="card shadow mb-4">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0"><i class="fa fa-user me-2"></i>Thông Tin Khách Hàng</h5>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="CustomerName" class="form-label"></label>
                                    <input asp-for="CustomerName" class="form-control" />
                                    <span asp-validation-for="CustomerName" class="text-danger"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="CustomerPhone" class="form-label"></label>
                                    <input asp-for="CustomerPhone" class="form-control" />
                                    <span asp-validation-for="CustomerPhone" class="text-danger"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="CustomerEmail" class="form-label"></label>
                                    <input asp-for="CustomerEmail" type="email" class="form-control" />
                                    <span asp-validation-for="CustomerEmail" class="text-danger"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="PaymentMethod" class="form-label">Phương thức thanh toán <span class="text-danger">*</span></label>
                                    <select asp-for="PaymentMethod" class="form-select" id="paymentMethod" required>
                                        <option value="">Chọn phương thức</option>
                                        <option value="COD">Thanh toán khi nhận hàng (COD)</option>
                                        
                                        <option value="VNPay">VNPay (Thanh toán online)</option>
                                       
                                    </select>
                                    <span asp-validation-for="PaymentMethod" class="text-danger"></span>
                                    <small class="form-text text-muted">
                                        <i class="fa fa-info-circle"></i> Nếu chọn VNPay hoặc Momo, bạn sẽ được chuyển đến trang thanh toán sau khi đặt hàng.
                                    </small>
                                </div>
                                <div class="col-12 mb-3">
                                    <label asp-for="ShippingAddress" class="form-label"></label>
                                    <textarea asp-for="ShippingAddress" class="form-control" rows="3" placeholder="Số nhà, đường, phường/xã, quận/huyện, tỉnh/thành phố"></textarea>
                                    <span asp-validation-for="ShippingAddress" class="text-danger"></span>
                                </div>
                                <div class="col-12 mb-3">
                                    <label asp-for="Notes" class="form-label"></label>
                                    <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Ghi chú thêm (nếu có)"></textarea>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card shadow">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0"><i class="fa fa-shopping-cart me-2"></i>Đơn Hàng Của Bạn</h5>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive">
                                <table class="table">
                                    <thead>
                                        <tr>
                                            <th>Sản phẩm</th>
                                            <th>Số lượng</th>
                                            <th>Giá</th>
                                            <th>Tổng</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in cartItems)
                                        {
                                            if (item.Product != null)
                                            {
                                                var price = item.Product.SalePrice ?? item.Product.Price ?? 0;
                                                var itemTotal = price * (item.Quantity ?? 1);
                                                <tr>
                                                    <td>
                                                        <div class="d-flex align-items-center">
                                                            @if (!string.IsNullOrEmpty(item.Product.ImageUrl))
                                                            {
                                                                <img src="@item.Product.ImageUrl" alt="@item.Product.ProductName" class="img-thumbnail me-3" style="width: 60px; height: 60px; object-fit: cover;">
                                                            }
                                                            <div>
                                                                <h6 class="mb-0">@item.Product.ProductName</h6>
                                                                @if (!string.IsNullOrEmpty(item.Product.Sku))
                                                                {
                                                                    <small class="text-muted">SKU: @item.Product.Sku</small>
                                                                }
                                                            </div>
                                                        </div>
                                                    </td>
                                                    <td>@(item.Quantity ?? 1)</td>
                                                    <td>@price.ToString("N0") đ</td>
                                                    <td class="fw-bold">@itemTotal.ToString("N0") đ</td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="card shadow sticky-top" style="top: 20px;">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0"><i class="fa fa-calculator me-2"></i>Tóm Tắt</h5>
                        </div>
                        <div class="card-body">
                            <div class="d-flex justify-content-between mb-3">
                                <span>Tạm tính:</span>
                                <strong>@subtotal.ToString("N0") đ</strong>
                            </div>
                            <div class="d-flex justify-content-between mb-3">
                                <span>Phí vận chuyển:</span>
                                <strong>@shippingFee.ToString("N0") đ</strong>
                            </div>
                            <hr>
                            <div class="d-flex justify-content-between mb-4">
                                <h5>Tổng cộng:</h5>
                                <h5 class="text-primary">@totalAmount.ToString("N0") đ</h5>
                            </div>
                            <button type="submit" class="btn btn-primary w-100 py-3 mb-3">
                                <i class="fa fa-check me-2"></i>Đặt Hàng
                            </button>
                            <a href="@Url.Action("Index", "Cart")" class="btn btn-outline-secondary w-100">
                                <i class="fa fa-arrow-left me-2"></i>Quay Lại Giỏ Hàng
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>
<!-- Checkout End -->

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

