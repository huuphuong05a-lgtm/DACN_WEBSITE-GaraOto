@model IEnumerable<CarServ.MVC.Models.Cart>

@{
    ViewData["Title"] = "Giỏ Hàng";
    var totalAmount = ViewData["TotalAmount"] as decimal? ?? 0;
    var totalItems = ViewData["TotalItems"] as int? ?? 0;
}

<!-- Page Header Start -->
<div class="container-fluid page-header mb-5 p-0" style="background-image: url(/img/carousel-bg-1.jpg);">
    <div class="container-fluid page-header-inner py-5">
        <div class="container text-center pb-5">
            <h1 class="display-3 text-white mb-3 animated slideInDown">Giỏ Hàng</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb justify-content-center text-uppercase">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Trang Chủ</a></li>
                    <li class="breadcrumb-item text-white active" aria-current="page">Giỏ Hàng</li>
                </ol>
            </nav>
        </div>
    </div>
</div>
<!-- Page Header End -->

<!-- Cart Start -->
<div class="container-xxl py-5">
    <div class="container">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]?.ToString()
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]?.ToString()
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (Model != null && Model.Any())
        {
            <div class="row">
                <div class="col-lg-8">
                    <div class="table-responsive">
                        <table class="table table-bordered">
                            <thead class="bg-light">
                                <tr>
                                    <th>Sản phẩm</th>
                                    <th>Giá</th>
                                    <th>Số lượng</th>
                                    <th>Tổng tiền</th>
                                    <th>Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    if (item.Product != null)
                                    {
                                        var price = item.Product.SalePrice ?? item.Product.Price ?? 0;
                                        var itemTotal = price * (item.Quantity ?? 1);
                                        <tr data-cart-id="@item.CartId">
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    @if (!string.IsNullOrEmpty(item.Product.ImageUrl))
                                                    {
                                                        <img src="@item.Product.ImageUrl" alt="@item.Product.ProductName" class="img-thumbnail me-3" style="width: 80px; height: 80px; object-fit: cover;">
                                                    }
                                                    else
                                                    {
                                                        <img src="~/img/product-1.jpg" alt="@item.Product.ProductName" class="img-thumbnail me-3" style="width: 80px; height: 80px; object-fit: cover;">
                                                    }
                                                    <div>
                                                        <h6 class="mb-0">@item.Product.ProductName</h6>
                                                        @if (!string.IsNullOrEmpty(item.Product.Sku))
                                                        {
                                                            <small class="text-muted">SKU: @item.Product.Sku</small>
                                                        }
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                @if (item.Product.SalePrice.HasValue && item.Product.SalePrice < item.Product.Price)
                                                {
                                                    <span class="text-primary fw-bold">@item.Product.SalePrice.Value.ToString("N0") đ</span>
                                                    <br>
                                                    <small class="text-muted text-decoration-line-through">@item.Product.Price.Value.ToString("N0") đ</small>
                                                }
                                                else if (item.Product.Price.HasValue)
                                                {
                                                    <span class="text-primary fw-bold">@item.Product.Price.Value.ToString("N0") đ</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">Liên hệ</span>
                                                }
                                            </td>
                                            <td>
                                                <div class="input-group" style="width: 120px;">
                                                    <button class="btn btn-outline-secondary btn-sm" type="button" onclick="updateQuantity(@item.CartId, @((item.Quantity ?? 1) - 1))">-</button>
                                                    <input type="number" class="form-control form-control-sm text-center" value="@(item.Quantity ?? 1)" min="1" max="@(item.Product.StockQuantity ?? 999)" id="quantity-@item.CartId" onchange="updateQuantity(@item.CartId, parseInt(this.value))">
                                                    <button class="btn btn-outline-secondary btn-sm" type="button" onclick="updateQuantity(@item.CartId, @((item.Quantity ?? 1) + 1))">+</button>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="fw-bold text-primary item-total" data-item-total="@itemTotal">@itemTotal.ToString("N0") đ</span>
                                            </td>
                                            <td>
                                                <button class="btn btn-danger btn-sm" onclick="removeFromCart(@item.CartId)" title="Xóa">
                                                    <i class="fa fa-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="mt-3">
                        <a href="@Url.Action("Index", "Product")" class="btn btn-outline-primary">
                            <i class="fa fa-arrow-left me-2"></i>Tiếp Tục Mua Sắm
                        </a>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="bg-light rounded p-4">
                        <h4 class="mb-4">Tóm Tắt Đơn Hàng</h4>
                        <div class="d-flex justify-content-between mb-3">
                            <span>Tổng sản phẩm:</span>
                            <strong>@totalItems</strong>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span>Phí vận chuyển:</span>
                            <strong>0 đ</strong>
                        </div>
                        <hr>
                        <div class="d-flex justify-content-between mb-4">
                            <h5>Tổng tiền:</h5>
                            <h5 class="text-primary" id="cart-total">@totalAmount.ToString("N0") đ</h5>
                        </div>
                        <a href="@Url.Action("Checkout", "Cart")" class="btn btn-primary w-100 py-3">
                            <i class="fa fa-shopping-cart me-2"></i>Thanh Toán
                        </a>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="fa fa-shopping-cart fa-4x text-muted mb-4"></i>
                <h3 class="mb-3">Giỏ hàng của bạn đang trống</h3>
                <p class="text-muted mb-4">Hãy thêm sản phẩm vào giỏ hàng để tiếp tục mua sắm.</p>
                <a href="@Url.Action("Index", "Product")" class="btn btn-primary">
                    <i class="fa fa-shopping-bag me-2"></i>Mua Sắm Ngay
                </a>
            </div>
        }
    </div>
</div>
<!-- Cart End -->

@section Scripts {
    <script>
        function updateQuantity(cartId, quantity) {
            if (quantity < 1) {
                quantity = 1;
            }

            $.ajax({
                url: '@Url.Action("UpdateQuantity", "Cart")',
                type: 'POST',
                data: {
                    cartId: cartId,
                    quantity: quantity
                },
                success: function(response) {
                    if (response.success) {
                        // Update item total
                        var row = $('tr[data-cart-id="' + cartId + '"]');
                        var price = parseFloat(row.find('td:nth-child(2) .text-primary').text().replace(/[^\d]/g, ''));
                        if (isNaN(price)) {
                            price = parseFloat(row.find('td:nth-child(2) .text-muted').text().replace(/[^\d]/g, ''));
                        }
                        var itemTotal = price * quantity;
                        row.find('.item-total').text(itemTotal.toLocaleString('vi-VN') + ' đ').attr('data-item-total', itemTotal);
                        
                        // Update quantity input
                        $('#quantity-' + cartId).val(quantity);
                        
                        // Update cart total
                        $('#cart-total').text(response.totalAmount.toLocaleString('vi-VN') + ' đ');
                        
                        // Update cart count in header
                        updateCartCount();
                    } else {
                        alert(response.message);
                    }
                },
                error: function() {
                    alert('Có lỗi xảy ra. Vui lòng thử lại.');
                }
            });
        }

        function removeFromCart(cartId) {
            if (!confirm('Bạn có chắc chắn muốn xóa sản phẩm này khỏi giỏ hàng?')) {
                return;
            }

            $.ajax({
                url: '@Url.Action("RemoveFromCart", "Cart")',
                type: 'POST',
                data: {
                    cartId: cartId
                },
                success: function(response) {
                    if (response.success) {
                        $('tr[data-cart-id="' + cartId + '"]').fadeOut(300, function() {
                            $(this).remove();
                            location.reload(); // Reload to recalculate totals
                        });
                        updateCartCount();
                    } else {
                        alert(response.message);
                    }
                },
                error: function() {
                    alert('Có lỗi xảy ra. Vui lòng thử lại.');
                }
            });
        }

        function updateCartCount() {
            $.ajax({
                url: '@Url.Action("GetCartCount", "Cart")',
                type: 'GET',
                success: function(response) {
                    $('#cart-count').text(response.count);
                    if (response.count > 0) {
                        $('#cart-count').show();
                    } else {
                        $('#cart-count').hide();
                    }
                }
            });
        }
    </script>
}

