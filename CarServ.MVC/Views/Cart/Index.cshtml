@model IEnumerable<CarServ.MVC.Models.Cart>

@{
    ViewData["Title"] = "Giỏ Hàng";
    var totalAmount = ViewData["TotalAmount"] as decimal? ?? 0;
    var totalItems = ViewData["TotalItems"] as int? ?? 0;
}

<!-- Page Header Start -->
<div class="container-fluid page-header mb-5 p-0" style="background-image: url(/img/carousel-bg-1.jpg);">
    <div class="container-fluid page-header-inner py-5">
        <div class="container text-center pb-5">
            <h1 class="display-3 text-white mb-3 animated slideInDown">Giỏ Hàng</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb justify-content-center text-uppercase">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Trang Chủ</a></li>
                    <li class="breadcrumb-item text-white active" aria-current="page">Giỏ Hàng</li>
                </ol>
            </nav>
        </div>
    </div>
</div>
<!-- Page Header End -->

<!-- Cart Start -->
<div class="container-xxl py-5">
    <div class="container">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]?.ToString()
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]?.ToString()
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (Model != null && Model.Any())
        {
            <form asp-action="Checkout" method="get" id="cart-buy-form">
            <input type="hidden" name="fromCartSelection" value="true" />
            <div class="row">
                <div class="col-lg-8">
                    <div class="table-responsive">
                        <table class="table table-bordered cart-table">
                            <thead class="bg-light">
                                <tr>
                                    <th style="width: 48px;">
                                        <input type="checkbox" class="form-check-input cart-select-all" id="cart-select-all" checked>
                                    </th>
                                    <th class="col-product">Sản phẩm</th>
                                    <th class="col-price">Giá</th>
                                    <th class="col-quantity">Số lượng</th>
                                    <th class="col-total">Tổng tiền</th>
                                    <th class="col-action">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    if (item.Product != null)
                                    {
                                        var price = item.Product.SalePrice ?? item.Product.Price ?? 0;
                                        var itemTotal = price * (item.Quantity ?? 1);
                                        <tr data-cart-id="@item.CartId">
                                            <td class="text-center align-middle">
                                                <input type="checkbox" class="form-check-input cart-item-select" name="selectedCartIds" value="@item.CartId" data-total="@itemTotal" data-quantity="@(item.Quantity ?? 1)" checked>
                                            </td>
                                            <td class="col-product">
                                                <div class="cart-product-cell">
                                                    @if (!string.IsNullOrEmpty(item.Product.ImageUrl))
                                                    {
                                                        <img src="@item.Product.ImageUrl" alt="@item.Product.ProductName" class="cart-product-img">
                                                    }
                                                    else
                                                    {
                                                        <img src="~/img/product-1.jpg" alt="@item.Product.ProductName" class="cart-product-img">
                                                    }
                                                    <div>
                                                        <h6 class="cart-product-name">@item.Product.ProductName</h6>
                                                        @if (!string.IsNullOrEmpty(item.Product.Sku))
                                                        {
                                                            <small class="cart-product-sku">SKU: @item.Product.Sku</small>
                                                        }
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="col-price">
                                                @if (item.Product.SalePrice.HasValue && item.Product.SalePrice < item.Product.Price)
                                                {
                                                    <span class="text-primary fw-bold">@item.Product.SalePrice.Value.ToString("N0") đ</span>
                                                    <br>
                                                    <small class="text-muted text-decoration-line-through">@item.Product.Price.Value.ToString("N0") đ</small>
                                                }
                                                else if (item.Product.Price.HasValue)
                                                {
                                                    <span class="text-primary fw-bold">@item.Product.Price.Value.ToString("N0") đ</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">Liên hệ</span>
                                                }
                                            </td>
                                            <td class="col-quantity">
                                                <div class="quantity-group cart-quantity-control">
                                                    <button class="quantity-btn" type="button" onclick="changeQuantity(@item.CartId, -1)" aria-label="Giảm số lượng">-</button>
                                                    <input type="number" class="quantity-input cart-quantity-input" value="@(item.Quantity ?? 1)" min="1" max="@(item.Product.StockQuantity ?? 999)" id="quantity-@item.CartId" onchange="updateQuantity(@item.CartId, parseInt(this.value) || 1)">
                                                    <button class="quantity-btn" type="button" onclick="changeQuantity(@item.CartId, 1)" aria-label="Tăng số lượng">+</button>
                                                </div>
                                            </td>
                                            <td class="col-total">
                                                <span class="fw-bold text-primary item-total" data-item-total="@itemTotal">@itemTotal.ToString("N0") đ</span>
                                            </td>
                                            <td class="col-action">
                                                <button type="button" class="cart-remove-btn" onclick="removeFromCart(@item.CartId)" title="Xóa">
                                                    <i class="fa fa-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="mt-3">
                        <a href="@Url.Action("Index", "Product")" class="btn btn-outline-primary">
                            <i class="fa fa-arrow-left me-2"></i>Tiếp Tục Mua Sắm
                        </a>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="order-summary-box">
                        <h4 class="cart-summary-title">Tóm Tắt Đơn Hàng</h4>
                        <div class="summary-row">
                            <span>Tổng sản phẩm:</span>
                            <strong id="cart-selected-count">@totalItems</strong>
                        </div>
                        <div class="summary-row">
                            <span>Phí vận chuyển:</span>
                            <strong class="text-success">Miễn phí</strong>
                        </div>
                        <div class="summary-total-row">
                            <span class="summary-total-label">Tổng tiền:</span>
                            <span class="summary-total-price" id="cart-total">@totalAmount.ToString("N0") đ</span>
                        </div>
                        <button type="submit" class="btn-checkout" id="cart-buy-button">
                            <i class="fa fa-shopping-cart"></i>Mua Hàng
                        </button>
                    </div>
                </div>
            </div>
            </form>
        }
        else
        {
            <div class="text-center py-5">
                <i class="fa fa-shopping-cart fa-4x text-muted mb-4"></i>
                <h3 class="mb-3">Giỏ hàng của bạn đang trống</h3>
                <p class="text-muted mb-4">Hãy thêm sản phẩm vào giỏ hàng để tiếp tục mua sắm.</p>
                <a href="@Url.Action("Index", "Product")" class="btn btn-primary">
                    <i class="fa fa-shopping-bag me-2"></i>Mua Sắm Ngay
                </a>
            </div>
        }
    </div>
</div>
<!-- Cart End -->

@section Scripts {
    @Html.AntiForgeryToken()
    <script>
        const antiForgeryToken = $('input[name="__RequestVerificationToken"]').val();

        function changeQuantity(cartId, delta) {
            var input = $('#quantity-' + cartId);
            var current = parseInt(input.val(), 10) || 1;
            var min = parseInt(input.attr('min'), 10) || 1;
            var max = parseInt(input.attr('max'), 10) || 999;
            var next = Math.min(Math.max(current + delta, min), max);

            updateQuantity(cartId, next);
        }

        function updateQuantity(cartId, quantity) {
            if (quantity < 1) {
                quantity = 1;
            }

            $.ajax({
                url: '@Url.Action("UpdateQuantity", "Cart")',
                type: 'POST',
                data: {
                    __RequestVerificationToken: antiForgeryToken,
                    cartId: cartId,
                    quantity: quantity
                },
                success: function(response) {
                    if (response.success) {
                        // Update item total
                        var row = $('tr[data-cart-id="' + cartId + '"]');
                        var price = parseFloat(row.find('td:nth-child(3) .text-primary').text().replace(/[^\d]/g, ''));
                        if (isNaN(price)) {
                            price = parseFloat(row.find('td:nth-child(3) .text-muted').text().replace(/[^\d]/g, ''));
                        }
                        var itemTotal = price * quantity;
                        row.find('.item-total').text(itemTotal.toLocaleString('vi-VN') + ' đ').attr('data-item-total', itemTotal);
                        row.find('.cart-item-select').attr('data-total', itemTotal).attr('data-quantity', quantity);
                        
                        // Update quantity input
                        $('#quantity-' + cartId).val(quantity);
                        
                        // Update selected cart summary
                        updateSelectedCartSummary();
                        
                        // Update cart count in header
                        updateCartCount();
                    } else {
                        alert(response.message);
                    }
                },
                error: function() {
                    alert('Có lỗi xảy ra. Vui lòng thử lại.');
                }
            });
        }

        function removeFromCart(cartId) {
            if (!confirm('Bạn có chắc chắn muốn xóa sản phẩm này khỏi giỏ hàng?')) {
                return;
            }

            $.ajax({
                url: '@Url.Action("RemoveFromCart", "Cart")',
                type: 'POST',
                data: {
                    __RequestVerificationToken: antiForgeryToken,
                    cartId: cartId
                },
                success: function(response) {
                    if (response.success) {
                        $('tr[data-cart-id="' + cartId + '"]').fadeOut(300, function() {
                            $(this).remove();
                            location.reload(); // Reload to recalculate totals
                        });
                        updateCartCount();
                    } else {
                        alert(response.message);
                    }
                },
                error: function() {
                    alert('Có lỗi xảy ra. Vui lòng thử lại.');
                }
            });
        }

        function updateCartCount() {
            $.ajax({
                url: '@Url.Action("GetCartCount", "Cart")',
                type: 'GET',
                success: function(response) {
                    $('#cart-count').text(response.count);
                    if (response.count > 0) {
                        $('#cart-count').show();
                    } else {
                        $('#cart-count').hide();
                    }
                }
            });
        }

        function updateSelectedCartSummary() {
            var selectedTotal = 0;
            var selectedCount = 0;
            var selectedItems = $('.cart-item-select:checked');

            selectedItems.each(function () {
                selectedTotal += parseFloat($(this).attr('data-total')) || 0;
                selectedCount += parseInt($(this).attr('data-quantity'), 10) || 0;
            });

            $('#cart-selected-count').text(selectedCount);
            $('#cart-total').text(selectedTotal.toLocaleString('vi-VN') + ' đ');
            $('#cart-buy-button').prop('disabled', selectedItems.length === 0);

            var allItems = $('.cart-item-select');
            $('#cart-select-all').prop('checked', allItems.length > 0 && selectedItems.length === allItems.length);
        }

        $(document).on('change', '.cart-item-select', updateSelectedCartSummary);

        $('#cart-select-all').on('change', function () {
            $('.cart-item-select').prop('checked', this.checked);
            updateSelectedCartSummary();
        });

        $('#cart-buy-form').on('submit', function (e) {
            if ($('.cart-item-select:checked').length === 0) {
                e.preventDefault();
                alert('Vui lòng chọn ít nhất một sản phẩm để mua hàng.');
            }
        });

        $(document).ready(updateSelectedCartSummary);
    </script>
}

