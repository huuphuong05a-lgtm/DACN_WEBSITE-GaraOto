@model CarServ.MVC.Models.Vehicle
@using CarServ.MVC.Models

@{
    ViewData["Title"] = "Chi tiết xe";
    var vehicleName = string.Join(" ", new[]
    {
        Model.Brand?.BrandName,
        Model.Model?.ModelName,
        Model.Year?.ToString()
    }.Where(value => !string.IsNullOrWhiteSpace(value)));
    var upcomingAppointments = Model.Appointments
        .Where(a => a.AppointmentDate >= DateTime.Now
            && a.Status != AppConstants.AppointmentStatus.Canceled
            && a.Status != AppConstants.AppointmentStatus.Completed
            && a.Status != AppConstants.AppointmentStatus.NoShow)
        .OrderBy(a => a.AppointmentDate)
        .ToList();
    var histories = Model.ServiceHistories
        .OrderByDescending(h => h.ServiceDate)
        .ToList();
    var latestHistory = histories.FirstOrDefault();
    var nextDateDue = latestHistory?.NextServiceDate.HasValue == true
        && latestHistory.NextServiceDate.Value.Date <= DateTime.Today.AddDays(30);
    var nextMileageDue = latestHistory?.NextServiceMileage.HasValue == true
        && Model.Mileage.HasValue
        && latestHistory.NextServiceMileage.Value - Model.Mileage.Value <= 500;
    var hasMaintenanceReminder = nextDateDue || nextMileageDue;
    var invoices = Model.Invoices
        .OrderByDescending(i => i.InvoiceDate)
        .ToList();
}

<div class="container-fluid page-header mb-5 p-0" style="background-image: url(/img/carousel-bg-1.jpg);">
    <div class="container-fluid page-header-inner py-5">
        <div class="container text-center">
            <h1 class="display-3 text-white mb-3 animated slideInDown">@Model.LicensePlate</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb justify-content-center text-uppercase">
                    <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Action("Vehicles", "Customer")">Xe của tôi</a></li>
                    <li class="breadcrumb-item text-white active" aria-current="page">Chi tiết xe</li>
                </ol>
            </nav>
        </div>
    </div>
</div>

<div class="container-xxl py-5">
    <div class="container">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
            <div>
                <p class="text-primary text-uppercase fw-bold mb-1" style="font-size: 12px; letter-spacing: 2px;">Garage profile</p>
                <h3 class="mb-1">@Model.LicensePlate</h3>
                <p class="text-muted mb-0">@(Model.VehicleName ?? vehicleName)</p>
            </div>
            <div class="d-flex gap-2">
                <a href="@Url.Action("Index", "Booking")" class="btn btn-outline-primary">
                    <i class="fa fa-calendar-plus me-2"></i>Đặt lịch
                </a>
                <a href="@Url.Action("EditVehicle", "Customer", new { id = Model.VehicleId })" class="btn btn-primary">
                    <i class="fa fa-edit me-2"></i>Sửa xe
                </a>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-md-3">
                <div class="bg-light rounded p-4 h-100">
                    <small class="text-muted d-block">Hãng / dòng</small>
                    <strong>@(string.IsNullOrWhiteSpace(vehicleName) ? "-" : vehicleName)</strong>
                </div>
            </div>
            <div class="col-md-3">
                <div class="bg-light rounded p-4 h-100">
                    <small class="text-muted d-block">Số km</small>
                    <strong>@(Model.Mileage.HasValue ? Model.Mileage.Value.ToString("N0") + " km" : "-")</strong>
                </div>
            </div>
            <div class="col-md-3">
                <div class="bg-light rounded p-4 h-100">
                    <small class="text-muted d-block">Lịch hẹn sắp tới</small>
                    <strong>@upcomingAppointments.Count</strong>
                </div>
            </div>
            <div class="col-md-3">
                <div class="bg-light rounded p-4 h-100">
                    <small class="text-muted d-block">Lịch sử sửa chữa</small>
                    <strong>@histories.Count</strong>
                </div>
            </div>
        </div>

        @if (hasMaintenanceReminder)
        {
            <div class="alert alert-warning mb-4">
                <div class="d-flex align-items-start gap-3">
                    <i class="fa fa-bell mt-1"></i>
                    <div>
                        <strong>Xe sắp đến hạn bảo dưỡng.</strong>
                        <div>
                            @if (latestHistory?.NextServiceDate.HasValue == true)
                            {
                                <span>Ngày gợi ý: @latestHistory.NextServiceDate.Value.ToString("dd/MM/yyyy"). </span>
                            }
                            @if (latestHistory?.NextServiceMileage.HasValue == true)
                            {
                                <span>Mốc km: @latestHistory.NextServiceMileage.Value.ToString("N0") km.</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="row g-4">
            <div class="col-lg-5">
                <div class="bg-light rounded p-4 mb-4">
                    <h5 class="mb-3">Thông tin xe</h5>
                    <dl class="row mb-0">
                        <dt class="col-5">Biển số</dt>
                        <dd class="col-7">@Model.LicensePlate</dd>
                        <dt class="col-5">Màu sắc</dt>
                        <dd class="col-7">@(Model.Color ?? "-")</dd>
                        <dt class="col-5">Nhiên liệu</dt>
                        <dd class="col-7">@(Model.FuelType ?? "-")</dd>
                        <dt class="col-5">Số khung</dt>
                        <dd class="col-7">@(Model.ChassisNumber ?? "-")</dd>
                        <dt class="col-5">Số máy</dt>
                        <dd class="col-7">@(Model.EngineNumber ?? "-")</dd>
                        <dt class="col-5">Ghi chú</dt>
                        <dd class="col-7">@(Model.Notes ?? "-")</dd>
                    </dl>
                </div>

                <div class="bg-light rounded p-4">
                    <h5 class="mb-3">Hóa đơn liên quan</h5>
                    @if (!invoices.Any())
                    {
                        <p class="text-muted mb-0">Chưa có hóa đơn cho xe này.</p>
                    }
                    else
                    {
                        @foreach (var invoice in invoices.Take(5))
                        {
                            <div class="d-flex justify-content-between border-bottom py-2">
                                <div>
                                    <strong>@invoice.InvoiceCode</strong>
                                    <small class="text-muted d-block">@invoice.InvoiceDate.ToString("dd/MM/yyyy")</small>
                                </div>
                                <strong>@invoice.TotalAmount.ToString("N0") đ</strong>
                            </div>
                        }
                    }
                </div>
            </div>

            <div class="col-lg-7">
                <div class="bg-light rounded p-4 mb-4">
                    <h5 class="mb-3">Lịch hẹn sắp tới</h5>
                    @if (!upcomingAppointments.Any())
                    {
                        <p class="text-muted mb-0">Chưa có lịch hẹn sắp tới.</p>
                    }
                    else
                    {
                        @foreach (var appointment in upcomingAppointments)
                        {
                            <div class="bg-white rounded p-3 mb-2">
                                <div class="d-flex justify-content-between">
                                    <strong>@appointment.AppointmentDate.ToString("dd/MM/yyyy HH:mm")</strong>
                                    <span class="badge bg-info">@appointment.Status</span>
                                </div>
                                <div>@(appointment.Service?.ServiceName ?? appointment.ServiceType)</div>
                                <small class="text-muted">Kỹ thuật viên: @(appointment.Technician?.FullName ?? "Chưa phân công")</small>
                            </div>
                        }
                    }
                </div>

                <div class="bg-light rounded p-4">
                    <h5 class="mb-3">Lịch sử sửa chữa</h5>
                    @if (!histories.Any())
                    {
                        <p class="text-muted mb-0">Chưa có lịch sử sửa chữa.</p>
                    }
                    else
                    {
                        @foreach (var history in histories)
                        {
                            <div class="bg-white rounded p-3 mb-2">
                                <div class="d-flex justify-content-between">
                                    <strong>@history.ServiceDate.ToString("dd/MM/yyyy")</strong>
                                    <span>@(history.TotalCost.HasValue ? history.TotalCost.Value.ToString("N0") + " đ" : "-")</span>
                                </div>
                                <div>@(history.Service?.ServiceName ?? history.ServiceName ?? "-")</div>
                                <small class="text-muted">
                                    Kỹ thuật viên: @(history.Technician?.FullName ?? "-")
                                    @if (history.Mileage.HasValue)
                                    {
                                        <text> | @history.Mileage.Value.ToString("N0") km</text>
                                    }
                                </small>
                                @if (!string.IsNullOrWhiteSpace(history.PartsReplaced))
                                {
                                    <div class="mt-2"><strong>Phụ tùng:</strong> @history.PartsReplaced</div>
                                }
                                @if (history.NextServiceDate.HasValue || history.NextServiceMileage.HasValue)
                                {
                                    <div class="mt-2 text-primary">
                                        <strong>Bảo dưỡng tiếp theo:</strong>
                                        @(history.NextServiceDate?.ToString("dd/MM/yyyy") ?? "-")
                                        @if (history.NextServiceMileage.HasValue)
                                        {
                                            <text> | @history.NextServiceMileage.Value.ToString("N0") km</text>
                                        }
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(history.Notes))
                                {
                                    <p class="mb-0 mt-2">@history.Notes</p>
                                }
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>
