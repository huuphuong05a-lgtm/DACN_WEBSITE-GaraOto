<!-- Team Start -->
@{
    var technicians = (ViewData["Technicians"] as List<CarServ.MVC.Models.Technician>) ?? new List<CarServ.MVC.Models.Technician>();
}
<div class="container-xxl py-5">
    <div class="container">
        <div class="text-center wow fadeInUp" data-wow-delay="0.1s">
            <h6 class="text-primary text-uppercase">// Đội Ngũ Kỹ Thuật Viên //</h6>
            <h1 class="mb-5">Kỹ Thuật Viên Chuyên Nghiệp Của Chúng Tôi</h1>
        </div>
        <div class="row g-4">
            @if (technicians.Any())
            {
                @foreach (var technician in technicians)
                {
                    <div class="col-lg-3 col-md-6 wow fadeInUp" data-wow-delay="0.1s">
                        <div class="team-item">
                            <div class="position-relative overflow-hidden">
                                @if (!string.IsNullOrEmpty(technician.ImageUrl))
                                {
                                    <img class="img-fluid" src="@technician.ImageUrl" alt="@technician.FullName" style="width: 100%; height: 300px; object-fit: cover;">
                                }
                                else
                                {
                                    <img class="img-fluid" src="~/img/team-1.jpg" alt="@technician.FullName" style="width: 100%; height: 300px; object-fit: cover;">
                                }
                                <div class="team-overlay position-absolute start-0 top-0 w-100 h-100">
                                    <a class="btn btn-square mx-1" href="@Url.Action("Details", "Technician", new { id = technician.TechnicianId })">
                                        <i class="fa fa-eye"></i>
                                    </a>
                                </div>
                            </div>
                            <div class="bg-light text-center p-4">
                                <h5 class="fw-bold mb-0">@technician.FullName</h5>
                                @if (!string.IsNullOrEmpty(technician.Position))
                                {
                                    <small>@technician.Position</small>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center">
                    <p class="text-muted">Chưa có kỹ thuật viên nào.</p>
                </div>
            }
        </div>
        @if (technicians.Any())
        {
            <div class="text-center mt-4">
                <a href="@Url.Action("Index", "Technician")" class="btn btn-primary py-3 px-5">Xem Tất Cả Kỹ Thuật Viên</a>
            </div>
        }
    </div>
</div>
<!-- Team End -->