<!-- Hero Start -->
@{
    var banners = (ViewData["Banners"] as List<CarServ.MVC.Models.Banner>) ?? new List<CarServ.MVC.Models.Banner>();
}
<div class="container-fluid p-0">
    <div id="header-carousel" class="carousel slide carousel-fade" data-bs-ride="carousel" data-bs-interval="6000">
        <div class="carousel-inner">
            @if (banners.Any())
            {
                @for (int i = 0; i < banners.Count; i++)
                {
                    var banner = banners[i];
                    <div class="carousel-item @(i == 0 ? "active" : "")">
                        <img class="w-100" src="@(banner.ImageUrl ?? "~/img/carousel-bg-1.jpg")" alt="@(banner.Title ?? "Banner")" style="height: 100vh; object-fit: cover; filter: brightness(0.7);">
                        <div class="carousel-caption d-flex align-items-center" style="background: linear-gradient(100deg, rgba(0,0,0,0.82) 0%, rgba(0,0,0,0.5) 40%, rgba(0,0,0,0.15) 70%, transparent 100%);">
                            <div class="container">
                                <div class="row">
                                    <div class="col-lg-8 col-xl-7 text-start">
                                        @if (!string.IsNullOrEmpty(banner.Subtitle))
                                        {
                                            <div class="d-flex align-items-center gap-3 mb-4 animated fadeInDown">
                                                <div style="width: 40px; height: 2px; background: #E11D2E;"></div>
                                                <span class="text-uppercase" style="font-size: 11px; letter-spacing: 5px; font-weight: 600; color: rgba(255,255,255,0.6);">@banner.Subtitle</span>
                                            </div>
                                        }
                                        <h1 class="text-white mb-4 animated fadeInUp" style="font-family:'Montserrat',sans-serif; font-weight:700; font-size:clamp(2rem, 3.5vw, 3rem); line-height: 1.2; letter-spacing: -0.5px; text-shadow: 0 2px 40px rgba(0,0,0,0.3); max-width: 750px; text-wrap: balance;">@(banner.Title ?? "NHP-AUTO Premium")</h1>
                                        @if (!string.IsNullOrEmpty(banner.Description))
                                        {
                                            <p class="mb-5 animated fadeInUp" style="color: rgba(255,255,255,0.8); font-size: 16px; line-height: 1.8; max-width: 500px;">@banner.Description</p>
                                        }
                                        @if (!string.IsNullOrEmpty(banner.LinkUrl))
                                        {
                                            <a href="@banner.LinkUrl" class="btn btn-primary d-inline-flex align-items-center animated fadeInUp" style="font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; padding: 14px 32px; border-radius: 4px; box-shadow: 0 4px 24px rgba(225,29,46,0.35);">
                                                @(banner.ButtonText ?? "Khám Phá") <i class="fa fa-arrow-right ms-2" style="font-size: 11px;"></i>
                                            </a>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="carousel-item active">
                    <img class="w-100" src="~/img/carousel-bg-1.jpg" alt="NHP-AUTO Hero" style="height: 100vh; object-fit: cover; filter: brightness(0.65);">
                    <div class="carousel-caption d-flex align-items-center" style="background: linear-gradient(100deg, rgba(0,0,0,0.82) 0%, rgba(0,0,0,0.5) 40%, rgba(0,0,0,0.15) 70%, transparent 100%);">
                        <div class="container">
                            <div class="row">
                                <div class="col-lg-8 col-xl-7 text-start">
                                    <div class="d-flex align-items-center gap-3 mb-4 animated fadeInDown">
                                        <div style="width: 40px; height: 2px; background: #E11D2E;"></div>
                                        <span class="text-uppercase" style="font-size: 12px; letter-spacing: 4px; font-weight: 700; color: rgba(255,255,255,0.7);">Dịch Vụ Ô Tô Cao Cấp</span>
                                    </div>
                                    <h1 class="text-white mb-4 animated fadeInUp" style="font-family:'Montserrat',sans-serif; font-weight:700; font-size:clamp(2rem, 3.5vw, 3rem); line-height: 1.2; letter-spacing: -0.5px; text-shadow: 0 2px 40px rgba(0,0,0,0.3); max-width: 750px; text-wrap: balance;">
                                        Chăm Sóc &amp; Sửa Chữa Ô Tô Chuyên Nghiệp
                                    </h1>
                                    <p class="mb-5 animated fadeInUp" style="color: rgba(255,255,255,0.8); font-size: 16px; line-height: 1.8; max-width: 500px;">
                                        Công nghệ hiện đại, đội ngũ kỹ sư hàng đầu — mang đến hiệu suất và diện mạo hoàn hảo nhất cho chiếc xe của bạn.
                                    </p>
                                    <div class="d-flex flex-wrap align-items-center gap-3 animated fadeInUp">
                                        <a href="@Url.Action("Index", "Booking")" class="btn btn-primary d-inline-flex align-items-center" style="font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; padding: 14px 32px; border-radius: 4px; box-shadow: 0 6px 28px rgba(225,29,46,0.4); border: none;">
                                            Đặt Lịch Ngay <i class="fa fa-arrow-right ms-2"></i>
                                        </a>
                                        <a href="@Url.Action("Index", "Service")" class="btn d-inline-flex align-items-center" style="font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; padding: 14px 32px; border-radius: 4px; background: rgba(255,255,255,0.08); color: #fff; border: 1px solid rgba(255,255,255,0.25); backdrop-filter: blur(8px);">
                                            Khám Phá Dịch Vụ
                                        </a>
                                    </div>
                                    <!-- Trust badges -->
                                    <div class="d-flex flex-wrap gap-4 mt-5 animated fadeInUp" style="animation-delay: 0.6s;">
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="d-flex align-items-center justify-content-center rounded-circle" style="width: 36px; height: 36px; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.12);">
                                                <i class="fa fa-star" style="font-size: 12px; color: #E11D2E;"></i>
                                            </div>
                                            <div>
                                                <span class="d-block text-white fw-bold" style="font-size: 14px; line-height: 1.2;">15+ Năm</span>
                                                <span style="font-size: 11px; color: rgba(255,255,255,0.4);">Kinh Nghiệm</span>
                                            </div>
                                        </div>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="d-flex align-items-center justify-content-center rounded-circle" style="width: 36px; height: 36px; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.12);">
                                                <i class="fa fa-users" style="font-size: 12px; color: #E11D2E;"></i>
                                            </div>
                                            <div>
                                                <span class="d-block text-white fw-bold" style="font-size: 14px; line-height: 1.2;">12,000+</span>
                                                <span style="font-size: 11px; color: rgba(255,255,255,0.4);">Khách Hàng</span>
                                            </div>
                                        </div>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="d-flex align-items-center justify-content-center rounded-circle" style="width: 36px; height: 36px; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.12);">
                                                <i class="fa fa-shield-alt" style="font-size: 12px; color: #E11D2E;"></i>
                                            </div>
                                            <div>
                                                <span class="d-block text-white fw-bold" style="font-size: 14px; line-height: 1.2;">100%</span>
                                                <span style="font-size: 11px; color: rgba(255,255,255,0.4);">Bảo Hành</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="carousel-item">
                    <img class="w-100" src="~/img/carousel-bg-2.jpg" alt="NHP-AUTO Service" style="height: 100vh; object-fit: cover; filter: brightness(0.65);">
                    <div class="carousel-caption d-flex align-items-center" style="background: linear-gradient(100deg, rgba(0,0,0,0.82) 0%, rgba(0,0,0,0.5) 40%, rgba(0,0,0,0.15) 70%, transparent 100%);">
                        <div class="container">
                            <div class="row">
                                <div class="col-lg-8 col-xl-7 text-start">
                                    <div class="d-flex align-items-center gap-3 mb-4 animated fadeInDown">
                                        <div style="width: 40px; height: 2px; background: #E11D2E;"></div>
                                        <span class="text-uppercase" style="font-size: 12px; letter-spacing: 4px; font-weight: 700; color: rgba(255,255,255,0.7);">Uy Tín · Chất Lượng · Tận Tâm</span>
                                    </div>
                                    <h1 class="text-white mb-4 animated fadeInUp" style="font-family:'Montserrat',sans-serif; font-weight:700; font-size:clamp(2rem, 3.5vw, 3rem); line-height: 1.25; letter-spacing: -0.5px; text-shadow: 0 2px 40px rgba(0,0,0,0.3); max-width: 750px;">
                                        Hơn 15 Năm Đồng Hành<br>
                                        Cùng Xế Yêu Của Bạn
                                    </h1>
                                    <p class="mb-5 animated fadeInUp" style="color: rgba(255,255,255,0.8); font-size: 16px; line-height: 1.8; max-width: 500px;">
                                        Được tin tưởng bởi hơn 12,000 khách hàng. Cam kết tiêu chuẩn dịch vụ ngang tầm quốc tế.
                                    </p>
                                    <div class="d-flex flex-wrap align-items-center gap-3 animated fadeInUp">
                                        <a href="@Url.Action("About", "Home")" class="btn btn-primary d-inline-flex align-items-center" style="font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; padding: 14px 32px; border-radius: 4px; box-shadow: 0 6px 28px rgba(225,29,46,0.4); border: none;">
                                            Về Chúng Tôi <i class="fa fa-arrow-right ms-2"></i>
                                        </a>
                                        <a href="@Url.Action("Index", "Contact")" class="btn d-inline-flex align-items-center" style="font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; padding: 14px 32px; border-radius: 4px; background: rgba(255,255,255,0.08); color: #fff; border: 1px solid rgba(255,255,255,0.25); backdrop-filter: blur(8px);">
                                            Liên Hệ Ngay
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
        <!-- Nav arrows -->
        <button class="carousel-control-prev" type="button" data-bs-target="#header-carousel" data-bs-slide="prev" style="width: 6%;">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#header-carousel" data-bs-slide="next" style="width: 6%;">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
        </button>
        <!-- Scroll indicator -->
        <div class="position-absolute bottom-0 start-50 translate-middle-x mb-4 animated fadeInUp" style="z-index:10; animation-delay: 1s;">
            <div class="d-flex flex-column align-items-center text-white" style="opacity: 0.4;">
                <div style="width: 1px; height: 40px; background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.6)); margin-bottom: 6px;"></div>
                <span class="text-uppercase" style="font-size: 9px; letter-spacing: 3px;">Scroll</span>
            </div>
        </div>
    </div>
</div>
<style>
    @@keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(6px)} }
</style>
<!-- Hero End -->

