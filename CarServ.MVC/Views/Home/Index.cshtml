                                    <a href="@Url.Action("Index", "Service")" class="btn btn-outline-dark d-inline-flex align-items-center" style="border-radius: 6px; padding: 12px 28px; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; border-width: 1.5px; transition: all 0.3s ease;" onmouseover="this.style.background='#E11D2E'; this.style.borderColor='#E11D2E'; this.style.color='#fff';" onmouseout="this.style.background='transparent'; this.style.borderColor='#212529'; this.style.color='#212529';">
                                        Xem Spa <i class="fa fa-arrow-right ms-2" style="font-size: 11px;"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Services Explore End -->

<!-- Booking CTA Start -->
<div class="container-fluid bg-dark py-5">
    <div class="container py-4">
        <div class="row align-items-center g-5">
            <div class="col-lg-7 text-center text-lg-start">
                <p class="text-primary text-uppercase fw-bold mb-2" style="font-size: 12px; letter-spacing: 3px;">Đặt Lịch Hẹn</p>
                <h2 class="text-white fw-bold mb-3" style="font-size: clamp(1.4rem, 3vw, 1.8rem); line-height: 1.3;">Dịch Vụ Xứng Tầm Phân Khúc Hạng Sang</h2>
                <p class="text-white-50 mb-0" style="font-size: 14px; line-height: 1.7; max-width: 500px;">Đặt lịch trước để tiết kiệm thời gian chờ đợi. Cố vấn dịch vụ sẽ liên hệ bạn trong 5 phút.</p>
            </div>
            <div class="col-lg-5 text-center text-lg-end">
                <div class="bg-white p-4 w-100" style="border-radius: 16px;">
                    <h5 class="fw-bold text-dark mb-3" style="font-size: 15px;">Đặt Lịch Nhanh Chóng</h5>
                    <p class="text-muted mb-3" style="font-size: 13px;">Để lại thông tin, chúng tôi sẽ phản hồi ngay.</p>
                    <a href="@Url.Action("Index", "Booking")" class="btn btn-primary rounded-pill w-100 py-2" style="font-size: 13px;">Đến Trang Đặt Lịch <i class="fa fa-arrow-right ms-2" style="font-size: 11px;"></i></a>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Booking CTA End -->

<!-- Team Start -->
@{
    var technicians = (ViewData["Technicians"] as List<CarServ.MVC.Models.Technician>) ?? new List<CarServ.MVC.Models.Technician>();
}
<div class="container-xxl py-5">
    <div class="container">
        <div class="text-center wow fadeInUp mb-5" data-wow-delay="0.1s">
            <p class="text-primary text-uppercase fw-bold mb-2" style="font-size: 12px; letter-spacing: 3px;">Đội Ngũ Chuyên Gia</p>
            <h2 class="fw-bold text-dark" style="font-size: clamp(1.4rem, 3vw, 1.8rem);">Những Người Làm Nên Chất Lượng</h2>
        </div>
        <div class="row g-4">
            @if (technicians.Any())
            {
                @foreach (var technician in technicians.Take(4))
                {
                    <div class="col-lg-3 col-md-6 wow fadeInUp" data-wow-delay="0.1s">
                        <div class="card team-item border-0 h-100 bg-white" style="border-radius: 14px; overflow: hidden;">
                            <div class="position-relative overflow-hidden">
                                @if (!string.IsNullOrEmpty(technician.ImageUrl))
                                {
                                    <img class="img-fluid w-100" src="@technician.ImageUrl" alt="@technician.FullName" style="height: 280px; object-fit: cover;">
                                }
                                else
                                {
                                    <img class="img-fluid w-100" src="~/img/team-1.jpg" alt="@technician.FullName" style="height: 280px; object-fit: cover;">
                                }
                                <div class="team-overlay position-absolute start-0 top-0 w-100 h-100">
                                    <a class="btn btn-square btn-primary rounded-circle" href="@Url.Action("Details", "Technician", new { id = technician.TechnicianId })" style="width:36px;height:36px;">
                                        <i class="fa fa-user-circle" style="font-size:13px;"></i>
                                    </a>
                                </div>
                            </div>
                            <div class="card-body text-center p-3">
                                <h6 class="fw-bold mb-0 text-dark" style="font-size: 14px;">@technician.FullName</h6>
                                @if (!string.IsNullOrEmpty(technician.Position))
                                {
                                    <small class="text-muted" style="font-size: 12px;">@technician.Position</small>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center">
                    <div class="p-4 bg-light" style="border-radius: 14px;">
                        <i class="fa fa-users fa-2x text-muted mb-2"></i>
                        <p class="text-muted mb-0" style="font-size: 14px;">Chưa có thông tin chuyên gia.</p>
                    </div>
                </div>
            }
        </div>
        @if (technicians.Any())
        {
            <div class="text-center mt-4">
                <a href="@Url.Action("Index", "Technician")" class="btn btn-outline-dark rounded-pill px-4 py-2" style="font-size: 13px;">Xem Toàn Bộ Đội Ngũ</a>
            </div>
        }
    </div>
</div>
<!-- Team End -->