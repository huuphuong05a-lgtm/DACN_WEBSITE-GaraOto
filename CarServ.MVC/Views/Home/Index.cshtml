<!-- Carousel Start -->
@{
    var banners = (ViewData["Banners"] as List<CarServ.MVC.Models.Banner>) ?? new List<CarServ.MVC.Models.Banner>();
}
<div class="container-fluid p-0 mb-5">
    <div id="header-carousel" class="carousel slide" data-bs-ride="carousel">
        <div class="carousel-inner">
            @if (banners.Any())
            {
                @for (int i = 0; i < banners.Count; i++)
                {
                    var banner = banners[i];
                    <div class="carousel-item @(i == 0 ? "active" : "")">
                        <img class="w-100" src="@(banner.ImageUrl ?? "~/img/carousel-bg-1.jpg")" alt="@(banner.Title ?? "Banner")">
                        <div class="carousel-caption d-flex align-items-center">
                            <div class="container">
                                <div class="row align-items-center justify-content-center justify-content-lg-start">
                                    <div class="col-10 col-lg-7 text-center text-lg-start">
                                        @if (!string.IsNullOrEmpty(banner.Subtitle))
                                        {
                                            <h6 class="text-white text-uppercase mb-3 animated slideInDown">@banner.Subtitle</h6>
                                        }
                                        <h1 class="display-3 text-white mb-4 pb-3 animated slideInDown">@(banner.Title ?? "CarServ")</h1>
                                        @if (!string.IsNullOrEmpty(banner.Description))
                                        {
                                            <p class="text-white mb-4 animated slideInDown">@banner.Description</p>
                                        }
                                        @if (!string.IsNullOrEmpty(banner.LinkUrl))
                                        {
                                            <a href="@banner.LinkUrl" class="btn btn-primary py-3 px-5 animated slideInDown">
                                                @(banner.ButtonText ?? "Tìm Hiểu Thêm")<i class="fa fa-arrow-right ms-3"></i>
                                            </a>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="carousel-item active">
                    <img class="w-100" src="~/img/carousel-bg-1.jpg" alt="Image">
                    <div class="carousel-caption d-flex align-items-center">
                        <div class="container">
                            <div class="row align-items-center justify-content-center justify-content-lg-start">
                                <div class="col-10 col-lg-7 text-center text-lg-start">
                                    <h6 class="text-white text-uppercase mb-3 animated slideInDown">// Dịch Vụ Ô Tô //</h6>
                                    <h1 class="display-3 text-white mb-4 pb-3 animated slideInDown">Trung Tâm Sửa Chữa Ô Tô Chuyên Nghiệp</h1>
                                    <a href="@Url.Action("Index", "Service")" class="btn btn-primary py-3 px-5 animated slideInDown">Tìm Hiểu Thêm<i class="fa fa-arrow-right ms-3"></i></a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#header-carousel"
                data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#header-carousel"
                data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
        </button>
    </div>
</div>
<!-- Carousel End -->
<!-- Service Start -->
<div class="container-xxl py-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.1s">
