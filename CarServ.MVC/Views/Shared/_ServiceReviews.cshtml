@model CarServ.MVC.Models.Service
@{
    var reviews = ViewData["Reviews"] as List<CarServ.MVC.Models.Review> ?? new List<CarServ.MVC.Models.Review>();
    ViewData["ReviewTitle"] = "Đánh giá dịch vụ";
    ViewData["EmptyReviewText"] = "Chưa có đánh giá nào cho dịch vụ này.";
}

@await Html.PartialAsync("_ReviewDisplay", reviews)

<div class="mt-4 p-3" style="border-radius: 8px; background: #fff7ed; border: 1px solid #fed7aa; color: #9a3412;">
    <i class="fa fa-info-circle me-2"></i>
    Khách hàng có thể đánh giá dịch vụ sau khi lịch hẹn đã hoàn thành trong mục tài khoản của mình.
</div>
