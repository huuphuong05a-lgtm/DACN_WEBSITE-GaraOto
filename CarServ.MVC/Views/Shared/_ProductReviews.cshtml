@model CarServ.MVC.Models.Product
@{
    var reviews = ViewData["Reviews"] as List<CarServ.MVC.Models.Review> ?? new List<CarServ.MVC.Models.Review>();
    ViewData["ReviewTitle"] = "Đánh giá sản phẩm";
    ViewData["EmptyReviewText"] = "Chưa có đánh giá nào cho sản phẩm này.";
}

@await Html.PartialAsync("_ReviewDisplay", reviews)

<div class="mt-4 p-3" style="border-radius: 8px; background: #f8fafc; border: 1px solid #e5e7eb; color: #64748b;">
    <i class="fa fa-lock me-2"></i>
    Đánh giá sản phẩm sẽ được mở cho khách hàng sau khi mua hàng thành công.
</div>
