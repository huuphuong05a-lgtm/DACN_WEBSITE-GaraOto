<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8">
    <title>@ViewData["Title"] - CarServ - Gara Ô Tô Chuyên Nghiệp</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">

    <!-- SEO -->
    <meta content="gara ô tô, sửa chữa xe hơi, bảo dưỡng xe, dịch vụ ô tô" name="keywords">
    <meta content="Gara ô tô CarServ cung cấp dịch vụ sửa chữa, bảo dưỡng xe hơi chuyên nghiệp" name="description">

    <!-- Favicon -->
    <link href="~/img/favicon.ico" rel="icon">

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600&display=swap" rel="stylesheet">

    <!-- Icons -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Libraries -->
    <link href="~/lib/animate/animate.min.css" rel="stylesheet">
    <link href="~/lib/owlcarousel/assets/owl.carousel.min.css" rel="stylesheet">
    <link href="~/lib/tempusdominus/css/tempusdominus-bootstrap-4.min.css" rel="stylesheet" />

    <!-- Bootstrap -->
    <link href="~/css/bootstrap.min.css" rel="stylesheet">

    <!-- Main Template CSS -->
    <link href="~/css/style.css" rel="stylesheet">

    <!-- ⭐ MUST HAVE: Chatbot Messenger CSS (SITE.CSS) -->
    <link href="~/css/site.css" rel="stylesheet">
</head>

<body style="position: relative;">

    <!-- Spinner -->
    <div id="spinner" class="show bg-white position-fixed translate-middle w-100 vh-100 top-50 start-50 d-flex align-items-center justify-content-center">
        <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;"></div>
    </div>

    <!-- Topbar -->
    <div class="container-fluid bg-light p-0">
        <div class="row gx-0 d-none d-lg-flex">
            <div class="col-lg-7 px-5 text-start">

                <div class="h-100 d-inline-flex align-items-center py-3 me-4">
                    <i class="fa fa-map-marker-alt text-primary me-2"></i>
                    <small>123 Đường ABC, Quận 1, TP.HCM</small>
                </div>

                <div class="h-100 d-inline-flex align-items-center py-3">
                    <i class="far fa-clock text-primary me-2"></i>
                    <small>Thứ 2 - Thứ 6 : 07.00 - 21.00</small>
                </div>

            </div>

            <div class="col-lg-5 px-5 text-end">
                <div class="h-100 d-inline-flex align-items-center py-3 me-4">
                    <i class="fa fa-phone-alt text-primary me-2"></i>
                    <small>+84 123 456 789</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg bg-white navbar-light shadow sticky-top p-0">

        <a href="/" class="navbar-brand d-flex align-items-center px-4 px-lg-5">
            <h2 class="m-0 text-primary"><i class="fa fa-car me-3"></i>CarServ</h2>
        </a>

        <button class="navbar-toggler me-4" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarCollapse">

            @await Component.InvokeAsync("MenuTop")

            <!-- Desktop Menu -->
            <div class="d-none d-lg-flex align-items-center">
                <a href="@Url.Action("Index", "Cart")" class="btn btn-outline-primary py-4 px-lg-4 position-relative me-2">
                    <i class="fa fa-shopping-cart"></i>
                    <span id="cart-count" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="display:none;">0</span>
                </a>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <!-- User Dropdown -->
                    <div class="dropdown me-2">
                        <button class="btn btn-outline-secondary py-4 px-lg-4 dropdown-toggle" type="button" id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="fa fa-user me-2"></i>@User.Identity.Name
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                            <li><a class="dropdown-item" href="@Url.Action("Profile", "Customer")"><i class="fa fa-user me-2"></i>Tài khoản</a></li>
                            <li><a class="dropdown-item" href="@Url.Action("Orders", "Customer")"><i class="fa fa-shopping-bag me-2"></i>Đơn hàng</a></li>
                            <li><a class="dropdown-item" href="@Url.Action("Appointments", "Customer")"><i class="fa fa-calendar me-2"></i>Lịch hẹn</a></li>
                            <li><a class="dropdown-item" href="@Url.Action("Vehicles", "Customer")"><i class="fa fa-car me-2"></i>Quản lý xe</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    <button type="submit" class="dropdown-item">
                                        <i class="fa fa-sign-out-alt me-2"></i>Đăng xuất
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <a href="@Url.Action("Login", "Account")" class="btn btn-outline-secondary py-4 px-lg-4 me-2">
                        <i class="fa fa-sign-in-alt me-2"></i>Đăng nhập
                    </a>
                }

                <a href="@Url.Action("Index", "Booking")" class="btn btn-primary py-4 px-lg-5">
                    Đặt lịch<i class="fa fa-arrow-right ms-3"></i>
                </a>
            </div>

            <!-- Mobile Menu -->
            <div class="d-lg-none mt-3">
                <a href="@Url.Action("Index", "Cart")" class="btn btn-outline-primary w-100 mb-2 position-relative">
                    <i class="fa fa-shopping-cart me-2"></i>Giỏ hàng
                    <span id="cart-count-mobile" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="display:none;">0</span>
                </a>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="dropdown mb-2">
                        <button class="btn btn-outline-secondary w-100 dropdown-toggle" type="button" id="userDropdownMobile" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="fa fa-user me-2"></i>@User.Identity.Name
                        </button>
                        <ul class="dropdown-menu w-100" aria-labelledby="userDropdownMobile">
                            <li><a class="dropdown-item" href="@Url.Action("Profile", "Customer")"><i class="fa fa-user me-2"></i>Tài khoản</a></li>
                            <li><a class="dropdown-item" href="@Url.Action("Orders", "Customer")"><i class="fa fa-shopping-bag me-2"></i>Đơn hàng</a></li>
                            <li><a class="dropdown-item" href="@Url.Action("Appointments", "Customer")"><i class="fa fa-calendar me-2"></i>Lịch hẹn</a></li>
                            <li><a class="dropdown-item" href="@Url.Action("Vehicles", "Customer")"><i class="fa fa-car me-2"></i>Quản lý xe</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline w-100">
                                    <button type="submit" class="dropdown-item">
                                        <i class="fa fa-sign-out-alt me-2"></i>Đăng xuất
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <a href="@Url.Action("Login", "Account")" class="btn btn-outline-secondary w-100 mb-2">
                        <i class="fa fa-sign-in-alt me-2"></i>Đăng nhập
                    </a>
                    <a href="@Url.Action("Register", "Account")" class="btn btn-outline-primary w-100 mb-2">
                        <i class="fa fa-user-plus me-2"></i>Đăng ký
                    </a>
                }

                <a href="@Url.Action("Index", "Booking")" class="btn btn-primary w-100">
                    <i class="fa fa-calendar me-2"></i>Đặt lịch
                </a>
            </div>

        </div>
    </nav>

    @RenderBody()

    <!-- Back To Top -->
    <a href="#" class="btn btn-lg btn-primary btn-lg-square back-to-top">
        <i class="bi bi-arrow-up"></i>
    </a>

    <!-- JS Libraries -->
    <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/lib/wow/wow.min.js"></script>
    <script src="~/lib/easing/easing.min.js"></script>
    <script src="~/lib/waypoints/waypoints.min.js"></script>
    <script src="~/lib/counterup/counterup.min.js"></script>
    <script src="~/lib/owlcarousel/owl.carousel.min.js"></script>
    <script src="~/lib/tempusdominus/js/moment.min.js"></script>
    <script src="~/lib/tempusdominus/js/moment-timezone.min.js"></script>
    <script src="~/lib/tempusdominus/js/tempusdominus-bootstrap-4.min.js"></script>

    <script src="~/js/main.js"></script>

    @*@await RenderSectionAsync("Scripts", required: false)*@

    <!-- ================================
         CHAT WIDGET BUTTON + UI
    ================================= -->
    @await RenderSectionAsync("Scripts", required: false)

    <button id="chat-toggle-btn" class="chat-btn-toggle">💬</button>

    <div id="chat-window" class="chat-box-container">
        <div class="chat-box-header">
            <span><i class="fas fa-robot me-2"></i>Trợ lý CarServ</span>
            <span id="chat-close-btn" class="chat-box-close">✖</span>
        </div>

        <div id="chat-messages" class="chat-msg-list">
            <div class="chat-bubble-row bot">
                <div class="chat-bubble">
                    Xin chào! 👋<br>
                    Tôi là trợ lý ảo CarServ.<br>
                    - Bạn cần tra cứu giá dịch vụ?<br>
                    - Muốn đặt lịch hẹn ngay?<br>
                    - Hay cần gặp nhân viên hỗ trợ?<br>
                    Cứ nhắn tin cho tôi nhé!
                </div>
            </div>
        </div>

        <div class="chat-box-footer">
            <input type="file" id="chat-image-upload" accept="image/*" style="display: none;" onchange="previewImage()">

            <button class="chat-btn-icon" onclick="document.getElementById('chat-image-upload').click()" title="Gửi ảnh">
                <i class="fas fa-camera"></i>
            </button>

            <input id="chat-input" class="chat-box-input" placeholder="Nhập tin nhắn..." autocomplete="off">

            <button id="chat-send-btn" class="chat-btn-send"><i class="fas fa-paper-plane"></i></button>
        </div>

        <div id="image-preview-container" style="display: none; padding: 10px; background: #f9f9f9; border-top: 1px solid #eee;">
            <div style="position: relative; display: inline-block;">
                <img id="image-preview" src="" style="max-height: 60px; border-radius: 8px; border: 1px solid #ddd;">
                <span onclick="clearImage()" style="position: absolute; top: -5px; right: -5px; background: red; color: white; border-radius: 50%; width: 20px; height: 20px; text-align: center; font-size: 12px; cursor: pointer;">&times;</span>
            </div>
        </div>
    </div>
    
    <script src="/js/chat-widget.js"></script>

</body>
</html>
