@model CarServ.MVC.Models.Contact

@{
    ViewData["Title"] = "Liên Hệ";
}

<!-- Page Header -->
<div class="container-fluid page-header p-0" style="background-image: url(/img/carousel-bg-1.jpg);">
    <div class="container-fluid page-header-inner py-5">
        <div class="container text-center py-4">
            <p class="text-white-50 text-uppercase mb-2" style="font-size: 12px; letter-spacing: 4px; font-weight: 600;">NHP-AUTO</p>
            <h1 class="text-white mb-3" style="font-family:'Montserrat',sans-serif; font-weight:800; font-size:clamp(1.6rem,3.5vw,2.2rem);">Liên Hệ Với Chúng Tôi</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb justify-content-center mb-0" style="font-size: 13px;">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")" class="text-white-50 text-decoration-none">Trang Chủ</a></li>
                    <li class="breadcrumb-item text-white active" aria-current="page">Liên Hệ</li>
                </ol>
            </nav>
        </div>
    </div>
</div>

<!-- Contact Info Cards -->
<div class="container-xxl" style="margin-top: -40px; position: relative; z-index: 10;">
    <div class="container">
        <div class="row g-3">
            <div class="col-md-4 wow fadeInUp" data-wow-delay="0.1s">
                <div class="bg-white p-4 d-flex align-items-center gap-3 h-100" style="border-radius: 14px; border: 1px solid #f0f0f0;">
                    <div class="flex-shrink-0 d-flex align-items-center justify-content-center rounded-circle" style="width: 44px; height: 44px; background: rgba(225,29,46,0.08);">
                        <i class="fa fa-map-marker-alt text-primary" style="font-size: 14px;"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-0" style="font-size: 13px;">Địa Chỉ</h6>
                        <span class="text-muted" style="font-size: 13px;">182 Lê Duẩn, TP Vinh, Nghệ An</span>
                    </div>
                </div>
            </div>
            <div class="col-md-4 wow fadeInUp" data-wow-delay="0.3s">
                <div class="bg-white p-4 d-flex align-items-center gap-3 h-100" style="border-radius: 14px; border: 1px solid #f0f0f0;">
                    <div class="flex-shrink-0 d-flex align-items-center justify-content-center rounded-circle" style="width: 44px; height: 44px; background: rgba(225,29,46,0.08);">
                        <i class="fa fa-phone-alt text-primary" style="font-size: 14px;"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-0" style="font-size: 13px;">Điện Thoại</h6>
                        <span class="text-muted" style="font-size: 13px;">+84 357 062 771</span>
                    </div>
                </div>
            </div>
            <div class="col-md-4 wow fadeInUp" data-wow-delay="0.5s">
                <div class="bg-white p-4 d-flex align-items-center gap-3 h-100" style="border-radius: 14px; border: 1px solid #f0f0f0;">
                    <div class="flex-shrink-0 d-flex align-items-center justify-content-center rounded-circle" style="width: 44px; height: 44px; background: rgba(225,29,46,0.08);">
                        <i class="fa fa-envelope text-primary" style="font-size: 14px;"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-0" style="font-size: 13px;">Email</h6>
                        <span class="text-muted" style="font-size: 13px;">carservnhp@gmail.com</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Map + Form -->
<div class="container-xxl py-5">
    <div class="container">
        <div class="row g-5">
            <!-- Map -->
            <div class="col-lg-6 wow fadeInUp" data-wow-delay="0.1s">
                <div class="overflow-hidden h-100" style="border-radius: 14px; min-height: 400px; border: 1px solid #f0f0f0; box-shadow: 0 10px 30px rgba(0,0,0,0.08);">
                    <iframe
                      src="https://www.google.com/maps?q=Đại+học+Vinh,+182+Lê+Duẩn,+Vinh,+Nghệ+An&output=embed"
                      width="100%"
                      height="100%"
                      style="border:0;"
                      allowfullscreen=""
                      loading="lazy"
                      referrerpolicy="no-referrer-when-downgrade">
                    </iframe>
                </div>
            </div>

            <!-- Form -->
            <div class="col-lg-6 wow fadeInUp" data-wow-delay="0.3s">
                <div class="bg-white p-4 p-md-5" style="border-radius: 16px; border: 1px solid #f0f0f0;">
                    <h4 class="fw-bold text-dark mb-1" style="font-size: 1.1rem;">Gửi Tin Nhắn</h4>
                    <p class="text-muted mb-4" style="font-size: 13px;">Chúng tôi sẽ phản hồi trong thời gian sớm nhất.</p>

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show mb-3" role="alert" style="border-radius: 10px; font-size: 13px;">
                            <i class="fa fa-check-circle me-2"></i>@TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" style="font-size: 10px;"></button>
                        </div>
                    }

                    @if (!User.Identity?.IsAuthenticated ?? true)
                    {
                        <div class="p-4 mb-4" style="border-radius: 12px; background: #FFF7ED; border: 1px solid #FED7AA;">
                            <div class="d-flex align-items-start gap-3">
                                <i class="fa fa-exclamation-triangle text-warning mt-1" style="font-size: 14px;"></i>
                                <div>
                                    <h6 class="fw-bold mb-1" style="font-size: 14px; color: #92400E;">Yêu cầu đăng nhập</h6>
                                    <p class="mb-3" style="font-size: 13px; color: #B45309;">Vui lòng đăng nhập để gửi liên hệ.</p>
                                    <div class="d-flex flex-wrap gap-2">
                                        <a href="@Url.Action("Login", "Account", new { returnUrl = Url.Action("Index", "Contact") })" class="btn btn-dark rounded-pill px-3 py-1" style="font-size: 12px;">
                                            <i class="fa fa-sign-in-alt me-1"></i>Đăng nhập
                                        </a>
                                        <a href="@Url.Action("Register", "Account")" class="btn btn-outline-dark rounded-pill px-3 py-1" style="font-size: 12px;">
                                            <i class="fa fa-user-plus me-1"></i>Đăng ký
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }

                    <form asp-action="Create" method="post" id="contactForm">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-size: 13px;"></div>
                        @{
                            var isDisabled = !(User.Identity?.IsAuthenticated ?? false);
                        }

                        <div class="row g-3">
                            <div class="col-sm-6">
                                <label asp-for="FullName" class="form-label">Họ và tên <span class="text-danger">*</span></label>
                                <input asp-for="FullName" class="form-control" placeholder="Nguyễn Văn A" required disabled="@isDisabled">
                                <span asp-validation-for="FullName" class="text-danger" style="font-size: 12px;"></span>
                            </div>
                            <div class="col-sm-6">
                                <label asp-for="Email" class="form-label">Email <span class="text-danger">*</span></label>
                                <input asp-for="Email" type="email" class="form-control" placeholder="email@example.com" required disabled="@isDisabled">
                                <span asp-validation-for="Email" class="text-danger" style="font-size: 12px;"></span>
                            </div>
                            <div class="col-sm-6">
                                <label asp-for="Phone" class="form-label">Số điện thoại</label>
                                <input asp-for="Phone" class="form-control" placeholder="0912 345 678" disabled="@isDisabled">
                            </div>
                            <div class="col-sm-6">
                                <label asp-for="Subject" class="form-label">Tiêu đề</label>
                                <input asp-for="Subject" class="form-control" placeholder="Chủ đề liên hệ" disabled="@isDisabled">
                            </div>
                            <div class="col-12">
                                <label asp-for="Message" class="form-label">Nội dung <span class="text-danger">*</span></label>
                                <textarea asp-for="Message" class="form-control" placeholder="Mô tả chi tiết yêu cầu..." rows="4" required disabled="@isDisabled"></textarea>
                                <span asp-validation-for="Message" class="text-danger" style="font-size: 12px;"></span>
                            </div>
                            <div class="col-12 pt-1">
                                @if (User.Identity?.IsAuthenticated == true)
                                {
                                    <button class="btn btn-primary rounded-pill w-100 py-2" type="submit" style="font-size: 14px;">
                                        <i class="fa fa-paper-plane me-2" style="font-size: 12px;"></i>Gửi Tin Nhắn
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-secondary rounded-pill w-100 py-2" type="button" disabled style="font-size: 14px; opacity: 0.5;">
                                        <i class="fa fa-lock me-2" style="font-size: 12px;"></i>Vui lòng đăng nhập
                                    </button>
                                }
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Contact End -->

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    @if (!User.Identity?.IsAuthenticated ?? true)
    {
        <script>
            document.getElementById('contactForm')?.addEventListener('submit', function(e) {
                e.preventDefault();
                alert('Vui lòng đăng nhập để gửi liên hệ.');
                window.location.href = '@Url.Action("Login", "Account", new { returnUrl = Url.Action("Index", "Contact") })';
            });
        </script>
    }
}
