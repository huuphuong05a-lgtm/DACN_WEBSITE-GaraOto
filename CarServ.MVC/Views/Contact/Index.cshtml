@model CarServ.MVC.Models.Contact

@{
    ViewData["Title"] = "Liên Hệ";
}

<!-- Page Header Start -->
<div class="container-fluid page-header mb-5 p-0" style="background-image: url(/img/carousel-bg-1.jpg);">
    <div class="container-fluid page-header-inner py-5">
        <div class="container text-center pb-5">
            <h1 class="display-3 text-white mb-3 animated slideInDown">Liên Hệ Với Chúng Tôi</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb justify-content-center text-uppercase">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Trang Chủ</a></li>
                    <li class="breadcrumb-item text-white active" aria-current="page">Liên Hệ</li>
                </ol>
            </nav>
        </div>
    </div>
</div>
<!-- Page Header End -->

<!-- Contact Start -->
<div class="container-xxl py-5">
    <div class="container">
        <div class="row g-5">
            <div class="col-lg-6">
                <div class="wow fadeInUp" data-wow-delay="0.1s">
                    <h1 class="mb-4">Thông Tin Liên Hệ</h1>
                    <p class="mb-4">Chúng tôi luôn sẵn sàng lắng nghe và hỗ trợ bạn. Hãy liên hệ với chúng tôi qua các thông tin dưới đây hoặc điền form bên cạnh.</p>
                    <div class="d-flex align-items-center mb-4">
                        <div class="d-flex align-items-center justify-content-center flex-shrink-0 bg-primary" style="width: 50px; height: 50px;">
                            <i class="fa fa-map-marker-alt text-white"></i>
                        </div>
                        <div class="ms-3">
                            <h5>Địa Chỉ</h5>
                            <p class="mb-0">123 Đường ABC, Quận 1, TP.HCM</p>
                        </div>
                    </div>
                    <div class="d-flex align-items-center mb-4">
                        <div class="d-flex align-items-center justify-content-center flex-shrink-0 bg-primary" style="width: 50px; height: 50px;">
                            <i class="fa fa-phone-alt text-white"></i>
                        </div>
                        <div class="ms-3">
                            <h5>Điện Thoại</h5>
                            <p class="mb-0">+84 123 456 789</p>
                        </div>
                    </div>
                    <div class="d-flex align-items-center">
                        <div class="d-flex align-items-center justify-content-center flex-shrink-0 bg-primary" style="width: 50px; height: 50px;">
                            <i class="fa fa-envelope-open text-white"></i>
                        </div>
                        <div class="ms-3">
                            <h5>Email</h5>
                            <p class="mb-0">info@carserv.vn</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="wow fadeInUp" data-wow-delay="0.5s">
                    <h1 class="mb-4">Gửi Tin Nhắn</h1>
                    
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            @TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    @if (!User.Identity?.IsAuthenticated ?? true)
                    {
                        <div class="alert alert-warning mb-4" role="alert">
                            <h5 class="alert-heading"><i class="fa fa-exclamation-triangle"></i> Yêu cầu đăng nhập</h5>
                            <p class="mb-3">Vui lòng đăng nhập để gửi liên hệ.</p>
                            <hr>
                            <p class="mb-0">
                                <a href="@Url.Action("Login", "Account", new { returnUrl = Url.Action("Index", "Contact") })" class="btn btn-primary btn-sm">
                                    <i class="fa fa-sign-in-alt"></i> Đăng nhập ngay
                                </a>
                                <span class="mx-2">hoặc</span>
                                <a href="@Url.Action("Register", "Account")" class="btn btn-outline-primary btn-sm">
                                    <i class="fa fa-user-plus"></i> Đăng ký tài khoản
                                </a>
                            </p>
                        </div>
                    }

                    <form asp-action="Create" method="post" id="contactForm">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <div class="row g-3">
                            @{
                                var isDisabled = !(User.Identity?.IsAuthenticated ?? false);
                            }
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="FullName" class="form-control" placeholder="Họ và tên *" required disabled="@isDisabled">
                                    <label asp-for="FullName">Họ và tên *</label>
                                    <span asp-validation-for="FullName" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Email" type="email" class="form-control" placeholder="Email *" required disabled="@isDisabled">
                                    <label asp-for="Email">Email *</label>
                                    <span asp-validation-for="Email" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Phone" class="form-control" placeholder="Số điện thoại" disabled="@isDisabled">
                                    <label asp-for="Phone">Số điện thoại</label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Subject" class="form-control" placeholder="Tiêu đề" disabled="@isDisabled">
                                    <label asp-for="Subject">Tiêu đề</label>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="form-floating">
                                    <textarea asp-for="Message" class="form-control" placeholder="Nội dung tin nhắn *" style="height: 150px" required disabled="@isDisabled"></textarea>
                                    <label asp-for="Message">Nội dung tin nhắn *</label>
                                    <span asp-validation-for="Message" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-12">
                                @if (User.Identity?.IsAuthenticated == true)
                                {
                                    <button class="btn btn-primary w-100 py-3" type="submit">Gửi Tin Nhắn</button>
                                }
                                else
                                {
                                    <button class="btn btn-primary w-100 py-3" type="button" disabled>
                                        <i class="fa fa-lock"></i> Vui lòng đăng nhập để gửi liên hệ
                                    </button>
                                }
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Contact End -->

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    @if (!User.Identity?.IsAuthenticated ?? true)
    {
        <script>
            // Disable form submission if not logged in
            document.getElementById('contactForm')?.addEventListener('submit', function(e) {
                e.preventDefault();
                alert('Vui lòng đăng nhập để gửi liên hệ.');
                window.location.href = '@Url.Action("Login", "Account", new { returnUrl = Url.Action("Index", "Contact") })';
            });
        </script>
    }
}


