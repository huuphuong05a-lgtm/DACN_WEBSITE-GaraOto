@model CarServ.MVC.Models.Appointment

@{
    ViewData["Title"] = "Đặt Lịch Hẹn";
    var services = ViewData["Services"] as SelectList;
    var technicians = ViewData["Technicians"] as SelectList;
    var selectedService = ViewData["SelectedService"] as CarServ.MVC.Models.Service;
}

<!-- Page Header -->
<div class="container-fluid page-header p-0" style="background-image: url(/img/carousel-bg-2.jpg);">
    <div class="container-fluid page-header-inner py-5">
        <div class="container text-center py-4">
            <p class="text-white-50 text-uppercase mb-2" style="font-size: 12px; letter-spacing: 4px; font-weight: 600;">NHP-AUTO</p>
            <h1 class="text-white mb-3" style="font-family:'Montserrat',sans-serif; font-weight:800; font-size:clamp(1.6rem,3.5vw,2.2rem);">Đặt Lịch Dịch Vụ</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb justify-content-center mb-0" style="font-size: 13px;">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")" class="text-white-50 text-decoration-none">Trang Chủ</a></li>
                    <li class="breadcrumb-item text-white active" aria-current="page">Đặt Lịch</li>
                </ol>
            </nav>
        </div>
    </div>
</div>

<!-- Booking Start -->
<div class="container-xxl py-5">
    <div class="container">
        <div class="row g-5 justify-content-center">
            <!-- Left Info Panel -->
            <div class="col-lg-5">
                <div class="sticky-lg-top" style="top: 100px;">
                    <p class="text-primary text-uppercase fw-bold mb-2" style="font-size: 12px; letter-spacing: 3px;">Đặt Lịch Hẹn</p>
                    <h2 class="fw-bold text-dark mb-4" style="font-size: clamp(1.4rem, 3vw, 1.8rem); line-height: 1.3;">Dịch Vụ Sửa Chữa Ô Tô Chuyên Nghiệp</h2>
                    <p class="text-muted mb-4" style="font-size: 14px; line-height: 1.8;">NHP-AUTO tự hào với đội ngũ kỹ thuật viên chuyên nghiệp, trang thiết bị hiện đại và dịch vụ khách hàng tận tâm.</p>

                    <div class="d-flex flex-column gap-3 mb-4">
                        <div class="d-flex align-items-center gap-3">
                            <div class="flex-shrink-0 d-flex align-items-center justify-content-center rounded-circle" style="width: 40px; height: 40px; background: rgba(225,29,46,0.08);">
                                <i class="fa fa-clock text-primary" style="font-size: 13px;"></i>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-0" style="font-size: 13px;">Phản hồi nhanh</h6>
                                <span class="text-muted" style="font-size: 12px;">Xác nhận lịch hẹn trong 5 phút</span>
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <div class="flex-shrink-0 d-flex align-items-center justify-content-center rounded-circle" style="width: 40px; height: 40px; background: rgba(225,29,46,0.08);">
                                <i class="fa fa-shield-alt text-primary" style="font-size: 13px;"></i>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-0" style="font-size: 13px;">Cam kết chất lượng</h6>
                                <span class="text-muted" style="font-size: 12px;">Bảo hành dịch vụ rõ ràng</span>
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <div class="flex-shrink-0 d-flex align-items-center justify-content-center rounded-circle" style="width: 40px; height: 40px; background: rgba(225,29,46,0.08);">
                                <i class="fa fa-wallet text-primary" style="font-size: 13px;"></i>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-0" style="font-size: 13px;">Giá cả minh bạch</h6>
                                <span class="text-muted" style="font-size: 12px;">Báo giá trước khi thực hiện</span>
                            </div>
                        </div>
                    </div>

                    <div class="p-3 bg-light" style="border-radius: 12px; font-size: 13px;">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <i class="fa fa-phone-alt text-primary" style="font-size: 12px;"></i>
                            <span class="text-muted">Hotline: <strong class="text-dark">+84 357 062 771</strong></span>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <i class="fa fa-map-marker-alt text-primary" style="font-size: 12px;"></i>
                            <span class="text-muted">182 Lê Duẩn, TP Vinh, Nghệ An</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Form -->
            <div class="col-lg-6">
                <div class="bg-white p-4 p-md-5" style="border-radius: 16px; border: 1px solid #f0f0f0;">
                    <h4 class="fw-bold text-dark mb-1" style="font-size: 1.1rem;">Thông Tin Đặt Lịch</h4>
                    <p class="text-muted mb-4" style="font-size: 13px;">Vui lòng điền đầy đủ thông tin bên dưới.</p>

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert" style="border-radius: 10px; font-size: 13px;">
                            <i class="fa fa-check-circle me-2"></i>@TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" style="font-size: 11px;"></button>
                        </div>
                    }

                    @if (!User.Identity?.IsAuthenticated ?? true)
                    {
                        <div class="p-4 mb-4" style="border-radius: 12px; background: #FFF7ED; border: 1px solid #FED7AA;">
                            <div class="d-flex align-items-start gap-3">
                                <i class="fa fa-exclamation-triangle text-warning mt-1" style="font-size: 14px;"></i>
                                <div>
                                    <h6 class="fw-bold mb-1" style="font-size: 14px; color: #92400E;">Yêu cầu đăng nhập</h6>
                                    <p class="mb-3" style="font-size: 13px; color: #B45309;">Vui lòng đăng nhập để đặt lịch hẹn.</p>
                                    <div class="d-flex flex-wrap gap-2">
                                        <a href="@Url.Action("Login", "Account", new { returnUrl = Url.Action("Index", "Booking") })" class="btn btn-dark rounded-pill px-3 py-1" style="font-size: 12px;">
                                            <i class="fa fa-sign-in-alt me-1"></i>Đăng nhập
                                        </a>
                                        <a href="@Url.Action("Register", "Account")" class="btn btn-outline-dark rounded-pill px-3 py-1" style="font-size: 12px;">
                                            <i class="fa fa-user-plus me-1"></i>Đăng ký
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }

                    <form asp-action="Create" method="post" id="bookingForm">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-size: 13px;"></div>
                        @{
                            var isDisabled = !(User.Identity?.IsAuthenticated ?? false);
                        }

                        <div class="row g-3">
                            <div class="col-12 col-sm-6">
                                <label class="form-label">Họ và tên <span class="text-danger">*</span></label>
                                <input asp-for="CustomerName" class="form-control" placeholder="Nguyễn Văn A" required disabled="@isDisabled">
                                <span asp-validation-for="CustomerName" class="text-danger" style="font-size: 12px;"></span>
                            </div>
                            <div class="col-12 col-sm-6">
                                <label class="form-label">Email <span class="text-danger">*</span></label>
                                <input asp-for="CustomerEmail" type="email" class="form-control" placeholder="email@example.com" required disabled="@isDisabled">
                                <span asp-validation-for="CustomerEmail" class="text-danger" style="font-size: 12px;"></span>
                            </div>
                            <div class="col-12 col-sm-6">
                                <label class="form-label">Số điện thoại <span class="text-danger">*</span></label>
                                <input asp-for="CustomerPhone" class="form-control" placeholder="0912 345 678" required disabled="@isDisabled">
                                <span asp-validation-for="CustomerPhone" class="text-danger" style="font-size: 12px;"></span>
                            </div>
                            <div class="col-12 col-sm-6">
                                <label class="form-label">Dịch vụ <span class="text-danger">*</span></label>
                                <select asp-for="ServiceId" asp-items="services" class="form-select" required disabled="@isDisabled">
                                    <option value="">Chọn dịch vụ</option>
                                </select>
                                <span asp-validation-for="ServiceId" class="text-danger" style="font-size: 12px;"></span>
                            </div>
                            <div class="col-12 col-sm-6">
                                <label class="form-label">Kỹ thuật viên</label>
                                <select asp-for="TechnicianId" asp-items="technicians" class="form-select" disabled="@isDisabled">
                                    <option value="">Tùy chọn</option>
                                </select>
                            </div>
                            <div class="col-12 col-sm-6">
                                <label class="form-label">Ngày & giờ hẹn <span class="text-danger">*</span></label>
                                <input asp-for="AppointmentDate" type="datetime-local" class="form-control" required min="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" disabled="@isDisabled">
                                <span asp-validation-for="AppointmentDate" class="text-danger" style="font-size: 12px;"></span>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Thông tin xe</label>
                                <input asp-for="VehicleInfo" class="form-control" placeholder="Biển số, hãng xe, model..." disabled="@isDisabled">
                            </div>
                            <div class="col-12">
                                <label class="form-label">Ghi chú</label>
                                <textarea asp-for="Notes" class="form-control" placeholder="Yêu cầu đặc biệt..." rows="3" disabled="@isDisabled"></textarea>
                            </div>
                            <div class="col-12 pt-2">
                                @if (User.Identity?.IsAuthenticated == true)
                                {
                                    <button class="btn btn-primary rounded-pill w-100 py-2" type="submit" style="font-size: 14px;">
                                        <i class="fa fa-calendar-check me-2" style="font-size: 13px;"></i>Xác Nhận Đặt Lịch
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-secondary rounded-pill w-100 py-2" type="button" disabled style="font-size: 14px; opacity: 0.5;">
                                        <i class="fa fa-lock me-2" style="font-size: 12px;"></i>Vui lòng đăng nhập để đặt lịch
                                    </button>
                                }
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Booking End -->

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    @if (!User.Identity?.IsAuthenticated ?? true)
    {
        <script>
            document.getElementById('bookingForm')?.addEventListener('submit', function(e) {
                e.preventDefault();
                alert('Vui lòng đăng nhập để đặt lịch hẹn dịch vụ.');
                window.location.href = '@Url.Action("Login", "Account", new { returnUrl = Url.Action("Index", "Booking") })';
            });
        </script>
    }
}
