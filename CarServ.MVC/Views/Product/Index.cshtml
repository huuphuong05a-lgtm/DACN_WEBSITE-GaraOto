@model IEnumerable<CarServ.MVC.Models.Product>

@{
    ViewData["Title"] = "Sản Phẩm";
    var categories = ViewData["Categories"] as List<CarServ.MVC.Models.Category> ?? new List<CarServ.MVC.Models.Category>();
    var selectedCategoryId = ViewData["CategoryId"] as int?;
}

<!-- Page Header -->
<div class="container-fluid page-header p-0" style="background-image: url(/img/carousel-bg-1.jpg);">
    <div class="container-fluid page-header-inner py-5">
        <div class="container text-center py-4">
            <p class="text-white-50 text-uppercase mb-2" style="font-size: 12px; letter-spacing: 4px; font-weight: 600;">NHP-AUTO</p>
            <h1 class="text-white mb-3" style="font-family:'Montserrat',sans-serif; font-weight:800; font-size:clamp(1.6rem,3.5vw,2.2rem);">Sản Phẩm Phụ Tùng</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb justify-content-center mb-0" style="font-size: 13px;">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")" class="text-white-50 text-decoration-none">Trang Chủ</a></li>
                    <li class="breadcrumb-item text-white active" aria-current="page">Sản Phẩm</li>
                </ol>
            </nav>
        </div>
    </div>
</div>

<!-- Products Start -->
<div class="container-xxl py-5">
    <div class="container">
        <!-- Search & Filter -->
        <div class="row mb-4 g-3 align-items-center">
            <div class="col-md-7">
                <form asp-action="Index" method="get" class="d-flex gap-2">
                    <input type="hidden" name="categoryId" value="@selectedCategoryId">
                    <div class="position-relative flex-fill">
                        <i class="fa fa-search position-absolute text-muted" style="left: 14px; top: 50%; transform: translateY(-50%); font-size: 13px;"></i>
                        <input type="text" name="searchString" class="form-control" placeholder="Tìm kiếm sản phẩm..." value="@ViewData["CurrentFilter"]" style="padding-left: 38px;">
                    </div>
                    <button type="submit" class="btn btn-primary rounded-pill px-4" style="font-size: 13px;">Tìm</button>
                </form>
            </div>
            <div class="col-md-3 ms-auto">
                <form asp-action="Index" method="get">
                    <input type="hidden" name="searchString" value="@ViewData["CurrentFilter"]">
                    <select name="categoryId" class="form-select" onchange="this.form.submit()" style="font-size: 13px;">
                        <option value="">Tất cả danh mục</option>
                        @foreach (var category in categories)
                        {
                            <option value="@category.CategoryId" selected="@(selectedCategoryId == category.CategoryId)">@category.CategoryName</option>
                        }
                    </select>
                </form>
            </div>
        </div>

        <!-- Count -->
        @if (Model != null && Model.Any())
        {
            <div class="mb-4">
                <p class="text-muted mb-0" style="font-size: 13px;">Hiển thị <strong class="text-dark">@Model.Count()</strong> sản phẩm</p>
            </div>
        }

        <!-- Products Grid -->
        <div class="row g-4">
            @if (Model != null && Model.Any())
            {
                @foreach (var product in Model)
                {
                    <div class="col-xl-3 col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.1s">
                        <div class="product-item d-flex flex-column h-100">
                            <!-- Image -->
                            <div class="product-img-wrapper">
                                @if (!string.IsNullOrEmpty(product.ImageUrl))
                                {
                                    <img src="@product.ImageUrl" alt="@product.ProductName">
                                }
                                else
                                {
                                    <img src="~/img/product-1.jpg" alt="@product.ProductName">
                                }

                                <!-- Badges -->
                                <div class="product-badges">
                                    @if (product.IsNew)
                                    {
                                        <span class="badge text-white" style="background: #111827;">Mới</span>
                                    }
                                    @if (product.IsFeatured)
                                    {
                                        <span class="badge text-white" style="background: #E11D2E;">Hot</span>
                                    }
                                    @if (product.SalePrice.HasValue && product.SalePrice < product.Price && product.Price.HasValue && product.Price > 0)
                                    {
                                        var discount = Math.Round((1 - (decimal)product.SalePrice.Value / (decimal)product.Price.Value) * 100);
                                        <span class="badge text-primary" style="background: rgba(225,29,46,0.1);">-@discount%</span>
                                    }
                                </div>

                                <!-- Quick View Overlay -->
                                <div class="product-overlay position-absolute start-0 top-0 w-100 h-100">
                                    <a class="btn btn-primary rounded-circle d-flex align-items-center justify-content-center" href="@(string.IsNullOrEmpty(product.Slug) ? Url.Action("Details", "Product", new { id = product.ProductId }) : Url.Action("Details", "Product", new { slug = product.Slug }))" style="width: 44px; height: 44px;">
                                        <i class="fa fa-arrow-right"></i>
                                    </a>
                                </div>
                            </div>

                            <!-- Content -->
                            <div class="p-4 flex-grow-1 d-flex flex-column">
                                @if (product.Category != null)
                                {
                                    <span class="text-muted mb-2 d-block" style="font-size: 11px; text-transform: uppercase; letter-spacing: 1px;">@product.Category.CategoryName</span>
                                }

                                <h6 class="fw-bold text-dark mb-2" style="font-size: 15px; line-height: 1.4;">
                                    <a href="@(string.IsNullOrEmpty(product.Slug) ? Url.Action("Details", "Product", new { id = product.ProductId }) : Url.Action("Details", "Product", new { slug = product.Slug }))" class="text-dark text-decoration-none">
                                        @product.ProductName
                                    </a>
                                </h6>

                                @if (!string.IsNullOrEmpty(product.ShortDescription))
                                {
                                    <p class="text-muted mb-4 flex-grow-1" style="font-size: 13px; line-height: 1.5;">@(product.ShortDescription.Length > 60 ? product.ShortDescription.Substring(0, 60) + "..." : product.ShortDescription)</p>
                                }

                                <!-- Price + CTA -->
                                <div class="d-flex align-items-center justify-content-between mt-auto pt-3" style="border-top: 1px solid var(--gray-50);">
                                    <div>
                                        @if (product.SalePrice.HasValue && product.SalePrice < product.Price)
                                        {
                                            <span class="text-primary fw-bold d-block" style="font-size: 16px;">@product.SalePrice.Value.ToString("N0") đ</span>
                                            <small class="text-muted text-decoration-line-through" style="font-size: 12px;">@product.Price.Value.ToString("N0") đ</small>
                                        }
                                        else if (product.Price.HasValue)
                                        {
                                            <span class="text-primary fw-bold" style="font-size: 16px;">@product.Price.Value.ToString("N0") đ</span>
                                        }
                                        else
                                        {
                                            <span class="text-primary fw-bold" style="font-size: 14px;">Liên hệ</span>
                                        }
                                    </div>
                                    <a class="btn-text-primary" href="@(string.IsNullOrEmpty(product.Slug) ? Url.Action("Details", "Product", new { id = product.ProductId }) : Url.Action("Details", "Product", new { slug = product.Slug }))">
                                        Chi Tiết <i class="fa fa-arrow-right ms-1"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <div class="d-flex flex-column align-items-center">
                        <i class="fa fa-box-open fa-2x text-muted mb-3"></i>
                        <p class="text-muted mb-0" style="font-size: 14px;">Không tìm thấy sản phẩm nào.</p>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
<!-- Products End -->
