@model CarServ.MVC.Models.Product

@{
    ViewData["Title"] = Model.ProductName;
    var relatedProducts = ViewData["RelatedProducts"] as List<CarServ.MVC.Models.Product> ?? new List<CarServ.MVC.Models.Product>();
}

<!-- Page Header Start -->
<div class="container-fluid page-header mb-5 p-0" style="background-image: url(/img/carousel-bg-1.jpg);">
    <div class="container-fluid page-header-inner py-5">
        <div class="container text-center pb-5">
            <h1 class="display-3 text-white mb-3 animated slideInDown">@Model.ProductName</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb justify-content-center text-uppercase">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Trang Chủ</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Product")">Sản Phẩm</a></li>
                    <li class="breadcrumb-item text-white active" aria-current="page">@Model.ProductName</li>
                </ol>
            </nav>
        </div>
    </div>
</div>
<!-- Page Header End -->

<!-- Product Details Start -->
<div class="container-xxl py-5">
    <div class="container">
        <div class="row g-5">
            <div class="col-lg-6">
                <div class="mb-4">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img class="img-fluid rounded w-100" src="@Model.ImageUrl" alt="@Model.ProductName" style="height: 500px; object-fit: cover;">
                    }
                    else
                    {
                        <img class="img-fluid rounded w-100" src="~/img/product-1.jpg" alt="@Model.ProductName" style="height: 500px; object-fit: cover;">
                    }
                </div>
            </div>

            <div class="col-lg-6">
                <h2 class="mb-4">@Model.ProductName</h2>
                
                @if (Model.Category != null)
                {
                    <div class="mb-3">
                        <span class="badge bg-primary">@Model.Category.CategoryName</span>
                    </div>
                }

                <div class="mb-4">
                    @if (Model.SalePrice.HasValue && Model.SalePrice < Model.Price)
                    {
                        <h3 class="text-primary mb-2">@Model.SalePrice.Value.ToString("N0") đ</h3>
                        <h5 class="text-muted text-decoration-line-through mb-0">@Model.Price.Value.ToString("N0") đ</h5>
                    }
                    else if (Model.Price.HasValue)
                    {
                        <h3 class="text-primary mb-0">@Model.Price.Value.ToString("N0") đ</h3>
                    }
                    else
                    {
                        <h3 class="text-primary mb-0">Liên hệ</h3>
                    }
                </div>

                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <div class="mb-4">
                        <h4>Mô tả sản phẩm</h4>
                        @Html.Raw(Model.Description.Replace("\n", "<br>"))
                    </div>
                }

                <div class="row mb-4">
                    @if (!string.IsNullOrEmpty(Model.Brand))
                    {
                        <div class="col-md-6 mb-3">
                            <strong>Thương hiệu:</strong> @Model.Brand
                        </div>
                    }
                    @if (Model.StockQuantity.HasValue)
                    {
                        <div class="col-md-6 mb-3">
                            <strong>Tồn kho:</strong> @Model.StockQuantity
                        </div>
                    }
                    @if (Model.WarrantyMonths.HasValue)
                    {
                        <div class="col-md-6 mb-3">
                            <strong>Bảo hành:</strong> @Model.WarrantyMonths tháng
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Sku))
                    {
                        <div class="col-md-6 mb-3">
                            <strong>Mã SKU:</strong> @Model.Sku
                        </div>
                    }
                </div>

                <div class="d-flex gap-3">
                    <button type="button" class="btn btn-primary btn-lg px-5" onclick="addToCart(@Model.ProductId, 1)">
                        <i class="fa fa-shopping-cart me-2"></i>Thêm Vào Giỏ
                    </button>
                    <button class="btn btn-outline-primary btn-lg px-5">
                        <i class="fa fa-heart me-2"></i>Yêu Thích
                    </button>
                </div>
            </div>
        </div>

        <!-- Reviews Section -->
        @await Html.PartialAsync("_ProductReviews", Model)

        <!-- Related Products -->
        @if (relatedProducts.Any())
        {
            <section class="related-products mt-5 pt-4">
                <div class="d-flex align-items-end justify-content-between mb-4">
                    <div>
                        <span class="text-primary text-uppercase fw-bold d-block mb-2" style="font-size: 11px; letter-spacing: 1.5px;">Gợi ý thêm</span>
                        <h3 class="mb-0">Sản Phẩm Liên Quan</h3>
                    </div>
                    <a href="@Url.Action("Index", "Product")" class="btn-text-primary d-none d-md-inline-flex align-items-center">
                        Xem tất cả <i class="fa fa-arrow-right ms-2"></i>
                    </a>
                </div>

                <div class="product-grid">
                    @foreach (var product in relatedProducts)
                    {
                        var productDetailsUrl = string.IsNullOrEmpty(product.Slug)
                            ? Url.Action("Details", "Product", new { id = product.ProductId })
                            : Url.Action("Details", "Product", new { slug = product.Slug });

                        <div class="product-grid-col wow fadeInUp" data-wow-delay="0.1s">
                            <div class="product-item d-flex flex-column h-100">
                                <div class="product-img-wrapper">
                                    @if (!string.IsNullOrEmpty(product.ImageUrl))
                                    {
                                        <img src="@product.ImageUrl" alt="@product.ProductName">
                                    }
                                    else
                                    {
                                        <img src="~/img/product-1.jpg" alt="@product.ProductName">
                                    }

                                    <div class="product-badges">
                                        @if (product.IsNew)
                                        {
                                            <span class="badge text-white" style="background: #111827;">Mới</span>
                                        }
                                        @if (product.IsFeatured)
                                        {
                                            <span class="badge text-white" style="background: #E11D2E;">Hot</span>
                                        }
                                        @if (product.SalePrice.HasValue && product.SalePrice < product.Price && product.Price.HasValue && product.Price > 0)
                                        {
                                            var discount = Math.Round((1 - (decimal)product.SalePrice.Value / (decimal)product.Price.Value) * 100);
                                            <span class="badge text-primary" style="background: rgba(225,29,46,0.1);">-@discount%</span>
                                        }
                                    </div>

                                    <div class="product-overlay position-absolute start-0 top-0 w-100 h-100">
                                        <a class="btn btn-primary rounded-circle d-flex align-items-center justify-content-center" href="@productDetailsUrl" style="width: 44px; height: 44px;">
                                            <i class="fa fa-arrow-right"></i>
                                        </a>
                                    </div>
                                </div>

                                <div class="p-4 flex-grow-1 d-flex flex-column">
                                    @if (product.Category != null)
                                    {
                                        <span class="text-muted mb-2 d-block" style="font-size: 11px; text-transform: uppercase; letter-spacing: 1px;">@product.Category.CategoryName</span>
                                    }
                                    <h6 class="fw-bold text-dark mb-2" style="font-size: 15px; line-height: 1.4;">
                                        <a href="@productDetailsUrl" class="text-dark text-decoration-none">@product.ProductName</a>
                                    </h6>
                                    @if (!string.IsNullOrEmpty(product.ShortDescription))
                                    {
                                        <p class="text-muted mb-4 flex-grow-1" style="font-size: 13px; line-height: 1.5;">@(product.ShortDescription.Length > 60 ? product.ShortDescription.Substring(0, 60) + "..." : product.ShortDescription)</p>
                                    }

                                    <div class="mt-auto pt-3" style="border-top: 1px solid var(--gray-50);">
                                        <div>
                                            @if (product.SalePrice.HasValue && product.SalePrice < product.Price)
                                            {
                                                <span class="text-primary fw-bold d-block" style="font-size: 16px;">@product.SalePrice.Value.ToString("N0") đ</span>
                                                <small class="text-muted text-decoration-line-through" style="font-size: 12px;">@product.Price.Value.ToString("N0") đ</small>
                                            }
                                            else if (product.Price.HasValue)
                                            {
                                                <span class="text-primary fw-bold" style="font-size: 16px;">@product.Price.Value.ToString("N0") đ</span>
                                            }
                                            else
                                            {
                                                <span class="text-primary fw-bold" style="font-size: 14px;">Liên hệ</span>
                                            }
                                        </div>
                                        <div class="product-card-actions">
                                            <button type="button" class="btn btn-outline-primary product-cart-btn" title="Thêm vào giỏ hàng" aria-label="Thêm vào giỏ hàng" onclick="addToCart(@product.ProductId, 1)">
                                                <i class="fa fa-shopping-cart"></i>
                                            </button>
                                            <button type="button" class="btn btn-primary product-buy-btn" onclick="buyNow(@product.ProductId)">
                                                Mua ngay
                                            </button>
                                            <a class="btn-text-primary product-detail-link" href="@productDetailsUrl">
                                                Chi Tiết <i class="fa fa-arrow-right ms-1"></i>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </section>
        }
    </div>
</div>
<!-- Product Details End -->

@section Scripts {
    @Html.AntiForgeryToken()
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        const antiForgeryToken = $('input[name="__RequestVerificationToken"]').val();
        var isAuthenticated = @((User.Identity?.IsAuthenticated ?? false).ToString().ToLower());
        
        function addToCart(productId, quantity) {
            // Check if user is authenticated
            if (!isAuthenticated) {
                var message = 'Vui lòng đăng nhập để thêm sản phẩm vào giỏ hàng.\n\nBạn có muốn đăng nhập ngay không?';
                if (confirm(message)) {
                    // Get current URL for returnUrl
                    var currentUrl = window.location.pathname + window.location.search;
                    var loginUrl = '@Url.Action("Login", "Account")' + '?returnUrl=' + encodeURIComponent(currentUrl);
                    window.location.href = loginUrl;
                }
                return;
            }

            $.ajax({
                url: '@Url.Action("AddToCart", "Cart")',
                type: 'POST',
                data: {
                    __RequestVerificationToken: antiForgeryToken,
                    productId: productId,
                    quantity: quantity
                },
                success: function(response) {
                    if (response.success) {
                        // Show success message
                        alert(response.message);
                        // Update cart count in header
                        updateCartCount();
                    } else {
                        alert(response.message);
                    }
                },
                error: function(xhr) {
                    // Handle 401 Unauthorized (not logged in)
                    if (xhr.status === 401 || xhr.status === 0) {
                        var message = 'Vui lòng đăng nhập để thêm sản phẩm vào giỏ hàng.\n\nBạn có muốn đăng nhập ngay không?';
                        if (confirm(message)) {
                            // Get current URL for returnUrl
                            var currentUrl = window.location.pathname + window.location.search;
                            var loginUrl = '@Url.Action("Login", "Account")' + '?returnUrl=' + encodeURIComponent(currentUrl);
                            window.location.href = loginUrl;
                        }
                    } else {
                        alert('Có lỗi xảy ra. Vui lòng thử lại.');
                    }
                }
            });
        }

        function buyNow(productId) {
            if (!isAuthenticated) {
                var currentUrl = window.location.pathname + window.location.search;
                var loginUrl = '@Url.Action("Login", "Account")' + '?returnUrl=' + encodeURIComponent(currentUrl);
                window.location.href = loginUrl;
                return;
            }

            $.ajax({
                url: '@Url.Action("AddToCart", "Cart")',
                type: 'POST',
                data: {
                    __RequestVerificationToken: antiForgeryToken,
                    productId: productId,
                    quantity: 1
                },
                success: function(response) {
                    if (response.success) {
                        window.location.href = '@Url.Action("Checkout", "Cart")';
                    } else {
                        alert(response.message);
                    }
                },
                error: function(xhr) {
                    if (xhr.status === 401 || xhr.status === 403 || xhr.status === 0) {
                        var currentUrl = window.location.pathname + window.location.search;
                        var loginUrl = '@Url.Action("Login", "Account")' + '?returnUrl=' + encodeURIComponent(currentUrl);
                        window.location.href = loginUrl;
                    } else {
                        alert('Có lỗi xảy ra. Vui lòng thử lại.');
                    }
                }
            });
        }

        function updateCartCount() {
            $.ajax({
                url: '@Url.Action("GetCartCount", "Cart")',
                type: 'GET',
                success: function(response) {
                    var cartCount = $('#cart-count');
                    if (cartCount.length) {
                        cartCount.text(response.count);
                        if (response.count > 0) {
                            cartCount.show();
                        } else {
                            cartCount.hide();
                        }
                    }
                }
            });
        }

        // Update cart count on page load
        $(document).ready(function() {
            updateCartCount();
        });
    </script>
}

