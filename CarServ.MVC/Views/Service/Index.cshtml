@model IEnumerable<CarServ.MVC.Models.Service>

@{
    ViewData["Title"] = "Dịch Vụ";
}

<!-- Page Header Start -->
<div class="container-fluid page-header mb-5 p-0" style="background-image: url(/img/carousel-bg-1.jpg);">
    <div class="container-fluid page-header-inner py-5">
        <div class="container text-center pb-5">
            <h1 class="display-3 text-white mb-3 animated slideInDown">Dịch Vụ Của Chúng Tôi</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb justify-content-center text-uppercase">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Trang Chủ</a></li>
                    <li class="breadcrumb-item text-white active" aria-current="page">Dịch Vụ</li>
                </ol>
            </nav>
        </div>
    </div>
</div>
<!-- Page Header End -->

<!-- Service Start -->
<div class="container-xxl py-5">
    <div class="container">
        <!-- Search and Filter -->
        <div class="row mb-4">
            <div class="col-md-8">
                <form asp-action="Index" method="get" class="d-flex">
                    <input type="text" name="searchString" class="form-control me-2" placeholder="Tìm kiếm dịch vụ..." value="@ViewData["CurrentFilter"]">
                    <button type="submit" class="btn btn-primary">Tìm Kiếm</button>
                </form>
            </div>
            <div class="col-md-4">
                <form asp-action="Index" method="get" class="d-flex">
                    <input type="hidden" name="searchString" value="@ViewData["CurrentFilter"]">
                    <select name="categoryFilter" class="form-select" onchange="this.form.submit()">
                        <option value="">Tất cả danh mục</option>
                        @foreach (var category in (List<string>)ViewData["Categories"])
                        {
                            <option value="@category" selected="@(ViewData["CategoryFilter"]?.ToString() == category)">@category</option>
                        }
                    </select>
                </form>
            </div>
        </div>

        <!-- Services Count -->
        @if (Model != null && Model.Any())
        {
            <div class="row mb-4">
                <div class="col-12">
                    <p class="text-muted">Hiển thị <strong>@Model.Count()</strong> dịch vụ</p>
                </div>
            </div>
        }

        <!-- Services Grid -->
        <div class="row g-4">
            @if (Model != null && Model.Any())
            {
                @foreach (var service in Model)
                {
                    <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.1s">
                        <div class="service-item bg-light d-flex flex-column overflow-hidden h-100">
                            <div class="position-relative overflow-hidden">
                                @if (!string.IsNullOrEmpty(service.ImageUrl))
                                {
                                    <img class="img-fluid" src="@service.ImageUrl" alt="@service.ServiceName" style="width: 100%; height: 250px; object-fit: cover;">
                                }
                                else
                                {
                                    <img class="img-fluid" src="~/img/service-1.jpg" alt="@service.ServiceName" style="width: 100%; height: 250px; object-fit: cover;">
                                }
                                @if (service.IsFeatured)
                                {
                                    <div class="position-absolute top-0 start-0 bg-warning text-white px-3 py-1 m-2 rounded">
                                        <small><i class="fa fa-star"></i> Nổi bật</small>
                                    </div>
                                }
                                <div class="service-overlay position-absolute start-0 top-0 w-100 h-100">
                                    <a class="btn btn-lg btn-primary btn-lg-square rounded-circle m-1" href="@(string.IsNullOrEmpty(service.Slug) ? Url.Action("Details", "Service", new { id = service.ServiceId }) : Url.Action("Details", "Service", new { slug = service.Slug }))">
                                        <i class="fa fa-link"></i>
                                    </a>
                                </div>
                            </div>
                            <div class="text-center p-4 pt-0 flex-grow-1 d-flex flex-column">
                                <div class="d-inline-block bg-primary text-white rounded-pill mb-3 px-3 py-1">
                                    @if (!string.IsNullOrEmpty(service.ServiceCategory))
                                    {
                                        <small>@service.ServiceCategory</small>
                                    }
                                    else
                                    {
                                        <small>Dịch Vụ</small>
                                    }
                                </div>
                                <h5 class="mb-3">@service.ServiceName</h5>
                                @if (!string.IsNullOrEmpty(service.ShortDescription))
                                {
                                    <p class="mb-3 flex-grow-1">@service.ShortDescription</p>
                                }
                                else if (!string.IsNullOrEmpty(service.Description))
                                {
                                    <p class="mb-3 flex-grow-1">@(service.Description.Length > 100 ? service.Description.Substring(0, 100) + "..." : service.Description)</p>
                                }
                                <div class="d-flex flex-column gap-2 mt-auto">
                                    <div class="d-flex justify-content-between align-items-center">
                                        @if (service.Price.HasValue)
                                        {
                                            <h5 class="text-primary mb-0">@service.Price.Value.ToString("N0") đ</h5>
                                        }
                                        else
                                        {
                                            <h5 class="text-primary mb-0">Liên hệ</h5>
                                        }
                                    </div>
                                    <div class="d-flex gap-2">
                                    <a class="btn btn-sm btn-primary rounded py-2 px-3 flex-fill" href="@(string.IsNullOrEmpty(service.Slug) ? Url.Action("Details", "Service", new { id = service.ServiceId }) : Url.Action("Details", "Service", new { slug = service.Slug }))">
                                        Xem Chi Tiết <i class="fa fa-arrow-right ms-2"></i>
                                    </a>
                                        <a class="btn btn-sm btn-success rounded py-2 px-3" href="@Url.Action("Index", "Booking", new { serviceId = service.ServiceId })" title="Đặt lịch ngay">
                                            <i class="fa fa-calendar-check"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center">
                    <p class="text-muted">Không tìm thấy dịch vụ nào.</p>
                </div>
            }
        </div>
    </div>
</div>
<!-- Service End -->

