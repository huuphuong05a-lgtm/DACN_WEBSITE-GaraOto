@model IEnumerable<CarServ.MVC.Models.Service>

@{
    ViewData["Title"] = "Dịch Vụ";
}

<!-- Page Header -->
<div class="container-fluid page-header p-0" style="background-image: url(/img/carousel-bg-1.jpg);">
    <div class="container-fluid page-header-inner py-5">
        <div class="container text-center py-4">
            <p class="text-white-50 text-uppercase mb-2" style="font-size: 12px; letter-spacing: 4px; font-weight: 600;">NHP-AUTO</p>
            <h1 class="text-white mb-3" style="font-family:'Montserrat',sans-serif; font-weight:800; font-size:clamp(1.6rem,3.5vw,2.2rem);">Dịch Vụ Của Chúng Tôi</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb justify-content-center mb-0" style="font-size: 13px;">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")" class="text-white-50 text-decoration-none">Trang Chủ</a></li>
                    <li class="breadcrumb-item text-white active" aria-current="page">Dịch Vụ</li>
                </ol>
            </nav>
        </div>
    </div>
</div>

<!-- Service Start -->
<div class="container-xxl py-5">
    <div class="container">
        <!-- Search & Filter -->
        <div class="row mb-4 g-3 align-items-center">
            <div class="col-md-7">
                <form asp-action="Index" method="get" class="d-flex gap-2">
                    <div class="position-relative flex-fill">
                        <i class="fa fa-search position-absolute text-muted" style="left: 14px; top: 50%; transform: translateY(-50%); font-size: 13px;"></i>
                        <input type="text" name="searchString" class="form-control" placeholder="Tìm kiếm dịch vụ..." value="@ViewData["CurrentFilter"]" style="padding-left: 38px;">
                    </div>
                    <button type="submit" class="btn btn-primary rounded-pill px-4" style="font-size: 13px;">Tìm</button>
                </form>
            </div>
            <div class="col-md-3 ms-auto">
                <form asp-action="Index" method="get">
                    <input type="hidden" name="searchString" value="@ViewData["CurrentFilter"]">
                    <select name="categoryFilter" class="form-select" onchange="this.form.submit()" style="font-size: 13px;">
                        <option value="">Tất cả danh mục</option>
                        @foreach (var category in (List<string>)ViewData["Categories"])
                        {
                            <option value="@category" selected="@(ViewData["CategoryFilter"]?.ToString() == category)">@category</option>
                        }
                    </select>
                </form>
            </div>
        </div>

        <!-- Count -->
        @if (Model != null && Model.Any())
        {
            <div class="mb-4">
                <p class="text-muted mb-0" style="font-size: 13px;">Hiển thị <strong class="text-dark">@Model.Count()</strong> dịch vụ</p>
            </div>
        }

        <!-- Services Grid -->
        <div class="row g-4">
            @if (Model != null && Model.Any())
            {
                @foreach (var service in Model)
                {
                    <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.1s">
                        <div class="service-item bg-white d-flex flex-column h-100" style="border-radius: 14px; overflow: hidden; border: 1px solid #f0f0f0;">
                            <!-- Image -->
                            <div class="position-relative overflow-hidden">
                                @if (!string.IsNullOrEmpty(service.ImageUrl))
                                {
                                    <img class="img-fluid w-100" src="@service.ImageUrl" alt="@service.ServiceName" style="height: 220px; object-fit: cover;">
                                }
                                else
                                {
                                    <img class="img-fluid w-100" src="~/img/service-1.jpg" alt="@service.ServiceName" style="height: 220px; object-fit: cover;">
                                }
                                @if (service.IsFeatured)
                                {
                                    <div class="position-absolute top-0 start-0 m-3">
                                        <span class="badge rounded-pill text-white px-3 py-1" style="font-size: 11px; font-weight: 600; background: rgba(225,29,46,0.9); backdrop-filter: blur(4px);">
                                            <i class="fa fa-star me-1" style="font-size: 9px;"></i>Nổi bật
                                        </span>
                                    </div>
                                }
                                <div class="service-overlay position-absolute start-0 top-0 w-100 h-100">
                                    <a class="btn btn-primary rounded-circle d-flex align-items-center justify-content-center" href="@(string.IsNullOrEmpty(service.Slug) ? Url.Action("Details", "Service", new { id = service.ServiceId }) : Url.Action("Details", "Service", new { slug = service.Slug }))" style="width: 40px; height: 40px;">
                                        <i class="fa fa-arrow-right" style="font-size: 13px;"></i>
                                    </a>
                                </div>
                            </div>

                            <!-- Content -->
                            <div class="p-4 flex-grow-1 d-flex flex-column">
                                <!-- Category Badge -->
                                <div class="mb-2">
                                    @if (!string.IsNullOrEmpty(service.ServiceCategory))
                                    {
                                        <span class="badge rounded-pill px-3 py-1" style="font-size: 11px; font-weight: 500; background: rgba(225,29,46,0.08); color: #E11D2E;">@service.ServiceCategory</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill px-3 py-1" style="font-size: 11px; font-weight: 500; background: rgba(225,29,46,0.08); color: #E11D2E;">Dịch Vụ</span>
                                    }
                                </div>

                                <!-- Title -->
                                <h6 class="fw-bold text-dark mb-2" style="font-size: 15px; line-height: 1.4;">@service.ServiceName</h6>

                                <!-- Description -->
                                @if (!string.IsNullOrEmpty(service.ShortDescription))
                                {
                                    <p class="text-muted mb-3 flex-grow-1" style="font-size: 13px; line-height: 1.6;">@service.ShortDescription</p>
                                }
                                else if (!string.IsNullOrEmpty(service.Description))
                                {
                                    <p class="text-muted mb-3 flex-grow-1" style="font-size: 13px; line-height: 1.6;">@(service.Description.Length > 100 ? service.Description.Substring(0, 100) + "..." : service.Description)</p>
                                }

                                <!-- Price + Actions -->
                                <div class="d-flex align-items-center justify-content-between mt-auto pt-3" style="border-top: 1px solid #f3f4f6;">
                                    @if (service.Price.HasValue)
                                    {
                                        <span class="text-primary fw-bold" style="font-size: 15px;">@service.Price.Value.ToString("N0") đ</span>
                                    }
                                    else
                                    {
                                        <span class="text-primary fw-bold" style="font-size: 14px;">Liên hệ</span>
                                    }
                                    <div class="d-flex gap-2">
                                        <a class="btn btn-primary rounded-pill px-3 py-1" href="@(string.IsNullOrEmpty(service.Slug) ? Url.Action("Details", "Service", new { id = service.ServiceId }) : Url.Action("Details", "Service", new { slug = service.Slug }))" style="font-size: 12px;">
                                            Chi Tiết <i class="fa fa-arrow-right ms-1" style="font-size: 10px;"></i>
                                        </a>
                                        <a class="btn btn-outline-dark rounded-pill px-3 py-1" href="@Url.Action("Index", "Booking", new { serviceId = service.ServiceId })" title="Đặt lịch" style="font-size: 12px;">
                                            <i class="fa fa-calendar-check"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <div class="d-flex flex-column align-items-center">
                        <i class="fa fa-search fa-2x text-muted mb-3"></i>
                        <p class="text-muted mb-0" style="font-size: 14px;">Không tìm thấy dịch vụ nào.</p>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
<!-- Service End -->
