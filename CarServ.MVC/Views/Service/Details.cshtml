@model CarServ.MVC.Models.Service

@{
    ViewData["Title"] = Model.ServiceName;
    var relatedServices = ViewData["RelatedServices"] as List<CarServ.MVC.Models.Service> ?? new List<CarServ.MVC.Models.Service>();
}

<!-- Page Header Start -->
<div class="container-fluid page-header mb-5 p-0" style="background-image: url(/img/carousel-bg-1.jpg);">
    <div class="container-fluid page-header-inner py-5">
        <div class="container text-center pb-5">
            <h1 class="display-3 text-white mb-3 animated slideInDown">@Model.ServiceName</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb justify-content-center text-uppercase">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Trang Chủ</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Service")">Dịch Vụ</a></li>
                    <li class="breadcrumb-item text-white active" aria-current="page">@Model.ServiceName</li>
                </ol>
            </nav>
        </div>
    </div>
</div>
<!-- Page Header End -->

<!-- Service Details Start -->
<div class="container-xxl py-5">
    <div class="container">
        <div class="row g-5">
            <div class="col-lg-8">
                <div class="mb-5">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img class="img-fluid rounded w-100 mb-4" src="@Model.ImageUrl" alt="@Model.ServiceName" style="height: 400px; object-fit: cover;">
                    }
                    else
                    {
                        <img class="img-fluid rounded w-100 mb-4" src="~/img/service-1.jpg" alt="@Model.ServiceName" style="height: 400px; object-fit: cover;">
                    }

                    <h2 class="mb-4">@Model.ServiceName</h2>
                    
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <div class="mb-4">
                            @Html.Raw(Model.Description.Replace("\n", "<br>"))
                        </div>
                    }

                    @if (Model.EstimatedDuration.HasValue)
                    {
                        <div class="mb-3">
                            <strong><i class="fa fa-clock text-primary me-2"></i>Thời gian ước tính:</strong> @Model.EstimatedDuration phút
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.ServiceCategory))
                    {
                        <div class="mb-3">
                            <strong><i class="fa fa-tag text-primary me-2"></i>Danh mục:</strong> @Model.ServiceCategory
                        </div>
                    }
                </div>
            </div>

            <div class="col-lg-4">
                <div class="bg-light rounded p-4 mb-4">
                    <h4 class="mb-4">Thông Tin Dịch Vụ</h4>
                    
                    @if (Model.Price.HasValue)
                    {
                        <div class="mb-3">
                            <h3 class="text-primary mb-0">@Model.Price.Value.ToString("N0") đ</h3>
                        </div>
                    }
                    else
                    {
                        <div class="mb-3">
                            <h3 class="text-primary mb-0">Liên hệ</h3>
                        </div>
                    }

                    @if (Model.EstimatedDuration.HasValue)
                    {
                        <div class="mb-3">
                            <i class="fa fa-clock text-primary me-2"></i>
                            <strong>Thời gian:</strong> @Model.EstimatedDuration phút
                        </div>
                    }

                    <a href="@Url.Action("Index", "Booking", new { serviceId = Model.ServiceId })" class="btn btn-primary w-100 py-3">
                        <i class="fa fa-calendar-check me-2"></i>Đặt Lịch Ngay
                    </a>
                </div>

                @if (Model.IsFeatured)
                {
                    <div class="bg-primary text-white rounded p-4 text-center">
                        <i class="fa fa-star fa-3x mb-3"></i>
                        <h5>Dịch Vụ Nổi Bật</h5>
                        <p class="mb-0">Dịch vụ được khách hàng yêu thích nhất</p>
                    </div>
                }
            </div>
        </div>

        <!-- Reviews Section -->
        @await Html.PartialAsync("_ServiceReviews", Model)

        <!-- Related Services -->
        @if (relatedServices.Any())
        {
            <div class="row g-4 mt-2">
                <div class="col-12">
                    <h3 class="mb-4">Dịch Vụ Liên Quan</h3>
                </div>
                @foreach (var service in relatedServices)
                {
                    <div class="col-lg-3 col-md-6 wow fadeInUp" data-wow-delay="0.1s">
                        <div class="service-item bg-light d-flex flex-column overflow-hidden h-100">
                            <div class="position-relative overflow-hidden">
                                @if (!string.IsNullOrEmpty(service.ImageUrl))
                                {
                                    <img class="img-fluid" src="@service.ImageUrl" alt="@service.ServiceName" style="width: 100%; height: 200px; object-fit: cover;">
                                }
                                else
                                {
                                    <img class="img-fluid" src="~/img/service-1.jpg" alt="@service.ServiceName" style="width: 100%; height: 200px; object-fit: cover;">
                                }
                            </div>
                            <div class="text-center p-4 pt-0 flex-grow-1 d-flex flex-column">
                                <h5 class="mb-3">@service.ServiceName</h5>
                                <div class="mt-auto">
                                    <a class="btn btn-sm btn-primary rounded py-2 px-4" href="@Url.Action("Details", "Service", new { id = service.ServiceId })">
                                        Xem Chi Tiết <i class="fa fa-arrow-right ms-2"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
<!-- Service Details End -->


