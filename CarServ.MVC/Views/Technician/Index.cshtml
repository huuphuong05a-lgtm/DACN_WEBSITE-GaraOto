@model IEnumerable<CarServ.MVC.Models.Technician>

@{
    ViewData["Title"] = "Kỹ Thuật Viên";
}

<!-- Page Header Start -->
<div class="container-fluid page-header mb-5 p-0" style="background-image: url(/img/carousel-bg-1.jpg);">
    <div class="container-fluid page-header-inner py-5">
        <div class="container text-center pb-5">
            <h1 class="display-3 text-white mb-3 animated slideInDown">Đội Ngũ Kỹ Thuật Viên</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb justify-content-center text-uppercase">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Trang Chủ</a></li>
                    <li class="breadcrumb-item text-white active" aria-current="page">Kỹ Thuật Viên</li>
                </ol>
            </nav>
        </div>
    </div>
</div>
<!-- Page Header End -->

<!-- Team Start -->
<div class="container-xxl py-5">
    <div class="container">
        <!-- Search -->
        <div class="row mb-4">
            <div class="col-md-6">
                <form asp-action="Index" method="get" class="d-flex">
                    <input type="text" name="searchString" class="form-control me-2" placeholder="Tìm kiếm kỹ thuật viên..." value="@ViewData["CurrentFilter"]">
                    <button type="submit" class="btn btn-primary">Tìm Kiếm</button>
                </form>
            </div>
        </div>

        <div class="row g-4">
            @if (Model != null && Model.Any())
            {
                @foreach (var technician in Model)
                {
                    <div class="col-lg-3 col-md-6 wow fadeInUp" data-wow-delay="0.1s">
                        <div class="team-item">
                            <div class="position-relative overflow-hidden">
                                @if (!string.IsNullOrEmpty(technician.ImageUrl))
                                {
                                    <img class="img-fluid" src="@technician.ImageUrl" alt="@technician.FullName" style="width: 100%; height: 300px; object-fit: cover;">
                                }
                                else
                                {
                                    <img class="img-fluid" src="~/img/team-1.jpg" alt="@technician.FullName" style="width: 100%; height: 300px; object-fit: cover;">
                                }
                                <div class="team-overlay position-absolute start-0 top-0 w-100 h-100">
                                    <a class="btn btn-square mx-1" href="@Url.Action("Details", "Technician", new { id = technician.TechnicianId })">
                                        <i class="fa fa-eye"></i>
                                    </a>
                                </div>
                            </div>
                            <div class="bg-light text-center p-4">
                                <h5 class="fw-bold mb-0">@technician.FullName</h5>
                                @if (!string.IsNullOrEmpty(technician.Position))
                                {
                                    <small>@technician.Position</small>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center">
                    <p class="text-muted">Không tìm thấy kỹ thuật viên nào.</p>
                </div>
            }
        </div>
    </div>
</div>
<!-- Team End -->

