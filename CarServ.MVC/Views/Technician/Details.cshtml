@model CarServ.MVC.Models.Technician

@{
    ViewData["Title"] = Model.FullName;
    var otherTechnicians = ViewData["OtherTechnicians"] as List<CarServ.MVC.Models.Technician> ?? new List<CarServ.MVC.Models.Technician>();
}

<!-- Page Header Start -->
<div class="container-fluid page-header mb-5 p-0" style="background-image: url(/img/carousel-bg-1.jpg);">
    <div class="container-fluid page-header-inner py-5">
        <div class="container text-center pb-5">
            <h1 class="display-3 text-white mb-3 animated slideInDown">@Model.FullName</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb justify-content-center text-uppercase">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Trang Chủ</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Technician")">Kỹ Thuật Viên</a></li>
                    <li class="breadcrumb-item text-white active" aria-current="page">@Model.FullName</li>
                </ol>
            </nav>
        </div>
    </div>
</div>
<!-- Page Header End -->

<!-- Technician Details Start -->
<div class="container-xxl py-5">
    <div class="container">
        <div class="row g-5">
            <div class="col-lg-4">
                <div class="bg-light rounded p-4 text-center">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img class="img-fluid rounded-circle mb-4" src="@Model.ImageUrl" alt="@Model.FullName" style="width: 300px; height: 300px; object-fit: cover;">
                    }
                    else
                    {
                        <img class="img-fluid rounded-circle mb-4" src="~/img/team-1.jpg" alt="@Model.FullName" style="width: 300px; height: 300px; object-fit: cover;">
                    }
                    <h3 class="mb-3">@Model.FullName</h3>
                    @if (!string.IsNullOrEmpty(Model.Position))
                    {
                        <h5 class="text-primary mb-3">@Model.Position</h5>
                    }
                </div>
            </div>

            <div class="col-lg-8">
                <h2 class="mb-4">Thông Tin Kỹ Thuật Viên</h2>
                
                @if (!string.IsNullOrEmpty(Model.Skills))
                {
                    <div class="mb-4">
                        <h5>Kỹ năng</h5>
                        <p>@Model.Skills</p>
                    </div>
                }

                @if (!string.IsNullOrEmpty(Model.Bio))
                {
                    <div class="mb-4">
                        <h5>Giới thiệu</h5>
                        <p>@Html.Raw(Model.Bio.Replace("\n", "<br>"))</p>
                    </div>
                }

                <div class="row mb-4">
                    @if (!string.IsNullOrEmpty(Model.Email))
                    {
                        <div class="col-md-6 mb-3">
                            <strong><i class="fa fa-envelope text-primary me-2"></i>Email:</strong> @Model.Email
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Phone))
                    {
                        <div class="col-md-6 mb-3">
                            <strong><i class="fa fa-phone text-primary me-2"></i>Điện thoại:</strong> @Model.Phone
                        </div>
                    }
                    @if (Model.ExperienceYears.HasValue)
                    {
                        <div class="col-md-6 mb-3">
                            <strong><i class="fa fa-calendar text-primary me-2"></i>Kinh nghiệm:</strong> @Model.ExperienceYears năm
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Other Technicians -->
        @if (otherTechnicians.Any())
        {
            <div class="row g-4 mt-5">
                <div class="col-12">
                    <h3 class="mb-4">Kỹ Thuật Viên Khác</h3>
                </div>
                @foreach (var technician in otherTechnicians)
                {
                    <div class="col-lg-3 col-md-6 wow fadeInUp" data-wow-delay="0.1s">
                        <div class="team-item">
                            <div class="position-relative overflow-hidden">
                                @if (!string.IsNullOrEmpty(technician.ImageUrl))
                                {
                                    <img class="img-fluid" src="@technician.ImageUrl" alt="@technician.FullName" style="width: 100%; height: 250px; object-fit: cover;">
                                }
                                else
                                {
                                    <img class="img-fluid" src="~/img/team-1.jpg" alt="@technician.FullName" style="width: 100%; height: 250px; object-fit: cover;">
                                }
                            </div>
                            <div class="bg-light text-center p-4">
                                <h5 class="fw-bold mb-0">@technician.FullName</h5>
                                @if (!string.IsNullOrEmpty(technician.Position))
                                {
                                    <small>@technician.Position</small>
                                }
                                <div class="mt-3">
                                    <a class="btn btn-sm btn-primary" href="@Url.Action("Details", "Technician", new { id = technician.TechnicianId })">
                                        Xem Chi Tiết
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
<!-- Technician Details End -->

