@model CarServ.MVC.Models.ViewModels.BlogListViewModel

@{
    ViewData["Title"] = "Blog - Tin Tức";
}

<!-- Page Header -->
<div class="container-fluid page-header p-0" style="background-image: url(/img/carousel-bg-1.jpg);">
    <div class="container-fluid page-header-inner py-5">
        <div class="container text-center py-4">
            <p class="text-white-50 text-uppercase mb-2" style="font-size: 12px; letter-spacing: 4px; font-weight: 600;">NHP-AUTO</p>
            <h1 class="text-white mb-3" style="font-family:'Montserrat',sans-serif; font-weight:800; font-size:clamp(1.6rem,3.5vw,2.2rem);">Blog & Tin Tức</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb justify-content-center mb-0" style="font-size: 13px;">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")" class="text-white-50 text-decoration-none">Trang Chủ</a></li>
                    <li class="breadcrumb-item text-white active" aria-current="page">Blog</li>
                </ol>
            </nav>
        </div>
    </div>
</div>

<!-- Blog Start -->
<div class="container-xxl py-5">
    <div class="container">
        <div class="row g-5">
            <!-- Main Content -->
            <div class="col-lg-8">
                @if (!string.IsNullOrEmpty(Model.SearchQuery))
                {
                    <div class="mb-4">
                        <h5 class="fw-bold text-dark" style="font-size: 15px;">Kết quả: "@(Model.SearchQuery ?? "")"</h5>
                        <p class="text-muted mb-0" style="font-size: 13px;">Tìm thấy <strong class="text-dark">@Model.TotalPosts</strong> bài viết</p>
                    </div>
                }
                else if (Model.CurrentCategoryId.HasValue)
                {
                    <div class="mb-4">
                        <h5 class="fw-bold text-dark" style="font-size: 15px;">Chuyên mục: @(Model.CurrentCategoryName ?? "")</h5>
                        <p class="text-muted mb-0" style="font-size: 13px;">@Model.TotalPosts bài viết</p>
                    </div>
                }

                @if (Model.Posts.Any())
                {
                    <div class="d-flex flex-column gap-4">
                        @foreach (var post in Model.Posts)
                        {
                            <article class="bg-white d-flex flex-column flex-md-row overflow-hidden" style="border-radius: 14px; border: 1px solid #f0f0f0; transition: all 0.25s cubic-bezier(0.4,0,0.2,1);" onmouseover="this.style.transform='translateY(-3px)';this.style.boxShadow='0 8px 24px rgba(0,0,0,0.08)'" onmouseout="this.style.transform='none';this.style.boxShadow='none'">
                                @if (!string.IsNullOrEmpty(post.Thumbnail))
                                {
                                    <a href="@Url.Action("Detail", "Blog", new { slug = post.Slug })" class="flex-shrink-0" style="width: 280px; min-height: 200px;">
                                        <img src="@(post.Thumbnail ?? "")" class="w-100 h-100" alt="@post.Title" style="object-fit: cover;">
                                    </a>
                                }
                                <div class="p-4 d-flex flex-column flex-grow-1 @(string.IsNullOrEmpty(post.Thumbnail ?? "") ? "" : "")">
                                    <!-- Meta -->
                                    <div class="d-flex align-items-center flex-wrap gap-2 mb-2">
                                        @if (!string.IsNullOrEmpty(post.CategoryName))
                                        {
                                            <a href="@Url.Action("Index", "Blog", new { categoryId = post.CategoryId })" class="badge rounded-pill text-decoration-none" style="font-size: 10px; font-weight: 600; background: rgba(225,29,46,0.08); color: #E11D2E; padding: 4px 10px;">
                                                @(post.CategoryName ?? "")
                                            </a>
                                        }
                                        @if (post.PublishedDate.HasValue)
                                        {
                                            <span class="text-muted" style="font-size: 11px;">
                                                @post.PublishedDate.Value.ToString("dd/MM/yyyy")
                                            </span>
                                        }
                                        <span class="text-muted ms-auto" style="font-size: 11px;">
                                            <i class="fa fa-eye me-1" style="font-size: 10px;"></i>@post.ViewCount
                                        </span>
                                    </div>

                                    <!-- Title -->
                                    <h6 class="fw-bold mb-2" style="font-size: 15px; line-height: 1.4;">
                                        <a href="@Url.Action("Detail", "Blog", new { slug = post.Slug })" class="text-dark text-decoration-none">
                                            @post.Title
                                        </a>
                                    </h6>

                                    <!-- Excerpt -->
                                    @if (!string.IsNullOrEmpty(post.ShortDescription))
                                    {
                                        <p class="text-muted mb-3 flex-grow-1" style="font-size: 13px; line-height: 1.6;">@(post.ShortDescription ?? "")</p>
                                    }

                                    <!-- Read More -->
                                    <a href="@Url.Action("Detail", "Blog", new { slug = post.Slug })" class="text-primary fw-bold text-decoration-none mt-auto" style="font-size: 12px;">
                                        Đọc tiếp <i class="fa fa-arrow-right ms-1" style="font-size: 10px;"></i>
                                    </a>
                                </div>
                            </article>
                        }
                    </div>

                    <!-- Pagination -->
                    @if (Model.TotalPages > 1)
                    {
                        <nav aria-label="Pagination" class="mt-5">
                            <ul class="pagination justify-content-center gap-1 mb-0">
                                @if (Model.CurrentPage > 1)
                                {
                                    <li class="page-item">
                                        <a class="page-link" href="@Url.Action("Index", "Blog", new { categoryId = Model.CurrentCategoryId, search = Model.SearchQuery, page = Model.CurrentPage - 1 })" style="font-size: 13px;">
                                            <i class="fa fa-chevron-left" style="font-size: 10px;"></i>
                                        </a>
                                    </li>
                                }

                                @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
                                {
                                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                        <a class="page-link" href="@Url.Action("Index", "Blog", new { categoryId = Model.CurrentCategoryId, search = Model.SearchQuery, page = i })" style="font-size: 13px;">
                                            @i
                                        </a>
                                    </li>
                                }

                                @if (Model.CurrentPage < Model.TotalPages)
                                {
                                    <li class="page-item">
                                        <a class="page-link" href="@Url.Action("Index", "Blog", new { categoryId = Model.CurrentCategoryId, search = Model.SearchQuery, page = Model.CurrentPage + 1 })" style="font-size: 13px;">
                                            <i class="fa fa-chevron-right" style="font-size: 10px;"></i>
                                        </a>
                                    </li>
                                }
                            </ul>
                        </nav>
                    }
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="fa fa-file-alt fa-2x text-muted mb-3"></i>
                        <p class="text-muted mb-0" style="font-size: 14px;">Chưa có bài viết nào.</p>
                    </div>
                }
            </div>

            <!-- Sidebar -->
            <div class="col-lg-4">
                <div class="sticky-lg-top d-flex flex-column gap-4" style="top: 90px;">
                    <!-- Search -->
                    <div class="bg-white p-4" style="border-radius: 14px; border: 1px solid #f0f0f0;">
                        <h6 class="fw-bold text-dark mb-3" style="font-size: 13px; text-transform: uppercase; letter-spacing: 1px;">Tìm Kiếm</h6>
                        <form asp-action="Index" method="get">
                            <input type="hidden" name="categoryId" value="@Model.CurrentCategoryId">
                            <div class="position-relative">
                                <i class="fa fa-search position-absolute text-muted" style="left: 14px; top: 50%; transform: translateY(-50%); font-size: 12px;"></i>
                                <input type="text" name="search" class="form-control" placeholder="Tìm bài viết..." value="@Model.SearchQuery" style="padding-left: 36px; padding-right: 70px;">
                                <button class="btn btn-primary position-absolute end-0 top-0 h-100 px-3" type="submit" style="border-radius: 0 10px 10px 0; font-size: 12px;">Tìm</button>
                            </div>
                        </form>
                    </div>

                    <!-- Categories -->
                    @if (Model.Categories.Any())
                    {
                        <div class="bg-white p-4" style="border-radius: 14px; border: 1px solid #f0f0f0;">
                            <h6 class="fw-bold text-dark mb-3" style="font-size: 13px; text-transform: uppercase; letter-spacing: 1px;">Chuyên Mục</h6>
                            <div class="d-flex flex-column gap-1">
                                <a href="@Url.Action("Index", "Blog")" class="d-flex align-items-center justify-content-between text-decoration-none py-2 px-3 @(Model.CurrentCategoryId == null ? "text-primary fw-bold" : "text-muted")" style="font-size: 13px; border-radius: 8px; transition: background 0.2s;" onmouseover="this.style.background='#f9fafb'" onmouseout="this.style.background='transparent'">
                                    <span>Tất cả</span>
                                </a>
                                @foreach (var category in Model.Categories)
                                {
                                    <a href="@Url.Action("Index", "Blog", new { categoryId = category.Id })" class="d-flex align-items-center justify-content-between text-decoration-none py-2 px-3 @(Model.CurrentCategoryId == category.Id ? "text-primary fw-bold" : "text-muted")" style="font-size: 13px; border-radius: 8px; transition: background 0.2s;" onmouseover="this.style.background='#f9fafb'" onmouseout="this.style.background='transparent'">
                                        <span>@category.Name</span>
                                    </a>
                                }
                            </div>
                        </div>
                    }

                    <!-- Latest Posts -->
                    @{
                        var latestPosts = ViewData["LatestPosts"] as List<CarServ.MVC.Models.ViewModels.BlogPostItemViewModel> ?? new List<CarServ.MVC.Models.ViewModels.BlogPostItemViewModel>();
                    }
                    @if (latestPosts.Any())
                    {
                        <div class="bg-white p-4" style="border-radius: 14px; border: 1px solid #f0f0f0;">
                            <h6 class="fw-bold text-dark mb-3" style="font-size: 13px; text-transform: uppercase; letter-spacing: 1px;">Mới Nhất</h6>
                            <div class="d-flex flex-column gap-3">
                                @foreach (var post in latestPosts)
                                {
                                    <a href="@Url.Action("Detail", "Blog", new { slug = post.Slug })" class="d-flex align-items-start gap-3 text-decoration-none">
                                        @if (!string.IsNullOrEmpty(post.Thumbnail))
                                        {
                                            <img src="@(post.Thumbnail ?? "")" class="flex-shrink-0" alt="@post.Title" style="width: 56px; height: 56px; object-fit: cover; border-radius: 8px;">
                                        }
                                        <div class="flex-grow-1 min-width-0">
                                            <h6 class="fw-bold text-dark mb-1" style="font-size: 13px; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">@post.Title</h6>
                                            @if (post.PublishedDate.HasValue)
                                            {
                                                <span class="text-muted" style="font-size: 11px;">@post.PublishedDate.Value.ToString("dd/MM/yyyy")</span>
                                            }
                                        </div>
                                    </a>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Blog End -->
