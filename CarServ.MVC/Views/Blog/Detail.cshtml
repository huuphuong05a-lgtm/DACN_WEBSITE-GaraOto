@model CarServ.MVC.Models.ViewModels.BlogDetailViewModel

@{
    ViewData["Title"] = Model.Post.SeoTitle ?? Model.Post.Title;
    ViewData["MetaDescription"] = Model.Post.SeoDescription ?? Model.Post.ShortDescription;
}

<!-- Page Header Start -->
<div class="container-fluid page-header mb-5 p-0" style="background-image: url(/img/carousel-bg-1.jpg);">
    <div class="container-fluid page-header-inner py-5">
        <div class="container text-center pb-5">
            <h1 class="display-3 text-white mb-3 animated slideInDown">@Model.Post.Title</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb justify-content-center text-uppercase">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Trang Chủ</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Blog")">Blog</a></li>
                    @if (Model.Post.Category != null)
                    {
                        <li class="breadcrumb-item"><a href="@Url.Action("Index", "Blog", new { categoryId = Model.Post.Category.Id })">@Model.Post.Category.Name</a></li>
                    }
                    <li class="breadcrumb-item text-white active" aria-current="page">@Model.Post.Title</li>
                </ol>
            </nav>
        </div>
    </div>
</div>
<!-- Page Header End -->

<!-- Blog Detail Start -->
<div class="container-xxl py-5">
    <div class="container">
        <div class="row g-5">
            <!-- Main Content - Left Column (8/12) -->
            <div class="col-lg-8">
                <article class="blog-post">
                    <!-- Post Header -->
                    <div class="mb-4">
                        <h1 class="mb-3">@Model.Post.Title</h1>
                        <div class="d-flex align-items-center flex-wrap mb-3">
                            @if (Model.Post.PublishedDate.HasValue)
                            {
                                <span class="text-muted me-3">
                                    <i class="fa fa-calendar me-1"></i>@Model.Post.PublishedDate.Value.ToString("dd/MM/yyyy HH:mm")
                                </span>
                            }
                            @if (Model.Post.Category != null)
                            {
                                <a href="@Url.Action("Index", "Blog", new { categoryId = Model.Post.Category.Id })" class="badge bg-primary text-decoration-none me-3">
                                    @Model.Post.Category.Name
                                </a>
                            }
                            <span class="text-muted">
                                <i class="fa fa-eye me-1"></i>@Model.Post.ViewCount lượt xem
                            </span>
                        </div>
                    </div>

                    <!-- Thumbnail -->
                    @if (!string.IsNullOrEmpty(Model.Post.Thumbnail))
                    {
                        <div class="mb-4">
                            <img src="@Model.Post.Thumbnail" class="img-fluid rounded w-100" alt="@Model.Post.Title" style="max-height: 500px; object-fit: cover;">
                        </div>
                    }

                    <!-- Short Description -->
                    @if (!string.IsNullOrEmpty(Model.Post.ShortDescription))
                    {
                        <div class="alert alert-light mb-4" role="alert">
                            <p class="mb-0 fst-italic">@Model.Post.ShortDescription</p>
                        </div>
                    }

                    <!-- Content -->
                    <div class="blog-content">
                        @if (!string.IsNullOrEmpty(Model.Post.Content))
                        {
                            @Html.Raw(Model.Post.Content)
                        }
                        else
                        {
                            <p class="text-muted">Nội dung đang được cập nhật...</p>
                        }
                    </div>

                    <!-- Related Posts -->
                    @if (Model.RelatedPosts.Any())
                    {
                        <div class="mt-5">
                            <h4 class="mb-4">Bài Viết Liên Quan</h4>
                            <div class="row g-4">
                                @foreach (var relatedPost in Model.RelatedPosts)
                                {
                                    <div class="col-md-6">
                                        <div class="card h-100 shadow-sm">
                                            @if (!string.IsNullOrEmpty(relatedPost.Thumbnail))
                                            {
                                                <a href="@Url.Action("Detail", "Blog", new { slug = relatedPost.Slug })">
                                                    <img src="@relatedPost.Thumbnail" class="card-img-top" alt="@relatedPost.Title" style="height: 150px; object-fit: cover;">
                                                </a>
                                            }
                                            <div class="card-body">
                                                <h6 class="card-title">
                                                    <a href="@Url.Action("Detail", "Blog", new { slug = relatedPost.Slug })" class="text-dark text-decoration-none">
                                                        @relatedPost.Title
                                                    </a>
                                                </h6>
                                                @if (!string.IsNullOrEmpty(relatedPost.ShortDescription))
                                                {
                                                    <p class="card-text text-muted" style="font-size: 0.9rem;">
                                                        @(relatedPost.ShortDescription.Length > 100 ? relatedPost.ShortDescription.Substring(0, 100) + "..." : relatedPost.ShortDescription)
                                                    </p>
                                                }
                                                <div class="d-flex justify-content-between align-items-center">
                                                    @if (relatedPost.PublishedDate.HasValue)
                                                    {
                                                        <small class="text-muted">@relatedPost.PublishedDate.Value.ToString("dd/MM/yyyy")</small>
                                                    }
                                                    <a href="@Url.Action("Detail", "Blog", new { slug = relatedPost.Slug })" class="btn btn-sm btn-primary">
                                                        Đọc tiếp <i class="fa fa-arrow-right ms-1"></i>
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </article>
            </div>

            <!-- Sidebar - Right Column (4/12) -->
            <div class="col-lg-4">
                <!-- Search Box -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="fa fa-search me-2"></i>Tìm Kiếm</h5>
                    </div>
                    <div class="card-body">
                        <form asp-action="Index" method="get">
                            <div class="input-group">
                                <input type="text" name="search" class="form-control" placeholder="Tìm kiếm bài viết...">
                                <button class="btn btn-primary" type="submit">
                                    <i class="fa fa-search"></i>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Categories -->
                @if (Model.Categories.Any())
                {
                    <div class="card shadow-sm mb-4">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0"><i class="fa fa-folder me-2"></i>Chuyên Mục</h5>
                        </div>
                        <div class="card-body p-0">
                            <ul class="list-group list-group-flush">
                                <li class="list-group-item">
                                    <a href="@Url.Action("Index", "Blog")" class="text-decoration-none text-dark">
                                        <i class="fa fa-list me-2"></i>Tất cả
                                    </a>
                                </li>
                                @foreach (var category in Model.Categories)
                                {
                                    <li class="list-group-item">
                                        <a href="@Url.Action("Index", "Blog", new { categoryId = category.Id })" class="text-decoration-none text-dark">
                                            <i class="fa fa-folder-open me-2"></i>@category.Name
                                        </a>
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                }

                <!-- Latest Posts -->
                @{
                    var latestPosts = ViewData["LatestPosts"] as List<CarServ.MVC.Models.ViewModels.BlogPostItemViewModel> ?? new List<CarServ.MVC.Models.ViewModels.BlogPostItemViewModel>();
                }
                @if (latestPosts.Any())
                {
                    <div class="card shadow-sm">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0"><i class="fa fa-clock me-2"></i>Bài Viết Mới Nhất</h5>
                        </div>
                        <div class="card-body p-0">
                            <ul class="list-group list-group-flush">
                                @foreach (var post in latestPosts)
                                {
                                    <li class="list-group-item">
                                        <a href="@Url.Action("Detail", "Blog", new { slug = post.Slug })" class="text-decoration-none text-dark">
                                            <div class="d-flex align-items-start">
                                                @if (!string.IsNullOrEmpty(post.Thumbnail))
                                                {
                                                    <img src="@post.Thumbnail" class="me-3 rounded" alt="@post.Title" style="width: 60px; height: 60px; object-fit: cover;">
                                                }
                                                <div class="flex-grow-1">
                                                    <h6 class="mb-1" style="font-size: 0.9rem;">@post.Title</h6>
                                                    @if (post.PublishedDate.HasValue)
                                                    {
                                                        <small class="text-muted">@post.PublishedDate.Value.ToString("dd/MM/yyyy")</small>
                                                    }
                                                </div>
                                            </div>
                                        </a>
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
<!-- Blog Detail End -->


