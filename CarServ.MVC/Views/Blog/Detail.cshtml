@model CarServ.MVC.Models.ViewModels.BlogDetailViewModel

@{
    ViewData["Title"] = Model.Post.SeoTitle ?? Model.Post.Title;
    ViewData["MetaDescription"] = Model.Post.SeoDescription ?? Model.Post.ShortDescription;
}

<!-- Page Header Start -->
<div class="container-fluid page-header mb-5 p-0" style="background-image: url(/img/carousel-bg-1.jpg);">
    <div class="container-fluid page-header-inner py-5">
        <div class="container text-center pb-5">
            <h1 class="display-3 text-white mb-3 animated slideInDown">@Model.Post.Title</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb justify-content-center text-uppercase">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Trang Chủ</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Blog")">Blog</a></li>
                    @if (Model.Post.Category != null)
                    {
                        <li class="breadcrumb-item"><a href="@Url.Action("Index", "Blog", new { categoryId = Model.Post.Category.Id })">@Model.Post.Category.Name</a></li>
                    }
                    <li class="breadcrumb-item text-white active" aria-current="page">@Model.Post.Title</li>
                </ol>
            </nav>
        </div>
    </div>
</div>
<!-- Page Header End -->

<!-- Blog Detail Start -->
<div class="container-xxl py-5 blog-detail-page">
    <div class="container">
        <div class="row g-5">
            <!-- Main Content - Left Column (8/12) -->
            <div class="col-lg-8">
                <article class="blog-post">
                    <!-- Post Header -->
                    <div class="mb-4">
                        <h1 class="blog-detail-title">@Model.Post.Title</h1>
                        <div class="blog-meta">
                            @if (Model.Post.PublishedDate.HasValue)
                            {
                                <span>
                                    <i class="far fa-calendar-alt"></i>@Model.Post.PublishedDate.Value.ToString("dd/MM/yyyy")
                                </span>
                            }
                            @if (Model.Post.Category != null)
                            {
                                <span>
                                    <i class="far fa-folder"></i>
                                    <a href="@Url.Action("Index", "Blog", new { categoryId = Model.Post.Category.Id })">@Model.Post.Category.Name</a>
                                </span>
                            }
                            <span>
                                <i class="far fa-eye"></i>@Model.Post.ViewCount lượt xem
                            </span>
                        </div>
                    </div>

                    <!-- Thumbnail -->
                    @if (!string.IsNullOrEmpty(Model.Post.Thumbnail))
                    {
                        <div class="mb-4">
                            <img src="@Model.Post.Thumbnail" class="img-fluid rounded w-100" alt="@Model.Post.Title" style="max-height: 500px; object-fit: cover;">
                        </div>
                    }

                    <!-- Short Description -->
                    @if (!string.IsNullOrEmpty(Model.Post.ShortDescription))
                    {
                        <div class="alert alert-light mb-4" role="alert">
                            <p class="mb-0 fst-italic">@Model.Post.ShortDescription</p>
                        </div>
                    }

                    <!-- Content -->
                    <div class="blog-content">
                        @if (!string.IsNullOrEmpty(Model.Post.Content))
                        {
                            @Html.Raw(Model.Post.Content)
                        }
                        else
                        {
                            <p class="text-muted">Nội dung đang được cập nhật...</p>
                        }
                    </div>

                    <!-- Related Posts -->
                    @if (Model.RelatedPosts.Any())
                    {
                        <section class="related-blog-section mt-5">
                            <div class="related-blog-heading">
                                <span>Đọc thêm</span>
                                <h4>Bài Viết Liên Quan</h4>
                            </div>
                            <div class="related-blog-grid">
                                @foreach (var relatedPost in Model.RelatedPosts)
                                {
                                    <article class="related-blog-card">
                                            @if (!string.IsNullOrEmpty(relatedPost.Thumbnail))
                                            {
                                                <a class="related-blog-image" href="@Url.Action("Detail", "Blog", new { slug = relatedPost.Slug })">
                                                    <img src="@relatedPost.Thumbnail" alt="@relatedPost.Title">
                                                </a>
                                            }
                                            <div class="related-blog-body">
                                                <h5>
                                                    <a href="@Url.Action("Detail", "Blog", new { slug = relatedPost.Slug })">
                                                        @relatedPost.Title
                                                    </a>
                                                </h5>
                                                @if (!string.IsNullOrEmpty(relatedPost.ShortDescription))
                                                {
                                                    <p>
                                                        @(relatedPost.ShortDescription.Length > 100 ? relatedPost.ShortDescription.Substring(0, 100) + "..." : relatedPost.ShortDescription)
                                                    </p>
                                                }
                                                <div class="related-blog-footer">
                                                    @if (relatedPost.PublishedDate.HasValue)
                                                    {
                                                        <time><i class="far fa-calendar-alt me-1"></i>@relatedPost.PublishedDate.Value.ToString("dd/MM/yyyy")</time>
                                                    }
                                                    <a href="@Url.Action("Detail", "Blog", new { slug = relatedPost.Slug })" class="related-blog-link">
                                                        Đọc tiếp <i class="fa fa-arrow-right ms-2"></i>
                                                    </a>
                                                </div>
                                            </div>
                                    </article>
                                }
                            </div>
                        </section>
                    }
                </article>
            </div>

            <!-- Sidebar - Right Column (4/12) -->
            <div class="col-lg-4">
                <!-- Search Box -->
                <div class="sidebar-widget">
                    <h5 class="widget-title"><i class="fa fa-search me-2"></i>Tìm Kiếm</h5>
                    <div>
                        <form asp-action="Index" method="get">
                            <div class="input-group">
                                <input type="text" name="search" class="form-control" placeholder="Tìm kiếm bài viết...">
                                <button class="btn btn-primary" type="submit">
                                    <i class="fa fa-search"></i>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Categories -->
                @if (Model.Categories.Any())
                {
                    <div class="sidebar-widget">
                        <h5 class="widget-title"><i class="fa fa-folder me-2"></i>Chuyên Mục</h5>
                        <div>
                            <ul class="blog-category-list">
                                <li>
                                    <a href="@Url.Action("Index", "Blog")">
                                        <span><i class="fa fa-list me-2"></i>Tất cả</span>
                                    </a>
                                </li>
                                @foreach (var category in Model.Categories)
                                {
                                    <li>
                                        <a href="@Url.Action("Index", "Blog", new { categoryId = category.Id })">
                                            <span><i class="fa fa-folder-open me-2"></i>@category.Name</span>
                                        </a>
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                }

                <!-- Latest Posts -->
                @{
                    var latestPosts = ViewData["LatestPosts"] as List<CarServ.MVC.Models.ViewModels.BlogPostItemViewModel> ?? new List<CarServ.MVC.Models.ViewModels.BlogPostItemViewModel>();
                }
                @if (latestPosts.Any())
                {
                    <div class="sidebar-widget">
                        <h5 class="widget-title"><i class="fa fa-clock me-2"></i>Bài Viết Mới Nhất</h5>
                        @foreach (var post in latestPosts)
                        {
                            <div class="recent-post-item">
                                @if (!string.IsNullOrEmpty(post.Thumbnail))
                                {
                                    <a class="recent-post-thumb" href="@Url.Action("Detail", "Blog", new { slug = post.Slug })">
                                        <img src="@post.Thumbnail" alt="@post.Title">
                                    </a>
                                }
                                <div>
                                    <h6 class="recent-post-title">
                                        <a href="@Url.Action("Detail", "Blog", new { slug = post.Slug })">@post.Title</a>
                                    </h6>
                                    @if (post.PublishedDate.HasValue)
                                    {
                                        <small class="text-muted"><i class="far fa-calendar-alt me-1"></i>@post.PublishedDate.Value.ToString("dd/MM/yyyy")</small>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
<!-- Blog Detail End -->


