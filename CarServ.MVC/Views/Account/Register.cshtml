@model CarServ.MVC.Controllers.RegisterViewModel
@{
    ViewData["Title"] = "Đăng Ký";
}

<!-- Register -->
<div class="min-vh-100 d-flex align-items-center justify-content-center" style="background: linear-gradient(135deg, #111827 0%, #1F2937 100%); padding: 40px 16px;">
    <div class="w-100" style="max-width: 440px;">
        <!-- Logo -->
        <div class="text-center mb-4">
            <a href="/" class="text-decoration-none">
                <i class="fa fa-car text-primary me-2" style="font-size: 1.1rem;"></i>
                <span style="font-family:'Montserrat',sans-serif; font-weight:800; font-size:1.3rem; color:#fff;">NHP-AUTO</span>
            </a>
        </div>

        <!-- Card -->
        <div class="bg-white p-4 p-md-5" style="border-radius: 16px;">
            <h4 class="fw-bold text-dark mb-1" style="font-size: 1.15rem;">Tạo Tài Khoản</h4>
            <p class="text-muted mb-4" style="font-size: 13px;">Đăng ký để đặt lịch và quản lý dịch vụ.</p>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show mb-3" role="alert" style="border-radius: 10px; font-size: 13px;">
                    <i class="fa fa-check-circle me-2"></i>@TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" style="font-size: 10px;"></button>
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert" style="border-radius: 10px; font-size: 13px;">
                    <i class="fa fa-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" style="font-size: 10px;"></button>
                </div>
            }

            <form asp-action="Register" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-size: 13px;"></div>

                <div class="mb-3">
                    <label asp-for="FullName" class="form-label">Họ và tên <span class="text-danger">*</span></label>
                    <input asp-for="FullName" class="form-control" placeholder="Nguyễn Văn A">
                    <span asp-validation-for="FullName" class="text-danger" style="font-size: 12px;"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label">Email <span class="text-danger">*</span></label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="you@example.com">
                    <span asp-validation-for="Email" class="text-danger" style="font-size: 12px;"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Phone" class="form-label">Số điện thoại <span class="text-danger">*</span></label>
                    <input asp-for="Phone" type="tel" class="form-control" placeholder="0912 345 678">
                    <span asp-validation-for="Phone" class="text-danger" style="font-size: 12px;"></span>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-6">
                        <label asp-for="Password" class="form-label">Mật khẩu <span class="text-danger">*</span></label>
                        <input asp-for="Password" type="password" class="form-control" placeholder="Tối thiểu 6 ký tự">
                        <span asp-validation-for="Password" class="text-danger" style="font-size: 12px;"></span>
                    </div>
                    <div class="col-6">
                        <label asp-for="ConfirmPassword" class="form-label">Xác nhận <span class="text-danger">*</span></label>
                        <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Nhập lại">
                        <span asp-validation-for="ConfirmPassword" class="text-danger" style="font-size: 12px;"></span>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary rounded-pill w-100 py-2 mb-3" style="font-size: 14px;">
                    <i class="fa fa-user-plus me-2" style="font-size: 13px;"></i>Đăng Ký
                </button>

                <p class="text-center text-muted mb-0" style="font-size: 13px;">
                    Đã có tài khoản? <a asp-action="Login" class="text-primary fw-bold text-decoration-none">Đăng nhập</a>
                </p>
            </form>
        </div>

        <!-- Back -->
        <div class="text-center mt-3">
            <a href="/" class="text-white-50 text-decoration-none" style="font-size: 13px;">
                <i class="fa fa-arrow-left me-1" style="font-size: 11px;"></i>Về trang chủ
            </a>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
