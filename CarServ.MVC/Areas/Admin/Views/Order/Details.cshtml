@model CarServ.MVC.Models.Order

@{
    ViewData["Title"] = "Chi tiết Đơn hàng";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Chi tiết Đơn hàng</h1>
        <div>
            <a href="@Url.Action("Edit", "Order", new { area = "Admin", id = Model.OrderId })" class="btn btn-warning">
                <i class="fas fa-edit"></i> Chỉnh sửa
            </a>
            <a href="@Url.Action("Index", "Order", new { area = "Admin" })" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Quay lại
            </a>
        </div>
    </div>

    <!-- Order Information -->
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Thông tin Đơn hàng</h6>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Mã đơn hàng:</dt>
                <dd class="col-sm-9"><strong>@(Model.OrderCode ?? "-")</strong></dd>

                <dt class="col-sm-3">Trạng thái:</dt>
                <dd class="col-sm-9">
                    @if (!string.IsNullOrEmpty(Model.Status))
                    {
                        string statusClass = "badge-secondary";
                        @switch (Model.Status)
                        {
                            case "Chờ xử lý":
                                statusClass = "badge-warning";
                                break;
                            case "Đang xử lý":
                                statusClass = "badge-info";
                                break;
                            case "Đang giao hàng":
                                statusClass = "badge-primary";
                                break;
                            case "Đã giao hàng":
                                statusClass = "badge-success";
                                break;
                            case "Đã hủy":
                                statusClass = "badge-danger";
                                break;
                            case "Hoàn trả":
                                statusClass = "badge-dark";
                                break;
                        }
                        <span class="badge @statusClass">@Model.Status</span>
                    }
                    else
                    {
                        <span class="badge badge-secondary">-</span>
                    }
                </dd>

                <dt class="col-sm-3">Khách hàng:</dt>
                <dd class="col-sm-9">
                    @if (Model.Customer != null)
                    {
                        <div><strong>@Model.Customer.FullName</strong></div>
                        <div>SĐT: @Model.Customer.Phone</div>
                        <div>Email: @Model.Customer.Email</div>
                    }
                    else
                    {
                        <span class="text-muted">-</span>
                    }
                </dd>

                <dt class="col-sm-3">Ngày đặt hàng:</dt>
                <dd class="col-sm-9">@(Model.OrderDate?.ToString("dd/MM/yyyy HH:mm") ?? "-")</dd>

                <dt class="col-sm-3">Phương thức thanh toán:</dt>
                <dd class="col-sm-9">@(Model.PaymentMethod ?? "-")</dd>

                <dt class="col-sm-3">Trạng thái thanh toán:</dt>
                <dd class="col-sm-9">
                    @if (!string.IsNullOrEmpty(Model.PaymentStatus))
                    {
                        string paymentClass = Model.PaymentStatus == "Đã thanh toán" ? "badge-success" : 
                                              Model.PaymentStatus == "Chưa thanh toán" ? "badge-danger" : 
                                              "badge-warning";
                        <span class="badge @paymentClass">@Model.PaymentStatus</span>
                    }
                    else
                    {
                        <span class="badge badge-secondary">-</span>
                    }
                </dd>

                <dt class="col-sm-3">Ngày thanh toán:</dt>
                <dd class="col-sm-9">@(Model.PaymentDate?.ToString("dd/MM/yyyy HH:mm") ?? "-")</dd>

                <dt class="col-sm-3">Mã giao dịch:</dt>
                <dd class="col-sm-9">@(Model.TransactionCode ?? "-")</dd>

                <dt class="col-sm-3">Địa chỉ giao hàng:</dt>
                <dd class="col-sm-9">
                    @if (!string.IsNullOrEmpty(Model.ShippingAddress))
                    {
                        <div>@Model.ShippingAddress</div>
                        <div>
                            @if (!string.IsNullOrEmpty(Model.ShippingWard))
                            {
                                <text>@Model.ShippingWard, </text>
                            }
                            @if (!string.IsNullOrEmpty(Model.ShippingDistrict))
                            {
                                <text>@Model.ShippingDistrict, </text>
                            }
                            @if (!string.IsNullOrEmpty(Model.ShippingCity))
                            {
                                <text>@Model.ShippingCity</text>
                            }
                        </div>
                    }
                    else
                    {
                        <span class="text-muted">-</span>
                    }
                </dd>

                <dt class="col-sm-3">Ghi chú khách hàng:</dt>
                <dd class="col-sm-9">@(Model.CustomerNotes ?? "-")</dd>

                <dt class="col-sm-3">Ghi chú quản trị:</dt>
                <dd class="col-sm-9">@(Model.AdminNotes ?? "-")</dd>
            </dl>
        </div>
    </div>

    <!-- Order Items -->
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Chi tiết Sản phẩm</h6>
        </div>
        <div class="card-body">
            @if (Model.OrderItems != null && Model.OrderItems.Any())
            {
                <div class="table-responsive">
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th>STT</th>
                                <th>Sản phẩm</th>
                                <th>Số lượng</th>
                                <th>Đơn giá</th>
                                <th>Giảm giá</th>
                                <th>Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int index = 1;
                            }
                            @foreach (var item in Model.OrderItems)
                            {
                                <tr>
                                    <td>@index</td>
                                    <td>
                                        @if (item.Product != null)
                                        {
                                            <div><strong>@item.Product.ProductName</strong></div>
                                            @if (!string.IsNullOrEmpty(item.Product.ImageUrl))
                                            {
                                                <img src="@item.Product.ImageUrl" alt="@item.Product.ProductName" style="max-width: 50px; max-height: 50px;" />
                                            }
                                        }
                                        else if (!string.IsNullOrEmpty(item.ProductName))
                                        {
                                            <div><strong>@item.ProductName</strong></div>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>@(item.Quantity ?? 0)</td>
                                    <td>@(item.UnitPrice?.ToString("N0") ?? "0") đ</td>
                                    <td>@(item.Discount?.ToString("N0") ?? "0") đ</td>
                                    <td><strong>@(item.TotalPrice?.ToString("N0") ?? "0") đ</strong></td>
                                </tr>
                                index++;
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="5" class="text-right"><strong>Tổng tiền sản phẩm:</strong></td>
                                <td><strong class="text-danger">@(Model.TotalAmount?.ToString("N0") ?? "0") đ</strong></td>
                            </tr>
                            <tr>
                                <td colspan="5" class="text-right"><strong>Phí vận chuyển:</strong></td>
                                <td><strong>@(Model.ShippingFee?.ToString("N0") ?? "0") đ</strong></td>
                            </tr>
                            <tr>
                                <td colspan="5" class="text-right"><strong>Giảm giá:</strong></td>
                                <td><strong class="text-success">-@(Model.DiscountAmount?.ToString("N0") ?? "0") đ</strong></td>
                            </tr>
                            @if (!string.IsNullOrEmpty(Model.DiscountCode))
                            {
                                <tr>
                                    <td colspan="5" class="text-right"><small>Mã giảm giá: @Model.DiscountCode</small></td>
                                    <td></td>
                                </tr>
                            }
                            <tr class="table-primary">
                                <td colspan="5" class="text-right"><strong>TỔNG CỘNG:</strong></td>
                                <td><strong class="text-danger" style="font-size: 1.2em;">@(Model.FinalAmount?.ToString("N0") ?? "0") đ</strong></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted">Chưa có sản phẩm trong đơn hàng này.</p>
            }
        </div>
    </div>

    <!-- Payment History -->
    <div class="card shadow mb-4">
        <div class="card-header py-3 d-flex justify-content-between align-items-center">
            <h6 class="m-0 font-weight-bold text-primary">Lịch sử Thanh toán</h6>
            <a href="@Url.Action("Create", "Payment", new { area = "Admin", orderId = Model.OrderId })" class="btn btn-sm btn-primary">
                <i class="fas fa-plus"></i> Thêm Thanh toán
            </a>
        </div>
        <div class="card-body">
            @{
                var payments = ViewData["Payments"] as List<CarServ.MVC.Models.Payment> ?? new List<CarServ.MVC.Models.Payment>();
                var totalPaid = ViewData["TotalPaid"] as decimal? ?? 0;
                var remaining = (Model.FinalAmount ?? 0) - totalPaid;
            }

            @if (payments.Any())
            {
                <div class="mb-3">
                    <div class="row">
                        <div class="col-md-4">
                            <strong>Tổng tiền đơn hàng:</strong> <span class="text-danger">@(Model.FinalAmount?.ToString("N0") ?? "0") đ</span>
                        </div>
                        <div class="col-md-4">
                            <strong>Đã thanh toán:</strong> <span class="text-success">@totalPaid.ToString("N0") đ</span>
                        </div>
                        <div class="col-md-4">
                            <strong>Còn lại:</strong> 
                            <span class="@(remaining > 0 ? "text-warning" : "text-success")">
                                @remaining.ToString("N0") đ
                            </span>
                        </div>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-bordered table-sm">
                        <thead>
                            <tr>
                                <th>Mã thanh toán</th>
                                <th>Số tiền</th>
                                <th>Phương thức</th>
                                <th>Trạng thái</th>
                                <th>Ngày thanh toán</th>
                                <th>Mã giao dịch</th>
                                <th>Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var payment in payments)
                            {
                                <tr>
                                    <td>@payment.PaymentCode</td>
                                    <td class="text-right">@payment.Amount.ToString("N0") đ</td>
                                    <td>@payment.PaymentMethod</td>
                                    <td>
                                        @{
                                            var statusClass = payment.PaymentStatus switch
                                            {
                                                "Đã thanh toán" => "badge-success",
                                                "Chờ thanh toán" => "badge-warning",
                                                "Thất bại" => "badge-danger",
                                                "Đã hủy" => "badge-secondary",
                                                "Hoàn tiền" => "badge-info",
                                                _ => "badge-secondary"
                                            };
                                        }
                                        <span class="badge @statusClass">@payment.PaymentStatus</span>
                                    </td>
                                    <td>@payment.PaymentDate.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(payment.TransactionCode))
                                        {
                                            <small>@payment.TransactionCode</small>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        <a href="@Url.Action("Details", "Payment", new { area = "Admin", id = payment.PaymentId })" 
                                           class="btn btn-sm btn-info" title="Chi tiết">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="@Url.Action("Edit", "Payment", new { area = "Admin", id = payment.PaymentId })" 
                                           class="btn btn-sm btn-primary" title="Sửa">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted">Chưa có lịch sử thanh toán cho đơn hàng này.</p>
                <a href="@Url.Action("Create", "Payment", new { area = "Admin", orderId = Model.OrderId })" class="btn btn-primary">
                    <i class="fas fa-plus"></i> Thêm Thanh toán
                </a>
            }
        </div>
    </div>
</div>


