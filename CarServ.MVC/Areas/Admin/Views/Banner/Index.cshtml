@model IEnumerable<CarServ.MVC.Models.Banner>

@{
    ViewData["Title"] = "Quản lý Banner";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Quản lý Banner</h1>
        <a href="@Url.Action("Create", "Banner", new { area = "Admin" })" class="btn btn-primary">
            <i class="fas fa-plus"></i> Thêm Banner Mới
        </a>
    </div>

    <!-- Search and Filter -->
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Tìm kiếm và Lọc</h6>
        </div>
        <div class="card-body">
            <form asp-action="Index" method="get">
                <div class="row">
                    <div class="col-md-3">
                        <div class="form-group">
                            <label>Tìm kiếm:</label>
                            <input type="text" name="searchString" class="form-control" value="@(ViewData["CurrentFilter"]?.ToString() ?? "")" placeholder="Tiêu đề, mô tả..." />
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="form-group">
                            <label>Loại Banner:</label>
                            <select name="typeFilter" class="form-control">
                                <option value="">Tất cả loại</option>
                                @if (ViewBag.BannerTypes != null)
                                {
                                    @foreach (var type in ViewBag.BannerTypes)
                                    {
                                        <option value="@type" selected="@(ViewData["CurrentType"]?.ToString() == type)">@type</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="form-group">
                            <label>Trạng thái:</label>
                            <select name="statusFilter" class="form-control">
                                <option value="">Tất cả trạng thái</option>
                                <option value="active" selected="@(ViewData["CurrentStatus"]?.ToString() == "active")">Đang hoạt động</option>
                                <option value="inactive" selected="@(ViewData["CurrentStatus"]?.ToString() == "inactive")">Không hoạt động</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label>Sắp xếp:</label>
                            <select name="sortOrder" class="form-control">
                                <option value="">Thứ tự hiển thị</option>
                                <option value="SortOrder" selected="@(ViewData["CurrentSort"]?.ToString() == "SortOrder")">Thứ tự tăng dần</option>
                                <option value="sortorder_desc" selected="@(ViewData["CurrentSort"]?.ToString() == "sortorder_desc")">Thứ tự giảm dần</option>
                                <option value="Date" selected="@(ViewData["CurrentSort"]?.ToString() == "Date")">Ngày tạo tăng dần</option>
                                <option value="date_desc" selected="@(ViewData["CurrentSort"]?.ToString() == "date_desc")">Ngày tạo giảm dần</option>
                                <option value="title_desc" selected="@(ViewData["CurrentSort"]?.ToString() == "title_desc")">Tiêu đề Z-A</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="form-group">
                            <label>&nbsp;</label>
                            <button type="submit" class="btn btn-primary btn-block">
                                <i class="fas fa-search"></i> Tìm
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Banner Table -->
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Danh sách Banner</h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered" id="dataTable" width="100%" cellspacing="0">
                    <thead>
                        <tr>
                            <th>Ảnh</th>
                            <th>Tiêu đề</th>
                            <th>Loại</th>
                            <th>Thứ tự</th>
                            <th>Ngày bắt đầu</th>
                            <th>Ngày kết thúc</th>
                            <th>Trạng thái</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" alt="@item.Title" style="width: 100px; height: 60px; object-fit: cover;" class="img-thumbnail" />
                                    }
                                    else
                                    {
                                        <span class="text-muted">Chưa có ảnh</span>
                                    }
                                </td>
                                <td>
                                    <strong>@(item.Title ?? "-")</strong>
                                    @if (!string.IsNullOrEmpty(item.Subtitle))
                                    {
                                        <br /><small class="text-muted">@item.Subtitle</small>
                                    }
                                </td>
                                <td>
                                    <span class="badge badge-info">@(item.BannerType ?? "Homepage")</span>
                                </td>
                                <td>@(item.SortOrder ?? 0)</td>
                                <td>@(item.StartDate?.ToString("dd/MM/yyyy") ?? "-")</td>
                                <td>@(item.EndDate?.ToString("dd/MM/yyyy") ?? "-")</td>
                                <td>
                                    @if (item.IsActive == true)
                                    {
                                        <span class="badge badge-success">Đang hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-secondary">Không hoạt động</span>
                                    }
                                </td>
                                <td>
                                    <a href="@Url.Action("Details", "Banner", new { area = "Admin", id = item.BannerId })" class="btn btn-info btn-sm">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a href="@Url.Action("Edit", "Banner", new { area = "Admin", id = item.BannerId })" class="btn btn-warning btn-sm">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a href="@Url.Action("Delete", "Banner", new { area = "Admin", id = item.BannerId })" class="btn btn-danger btn-sm">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#dataTable').DataTable({
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.10.24/i18n/Vietnamese.json"
                },
                "order": [[3, "asc"]]
            });
        });
    </script>
}

