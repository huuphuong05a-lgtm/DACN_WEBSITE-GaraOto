@model CarServ.MVC.Models.Banner

@{
    ViewData["Title"] = "Chi tiết Banner";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Chi tiết Banner</h1>
        <div>
            <a href="@Url.Action("Edit", "Banner", new { area = "Admin", id = Model.BannerId })" class="btn btn-warning">
                <i class="fas fa-edit"></i> Chỉnh sửa
            </a>
            <a href="@Url.Action("Index", "Banner", new { area = "Admin" })" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Quay lại
            </a>
        </div>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Thông tin Banner</h6>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-4">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" alt="@Model.Title" class="img-fluid img-thumbnail" />
                    }
                    else
                    {
                        <div class="text-center text-muted p-5 border">
                            <i class="fas fa-image fa-3x mb-3"></i>
                            <p>Chưa có ảnh Desktop</p>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.MobileImageUrl))
                    {
                        <hr />
                        <h6>Ảnh Mobile:</h6>
                        <img src="@Model.MobileImageUrl" alt="@Model.Title" class="img-fluid img-thumbnail" />
                    }
                </div>
                <div class="col-md-8">
                    <dl class="row">
                        <dt class="col-sm-4">Tiêu đề:</dt>
                        <dd class="col-sm-8"><strong>@(Model.Title ?? "-")</strong></dd>

                        <dt class="col-sm-4">Phụ đề:</dt>
                        <dd class="col-sm-8">@(Model.Subtitle ?? "-")</dd>

                        <dt class="col-sm-4">Mô tả:</dt>
                        <dd class="col-sm-8">@(Model.Description ?? "-")</dd>

                        <dt class="col-sm-4">URL Liên kết:</dt>
                        <dd class="col-sm-8">
                            @if (!string.IsNullOrEmpty(Model.LinkUrl))
                            {
                                <a href="@Model.LinkUrl" target="_blank">@Model.LinkUrl</a>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </dd>

                        <dt class="col-sm-4">Text Nút:</dt>
                        <dd class="col-sm-8">@(Model.ButtonText ?? "-")</dd>

                        <dt class="col-sm-4">Màu Nút:</dt>
                        <dd class="col-sm-8">
                            <span class="badge badge-@(Model.ButtonColor ?? "primary")">@(Model.ButtonColor ?? "primary")</span>
                        </dd>

                        <dt class="col-sm-4">Loại Banner:</dt>
                        <dd class="col-sm-8">
                            <span class="badge badge-info">@(Model.BannerType ?? "Homepage")</span>
                        </dd>

                        <dt class="col-sm-4">Thứ tự hiển thị:</dt>
                        <dd class="col-sm-8">@(Model.SortOrder ?? 0)</dd>

                        <dt class="col-sm-4">Ngày bắt đầu:</dt>
                        <dd class="col-sm-8">@(Model.StartDate?.ToString("dd/MM/yyyy HH:mm") ?? "-")</dd>

                        <dt class="col-sm-4">Ngày kết thúc:</dt>
                        <dd class="col-sm-8">@(Model.EndDate?.ToString("dd/MM/yyyy HH:mm") ?? "-")</dd>

                        <dt class="col-sm-4">Trạng thái:</dt>
                        <dd class="col-sm-8">
                            @if (Model.IsActive == true)
                            {
                                <span class="badge badge-success">Đang hoạt động</span>
                            }
                            else
                            {
                                <span class="badge badge-secondary">Không hoạt động</span>
                            }
                        </dd>

                        <dt class="col-sm-4">Ngày tạo:</dt>
                        <dd class="col-sm-8">@(Model.CreatedDate?.ToString("dd/MM/yyyy HH:mm") ?? "-")</dd>

                        <dt class="col-sm-4">Ngày cập nhật:</dt>
                        <dd class="col-sm-8">@(Model.UpdatedDate?.ToString("dd/MM/yyyy HH:mm") ?? "-")</dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>
</div>

