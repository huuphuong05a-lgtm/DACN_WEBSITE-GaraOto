@model CarServ.MVC.Models.Menu

@{
    ViewData["Title"] = "Chi tiết Menu";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Chi tiết Menu</h1>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Thông tin Menu</h6>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Tên Menu:</dt>
                <dd class="col-sm-9"><strong>@Model.MenuName</strong></dd>

                <dt class="col-sm-3">URL:</dt>
                <dd class="col-sm-9">@(Model.MenuUrl ?? "-")</dd>

                <dt class="col-sm-3">Menu Cha:</dt>
                <dd class="col-sm-9">
                    @if (Model.Parent != null)
                    {
                        <span class="badge badge-info">@Model.Parent.MenuName</span>
                    }
                    else
                    {
                        <span class="text-muted">Menu gốc</span>
                    }
                </dd>

                <dt class="col-sm-3">Icon:</dt>
                <dd class="col-sm-9">
                    @if (!string.IsNullOrEmpty(Model.IconClass))
                    {
                        <i class="@Model.IconClass"></i> @Model.IconClass
                    }
                    else
                    {
                        <span class="text-muted">-</span>
                    }
                </dd>

                <dt class="col-sm-3">Thứ tự:</dt>
                <dd class="col-sm-9">@(Model.SortOrder ?? 0)</dd>

                <dt class="col-sm-3">Trạng thái:</dt>
                <dd class="col-sm-9">
                    @if (Model.IsActive == true)
                    {
                        <span class="badge badge-success">Đang hoạt động</span>
                    }
                    else
                    {
                        <span class="badge badge-secondary">Không hoạt động</span>
                    }
                </dd>

                <dt class="col-sm-3">Ngày tạo:</dt>
                <dd class="col-sm-9">@(Model.CreatedDate?.ToString("dd/MM/yyyy HH:mm") ?? "-")</dd>

                <dt class="col-sm-3">Ngày cập nhật:</dt>
                <dd class="col-sm-9">@(Model.UpdatedDate?.ToString("dd/MM/yyyy HH:mm") ?? "-")</dd>
            </dl>

            @if (Model.InverseParent != null && Model.InverseParent.Any())
            {
                <hr />
                <h5>Menu con:</h5>
                <ul>
                    @foreach (var child in Model.InverseParent.OrderBy(m => m.SortOrder))
                    {
                        <li>
                            <strong>@child.MenuName</strong> - @(child.MenuUrl ?? "-")
                            @if (child.IsActive == true)
                            {
                                <span class="badge badge-success">Hoạt động</span>
                            }
                            else
                            {
                                <span class="badge badge-secondary">Không hoạt động</span>
                            }
                        </li>
                    }
                </ul>
            }

            <div class="mt-4">
                <a href="@Url.Action("Edit", "Menu", new { area = "Admin", id = Model.MenuId })" class="btn btn-warning">
                    <i class="fas fa-edit"></i> Chỉnh sửa
                </a>
                <a href="@Url.Action("Index", "Menu", new { area = "Admin" })" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Quay lại
                </a>
            </div>
        </div>
    </div>
</div>



