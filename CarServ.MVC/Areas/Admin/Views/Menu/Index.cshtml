@model IEnumerable<CarServ.MVC.Models.Menu>

@{
    ViewData["Title"] = "Quản lý Menu";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Quản lý Menu</h1>
        <a href="@Url.Action("Create", "Menu", new { area = "Admin" })" class="btn btn-primary">
            <i class="fas fa-plus"></i> Thêm Menu Mới
        </a>
    </div>

    <!-- Search and Filter -->
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Tìm kiếm và Lọc</h6>
        </div>
        <div class="card-body">
            <form asp-action="Index" method="get">
                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label>Tìm kiếm:</label>
                            <input type="text" name="searchString" class="form-control" value="@ViewData["CurrentFilter"]" placeholder="Tên menu, URL..." />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label>Trạng thái:</label>
                            <select name="statusFilter" class="form-control" asp-items="@(new SelectList(new[] { new { Value = "active", Text = "Đang hoạt động" }, new { Value = "inactive", Text = "Không hoạt động" } }, "Value", "Text", (string)ViewData["CurrentStatus"]))">
                                <option value="">Tất cả trạng thái</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label>Sắp xếp:</label>
                            <select name="sortOrder" class="form-control">
                                <option value="">Mặc định</option>
                                <option value="SortOrder" selected="@(ViewData["CurrentSort"]?.ToString() == "SortOrder")">Thứ tự tăng dần</option>
                                <option value="sortorder_desc" selected="@(ViewData["CurrentSort"]?.ToString() == "sortorder_desc")">Thứ tự giảm dần</option>
                                <option value="name_desc" selected="@(ViewData["CurrentSort"]?.ToString() == "name_desc")">Tên Z-A</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="form-group">
                            <label>&nbsp;</label>
                            <button type="submit" class="btn btn-primary btn-block">
                                <i class="fas fa-search"></i> Tìm
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Menu Table -->
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Danh sách Menu</h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered" id="dataTable" width="100%" cellspacing="0">
                    <thead>
                        <tr>
                            <th>Tên Menu</th>
                            <th>URL</th>
                            <th>Menu Cha</th>
                            <th>Icon</th>
                            <th>Thứ tự</th>
                            <th>Trạng thái</th>
                            <th>Ngày tạo</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    @if (item.ParentId != null)
                                    {
                                        <span class="text-muted">└─ </span>
                                    }
                                    <strong>@item.MenuName</strong>
                                </td>
                                <td>@(item.MenuUrl ?? "-")</td>
                                <td>
                                    @if (item.Parent != null)
                                    {
                                        <span class="badge badge-info">@item.Parent.MenuName</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Menu gốc</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.IconClass))
                                    {
                                        <i class="@item.IconClass"></i>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>@(item.SortOrder ?? 0)</td>
                                <td>
                                    @if (item.IsActive == true)
                                    {
                                        <span class="badge badge-success">Đang hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-secondary">Không hoạt động</span>
                                    }
                                </td>
                                <td>@(item.CreatedDate?.ToString("dd/MM/yyyy") ?? "-")</td>
                                <td>
                                    <a href="@Url.Action("Details", "Menu", new { area = "Admin", id = item.MenuId })" class="btn btn-info btn-sm">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a href="@Url.Action("Edit", "Menu", new { area = "Admin", id = item.MenuId })" class="btn btn-warning btn-sm">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a href="@Url.Action("Delete", "Menu", new { area = "Admin", id = item.MenuId })" class="btn btn-danger btn-sm">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#dataTable').DataTable({
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.10.24/i18n/Vietnamese.json"
                },
                "order": [[4, "asc"]]
            });
        });
    </script>
}



