@model CarServ.MVC.Models.Service

@{
    ViewData["Title"] = "Xóa Dịch vụ";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Xóa Dịch vụ</h1>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3 bg-danger">
            <h6 class="m-0 font-weight-bold text-white">Xác nhận xóa</h6>
        </div>
        <div class="card-body">
            <h4 class="text-danger">Bạn có chắc chắn muốn xóa dịch vụ này?</h4>
            
            <hr />
            
            <div class="row">
                <div class="col-md-4">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" alt="@Model.ServiceName" class="img-fluid img-thumbnail" />
                    }
                </div>
                <div class="col-md-8">
                    <dl class="row">
                        <dt class="col-sm-4">Tên Dịch vụ:</dt>
                        <dd class="col-sm-8"><strong>@Model.ServiceName</strong></dd>

                        <dt class="col-sm-4">Giá:</dt>
                        <dd class="col-sm-8">
                            @if (Model.Price.HasValue)
                            {
                                <strong>@Model.Price.Value.ToString("N0") đ</strong>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </dd>

                        <dt class="col-sm-4">Danh mục:</dt>
                        <dd class="col-sm-8">
                            @if (!string.IsNullOrEmpty(Model.ServiceCategory))
                            {
                                <span class="badge badge-info">@Model.ServiceCategory</span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </dd>

                        <dt class="col-sm-4">Trạng thái:</dt>
                        <dd class="col-sm-8">
                            @if (Model.IsActive)
                            {
                                <span class="badge badge-success">Đang hoạt động</span>
                            }
                            else
                            {
                                <span class="badge badge-secondary">Không hoạt động</span>
                            }
                        </dd>
                    </dl>
                </div>
            </div>

            <div class="alert alert-warning mt-3">
                <i class="fas fa-exclamation-triangle"></i> <strong>Cảnh báo:</strong> Hành động này không thể hoàn tác. Dịch vụ và ảnh liên quan sẽ bị xóa vĩnh viễn.
            </div>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="ServiceId" />
                <button type="submit" class="btn btn-danger">
                    <i class="fas fa-trash"></i> Xóa
                </button>
                <a href="@Url.Action("Index", "Service", new { area = "Admin" })" class="btn btn-secondary">
                    <i class="fas fa-times"></i> Hủy
                </a>
            </form>
        </div>
    </div>
</div>



