@model CarServ.MVC.Models.Service

@{
    ViewData["Title"] = "Chỉnh sửa Dịch vụ";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Chỉnh sửa Dịch vụ</h1>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Thông tin Dịch vụ</h6>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="ServiceId" />
                <input type="hidden" asp-for="CreatedDate" />

                <div class="form-group">
                    <label asp-for="ServiceName" class="control-label">Tên Dịch vụ <span class="text-danger">*</span></label>
                    <input asp-for="ServiceName" class="form-control" required />
                    <span asp-validation-for="ServiceName" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ShortDescription" class="control-label">Mô tả ngắn</label>
                    <textarea asp-for="ShortDescription" class="form-control" rows="2" placeholder="Mô tả ngắn về dịch vụ..."></textarea>
                    <span asp-validation-for="ShortDescription" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Description" class="control-label">Mô tả chi tiết</label>
                    <textarea asp-for="Description" class="form-control" rows="5" placeholder="Mô tả chi tiết về dịch vụ..."></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label asp-for="Price" class="control-label">Giá (VNĐ)</label>
                            <input asp-for="Price" type="text" class="form-control" placeholder="450000" id="Price" />
                            <span asp-validation-for="Price" class="text-danger"></span>
                            <small class="form-text text-muted">Nhập số nguyên (ví dụ: 450000)</small>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label asp-for="EstimatedDuration" class="control-label">Thời gian ước tính (phút)</label>
                            <input asp-for="EstimatedDuration" type="number" class="form-control" min="1" />
                            <span asp-validation-for="EstimatedDuration" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label asp-for="ServiceCategory" class="control-label">Danh mục</label>
                            <input asp-for="ServiceCategory" class="form-control" placeholder="Ví dụ: Bảo dưỡng, Sửa chữa..." />
                            <span asp-validation-for="ServiceCategory" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label class="control-label">Ảnh dịch vụ</label>
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <div class="mb-3">
                            <div class="border p-2 d-inline-block">
                                <img src="@Model.ImageUrl" alt="@Model.ServiceName" id="currentImagePreview" style="max-width: 200px; max-height: 200px;" class="img-thumbnail" />
                                <br /><small class="text-muted">Ảnh hiện tại</small>
                            </div>
                        </div>
                    }
                    <button type="button" class="btn btn-primary" data-toggle="modal" data-target="#imageBrowserModal">
                        <i class="fas fa-images"></i> Chọn ảnh
                    </button>
                    <input type="hidden" asp-for="ImageUrl" id="selectedImageUrl" />
                    <div id="selectedImagePreview" class="mt-3" style="display: @(string.IsNullOrEmpty(Model.ImageUrl) ? "none" : "block");">
                        <div class="border p-2 d-inline-block">
                            <img id="previewImg" src="@Model.ImageUrl" alt="Preview" style="max-width: 200px; max-height: 200px;" class="img-thumbnail" />
                            <br /><small class="text-muted">Ảnh đã chọn: <span id="selectedImageName">@(Model.ImageUrl != null ? Model.ImageUrl.Split('/').Last() : "")</span></small>
                            <button type="button" class="btn btn-sm btn-danger ml-2" onclick="clearSelectedImage()">
                                <i class="fas fa-times"></i> Xóa
                            </button>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label asp-for="SortOrder" class="control-label">Thứ tự hiển thị</label>
                            <input asp-for="SortOrder" type="number" class="form-control" />
                            <span asp-validation-for="SortOrder" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label asp-for="MetaTitle" class="control-label">Meta Title (SEO)</label>
                            <input asp-for="MetaTitle" class="form-control" />
                            <span asp-validation-for="MetaTitle" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label asp-for="MetaDescription" class="control-label">Meta Description (SEO)</label>
                            <input asp-for="MetaDescription" class="form-control" />
                            <span asp-validation-for="MetaDescription" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <div class="form-check">
                        <input type="hidden" name="IsActive" value="false" />
                        <input type="checkbox" name="IsActive" id="IsActive" class="form-check-input" value="true" @(Model.IsActive ? "checked" : "") />
                        <label class="form-check-label" for="IsActive">Kích hoạt</label>
                    </div>
                </div>

                <div class="form-group">
                    <div class="form-check">
                        <input type="hidden" name="IsFeatured" value="false" />
                        <input type="checkbox" name="IsFeatured" id="IsFeatured" class="form-check-input" value="true" @(Model.IsFeatured ? "checked" : "") />
                        <label class="form-check-label" for="IsFeatured">Nổi bật</label>
                    </div>
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Cập nhật
                    </button>
                    <a href="@Url.Action("Index", "Service", new { area = "Admin" })" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Hủy
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Image Browser Modal -->
<div class="modal fade" id="imageBrowserModal" tabindex="-1" role="dialog" aria-labelledby="imageBrowserModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="imageBrowserModalLabel">Chọn ảnh từ thư viện</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label for="imageUpload" class="form-label">Upload ảnh mới:</label>
                    <div class="input-group">
                        <div class="custom-file">
                            <input type="file" class="custom-file-input" id="imageUpload" accept="image/*">
                            <label class="custom-file-label" for="imageUpload">Chọn file ảnh...</label>
                        </div>
                        <div class="input-group-append">
                            <button class="btn btn-success" type="button" id="btnUploadImage" disabled>
                                <i class="fas fa-upload"></i> Upload
                            </button>
                        </div>
                    </div>
                    <small class="form-text text-muted">Chấp nhận: JPG, JPEG, PNG, GIF, WEBP</small>
                    <div id="uploadProgress" class="mt-2" style="display: none;">
                        <div class="progress">
                            <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width: 100%"></div>
                        </div>
                    </div>
                </div>
                <hr />
                <div class="table-responsive">
                    <table class="table table-bordered table-hover" id="imageTable">
                        <thead>
                            <tr>
                                <th style="width: 80px;">Ảnh</th>
                                <th>Tên file</th>
                                <th style="width: 150px;">Kích thước</th>
                                <th style="width: 120px;">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody id="imageTableBody">
                            <tr>
                                <td colspan="4" class="text-center">
                                    <div class="spinner-border" role="status">
                                        <span class="sr-only">Đang tải...</span>
                                    </div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        // Format price input - remove commas, dots, and non-numeric characters
        $(document).ready(function() {
            $('#Price').on('input', function() {
                var value = $(this).val();
                // Remove all non-numeric characters except digits
                value = value.replace(/[^0-9]/g, '');
                $(this).val(value);
            });

            // Format on blur to ensure clean value
            $('#Price').on('blur', function() {
                var value = $(this).val();
                if (value) {
                    value = value.replace(/[^0-9]/g, '');
                    $(this).val(value);
                }
            });
        });

        function formatFileSize(bytes) {
            if (bytes === 0) return '0 Bytes';
            var k = 1024;
            var sizes = ['Bytes', 'KB', 'MB'];
            var i = Math.floor(Math.log(bytes) / Math.log(k));
            return Math.round(bytes / Math.pow(k, i) * 100) / 100 + ' ' + sizes[i];
        }

        function clearSelectedImage() {
            $('#selectedImageUrl').val('');
            $('#ImageUrl').val(''); // Also clear the asp-for field
            $('#selectedImagePreview').hide();
            $('#previewImg').attr('src', '');
            $('#selectedImageName').text('');
        }

        function selectImage(url, name) {
            // Update the hidden input (asp-for generates id="ImageUrl")
            $('#selectedImageUrl').val(url);
            $('#ImageUrl').val(url); // Update asp-for field
            $('#previewImg').attr('src', url);
            $('#selectedImageName').text(name);
            $('#selectedImagePreview').show();
            $('#imageBrowserModal').modal('hide');
        }

        function deleteImage(url, name) {
            if (!confirm('Bạn có chắc chắn muốn xóa ảnh "' + name + '"?')) {
                return;
            }

            $.ajax({
                url: '@Url.Action("DeleteImage", "Service", new { area = "Admin" })',
                type: 'POST',
                data: { imageUrl: url },
                success: function(response) {
                    if (response.success) {
                        // Remove the row from table
                        var rowId = 'row_' + name.replace(/[^a-zA-Z0-9]/g, '_');
                        $('#' + rowId).fadeOut(300, function() {
                            $(this).remove();
                            // If no images left, show empty message
                            if ($('#imageTableBody tr').length === 0) {
                                $('#imageTableBody').html('<tr><td colspan="4" class="text-center text-muted"><p>Chưa có ảnh nào trong thư viện</p></td></tr>');
                            }
                        });
                    } else {
                        alert('Lỗi: ' + response.message);
                    }
                },
                error: function() {
                    alert('Lỗi khi xóa ảnh');
                }
            });
        }

        $(document).ready(function() {
            // Handle file input change
            $('#imageUpload').on('change', function() {
                var fileName = $(this).val().split('\\').pop();
                $(this).siblings('.custom-file-label').text(fileName || 'Chọn file ảnh...');
                $('#btnUploadImage').prop('disabled', !fileName);
            });

            // Handle upload button click
            $('#btnUploadImage').on('click', function() {
                var fileInput = $('#imageUpload')[0];
                if (!fileInput.files || fileInput.files.length === 0) {
                    alert('Vui lòng chọn file ảnh');
                    return;
                }

                var file = fileInput.files[0];
                var maxSize = 10 * 1024 * 1024; // 10MB
                if (file.size > maxSize) {
                    alert('File ảnh không được vượt quá 10MB');
                    return;
                }

                var formData = new FormData();
                formData.append('file', file);

                var uploadUrl = '@Url.Action("UploadImage", "Service", new { area = "Admin" })';
                console.log('Upload URL:', uploadUrl);
                
                $('#uploadProgress').show();
                $('#btnUploadImage').prop('disabled', true);

                $.ajax({
                    url: uploadUrl,
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function(response) {
                        $('#uploadProgress').hide();
                        $('#btnUploadImage').prop('disabled', false);
                        $('#imageUpload').val('');
                        $('.custom-file-label').text('Chọn file ảnh...');

                        if (response.success) {
                            // Reload images
                            loadImages();
                            alert('Upload ảnh thành công!');
                        } else {
                            alert('Lỗi: ' + response.message);
                        }
                    },
                    error: function(xhr, status, error) {
                        $('#uploadProgress').hide();
                        $('#btnUploadImage').prop('disabled', false);
                        var errorMessage = 'Lỗi khi upload ảnh';
                        if (xhr.status === 404) {
                            errorMessage = 'Không tìm thấy endpoint. Vui lòng kiểm tra lại URL hoặc rebuild project.';
                        } else if (xhr.responseJSON && xhr.responseJSON.message) {
                            errorMessage = xhr.responseJSON.message;
                        } else if (xhr.responseText) {
                            try {
                                var response = JSON.parse(xhr.responseText);
                                if (response.message) {
                                    errorMessage = response.message;
                                }
                            } catch (e) {
                                errorMessage = 'Lỗi: ' + xhr.status + ' - ' + error;
                            }
                        } else {
                            errorMessage = 'Lỗi: ' + xhr.status + ' - ' + error;
                        }
                        alert(errorMessage);
                        console.error('Upload error:', xhr, status, error);
                    }
                });
            });

            // Load images when modal is shown
            $('#imageBrowserModal').on('show.bs.modal', function() {
                loadImages();
            });

            function loadImages() {
                $('#imageTableBody').html('<tr><td colspan="4" class="text-center"><div class="spinner-border" role="status"><span class="sr-only">Đang tải...</span></div></td></tr>');
                
                $.ajax({
                    url: '@Url.Action("BrowseImages", "Service", new { area = "Admin" })',
                    type: 'GET',
                    success: function(images) {
                        if (images.length === 0) {
                            $('#imageTableBody').html('<tr><td colspan="4" class="text-center text-muted"><p>Chưa có ảnh nào trong thư viện</p></td></tr>');
                            return;
                        }

                        var html = '';
                        images.forEach(function(image) {
                            html += '<tr id="row_' + image.name.replace(/[^a-zA-Z0-9]/g, '_') + '">';
                            html += '<td><img src="' + image.url + '" alt="' + image.name + '" style="width: 60px; height: 60px; object-fit: cover;" class="img-thumbnail" /></td>';
                            html += '<td>' + image.name + '</td>';
                            html += '<td>' + formatFileSize(image.size) + '</td>';
                            html += '<td style="white-space: nowrap;">';
                            html += '<button type="button" class="btn btn-sm btn-primary mr-1" onclick="selectImage(\'' + image.url.replace(/'/g, "\\'") + '\', \'' + image.name.replace(/'/g, "\\'") + '\')"><i class="fas fa-check"></i> Chọn</button>';
                            html += '<button type="button" class="btn btn-sm btn-danger" onclick="deleteImage(\'' + image.url.replace(/'/g, "\\'") + '\', \'' + image.name.replace(/'/g, "\\'") + '\')"><i class="fas fa-trash"></i> Xóa</button>';
                            html += '</td>';
                            html += '</tr>';
                        });
                        $('#imageTableBody').html(html);
                    },
                    error: function() {
                        $('#imageTableBody').html('<tr><td colspan="4" class="text-center text-danger"><p>Lỗi khi tải ảnh</p></td></tr>');
                    }
                });
            }
        });
    </script>
}

