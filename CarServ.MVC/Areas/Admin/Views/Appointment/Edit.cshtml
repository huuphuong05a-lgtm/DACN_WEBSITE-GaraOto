@model CarServ.MVC.Models.Appointment
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Chỉnh sửa lịch hẹn";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Chỉnh sửa lịch hẹn</h1>
        <a href="@Url.Action("Details", "Appointment", new { area = "Admin", id = Model.AppointmentId })" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Quay lại
        </a>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Thông tin lịch hẹn</h6>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="AppointmentId" />
                <input type="hidden" asp-for="AppointmentCode" />
                <input type="hidden" asp-for="CreatedDate" />

                @if (Model.AppointmentDate <= DateTime.Now)
                {
                    <div class="alert alert-warning">
                        <i class="fas fa-info-circle"></i>
                        Lịch hẹn này đang có thời gian trong quá khứ. Bạn vẫn có thể cập nhật trạng thái, kỹ thuật viên, ghi chú hoặc tổng tiền; nếu đổi sang thời gian mới thì nên chọn thời gian trong tương lai.
                    </div>
                }

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Mã lịch hẹn</label>
                            <input type="text" class="form-control" value="@(string.IsNullOrWhiteSpace(Model.AppointmentCode) ? "Sẽ tự tạo khi lưu" : Model.AppointmentCode)" readonly />
                            @if (string.IsNullOrWhiteSpace(Model.AppointmentCode))
                            {
                                <small class="form-text text-muted">Dữ liệu cũ chưa có mã lịch hẹn, hệ thống sẽ tự tạo mã khi cập nhật.</small>
                            }
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="Status">Trạng thái <span class="text-danger">*</span></label>
                            <select asp-for="Status" class="form-control" required>
                                @foreach (var status in ViewBag.StatusList ?? Array.Empty<string>())
                                {
                                    <option value="@status" selected="@(Model.Status == status)">@status</option>
                                }
                            </select>
                            <span asp-validation-for="Status" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="CustomerId">Khách hàng</label>
                            <select asp-for="CustomerId" class="form-control">
                                <option value="">Chọn khách hàng...</option>
                                @foreach (SelectListItem customer in ViewBag.Customers ?? new List<SelectListItem>())
                                {
                                    <option value="@customer.Value" selected="@(Model.CustomerId.HasValue && Model.CustomerId.Value.ToString() == customer.Value)">@customer.Text</option>
                                }
                            </select>
                            <span asp-validation-for="CustomerId" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="VehicleId">Xe</label>
                            <select asp-for="VehicleId" class="form-control" id="vehicleSelect">
                                <option value="">Chọn xe hoặc nhập thông tin xe bên dưới...</option>
                                @foreach (SelectListItem vehicle in ViewBag.Vehicles ?? new List<SelectListItem>())
                                {
                                    <option value="@vehicle.Value" selected="@(Model.VehicleId.HasValue && Model.VehicleId.Value.ToString() == vehicle.Value)">@vehicle.Text</option>
                                }
                            </select>
                            <span asp-validation-for="VehicleId" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label>Thông tin khách hàng</label>
                    <div class="row">
                        <div class="col-md-4">
                            <input asp-for="CustomerName" class="form-control" placeholder="Tên khách hàng" />
                        </div>
                        <div class="col-md-4">
                            <input asp-for="CustomerPhone" class="form-control" placeholder="Số điện thoại" />
                        </div>
                        <div class="col-md-4">
                            <input asp-for="CustomerEmail" class="form-control" placeholder="Email" />
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="ServiceId">Dịch vụ</label>
                            <select asp-for="ServiceId" class="form-control" id="serviceSelect">
                                <option value="">Chọn dịch vụ...</option>
                                @foreach (SelectListItem service in ViewBag.Services ?? new List<SelectListItem>())
                                {
                                    <option value="@service.Value" selected="@(Model.ServiceId.HasValue && Model.ServiceId.Value.ToString() == service.Value)">@service.Text</option>
                                }
                            </select>
                            <span asp-validation-for="ServiceId" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="ServiceType">Tên dịch vụ hiển thị</label>
                            <input asp-for="ServiceType" class="form-control" id="serviceNameInput" placeholder="Tự điền theo dịch vụ đã chọn hoặc nhập dịch vụ riêng" />
                            <small class="form-text text-muted">Nếu chọn dịch vụ có sẵn, ô này sẽ tự cập nhật theo tên dịch vụ.</small>
                            <span asp-validation-for="ServiceType" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label asp-for="AppointmentDate">Ngày giờ hẹn <span class="text-danger">*</span></label>
                            <input asp-for="AppointmentDate" type="datetime-local" class="form-control appointment-date-input" step="1800" required />
                            <small class="form-text text-muted">Chỉ nhận lịch trong giờ làm việc 08:00-17:00, tránh giờ nghỉ trưa 12:00-13:00.</small>
                            <span asp-validation-for="AppointmentDate" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label asp-for="EstimatedDuration">Thời gian ước tính (phút)</label>
                            <input asp-for="EstimatedDuration" type="number" class="form-control estimated-duration-input" min="1" />
                            <span asp-validation-for="EstimatedDuration" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label asp-for="ActualDuration">Thời gian thực tế (phút)</label>
                            <input asp-for="ActualDuration" type="number" class="form-control" min="1" />
                            <span asp-validation-for="ActualDuration" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="TechnicianId">Kỹ thuật viên</label>
                            <select asp-for="TechnicianId" class="form-control">
                                <option value="">Chưa phân công</option>
                                @foreach (SelectListItem technician in ViewBag.Technicians ?? new List<SelectListItem>())
                                {
                                    <option value="@technician.Value" selected="@(Model.TechnicianId.HasValue && Model.TechnicianId.Value.ToString() == technician.Value)">@technician.Text</option>
                                }
                            </select>
                            <span asp-validation-for="TechnicianId" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="TotalPrice">Tổng tiền (VNĐ)</label>
                            <input asp-for="TotalPrice" type="number" class="form-control" min="0" step="any" placeholder="Ví dụ: 450000" />
                            <small class="form-text text-muted">Số tiền này dùng để thống kê doanh thu khi lịch hẹn hoàn thành.</small>
                            <span asp-validation-for="TotalPrice" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="VehicleInfo">Thông tin xe</label>
                    <input asp-for="VehicleInfo" class="form-control" placeholder="Ví dụ: Toyota Camry 2020, biển số 30A-12345" />
                    <span asp-validation-for="VehicleInfo" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Notes">Ghi chú</label>
                    <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Ghi chú thêm về lịch hẹn..."></textarea>
                    <span asp-validation-for="Notes" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Cập nhật
                </button>
                <a href="@Url.Action("Index", "Appointment", new { area = "Admin" })" class="btn btn-secondary">
                    <i class="fas fa-times"></i> Hủy
                </a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        $(function () {
            $('#serviceSelect').on('change', function () {
                const text = $(this).find('option:selected').text();
                if ($(this).val()) {
                    $('#serviceNameInput').val(text);
                }
            });

            $('#vehicleSelect').on('change', function () {
                const text = $(this).find('option:selected').text();
                if ($(this).val()) {
                    $('#VehicleInfo').val(text);
                }
            });

            const appointmentInput = $('.appointment-date-input')[0];
            const durationInput = $('.estimated-duration-input')[0];

            function validateWorkingTime() {
                if (!appointmentInput || !appointmentInput.value) {
                    return true;
                }

                const selected = new Date(appointmentInput.value);
                const duration = parseInt(durationInput?.value || '60', 10) || 60;
                const startMinutes = selected.getHours() * 60 + selected.getMinutes();
                const endMinutes = startMinutes + duration;
                const workStart = 8 * 60;
                const lunchStart = 12 * 60;
                const lunchEnd = 13 * 60;
                const workEnd = 17 * 60;
                const crossesLunch = startMinutes < lunchEnd && endMinutes > lunchStart;
                const isValid = startMinutes >= workStart && endMinutes <= workEnd && !crossesLunch;

                appointmentInput.setCustomValidity(isValid
                    ? ''
                    : 'Vui lòng chọn khung giờ trong giờ làm việc 08:00-17:00 và tránh giờ nghỉ trưa 12:00-13:00.');

                return isValid;
            }

            $('.appointment-date-input, .estimated-duration-input').on('input change', function () {
                validateWorkingTime();
                appointmentInput?.reportValidity();
            });

            $('form').on('submit', function (event) {
                if (!validateWorkingTime()) {
                    event.preventDefault();
                    appointmentInput?.reportValidity();
                }
            });
        });
    </script>
}
