@model CarServ.MVC.Models.Appointment

@{
    ViewData["Title"] = "Chi tiết Lịch hẹn";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Chi tiết Lịch hẹn</h1>
        <div>
            <a href="@Url.Action("Edit", "Appointment", new { area = "Admin", id = Model.AppointmentId })" class="btn btn-warning">
                <i class="fas fa-edit"></i> Chỉnh sửa
            </a>
            <a href="@Url.Action("Index", "Appointment", new { area = "Admin" })" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Quay lại
            </a>
        </div>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Thông tin Lịch hẹn</h6>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Mã lịch hẹn:</dt>
                <dd class="col-sm-9"><strong>@(Model.AppointmentCode ?? "-")</strong></dd>

                <dt class="col-sm-3">Trạng thái:</dt>
                <dd class="col-sm-9">
                    @if (!string.IsNullOrEmpty(Model.Status))
                    {
                        string statusClass = "badge-secondary";
                        @switch (Model.Status)
                        {
                            case "Chờ xác nhận":
                                statusClass = "badge-warning";
                                break;
                            case "Đã xác nhận":
                                statusClass = "badge-info";
                                break;
                            case "Đang thực hiện":
                                statusClass = "badge-primary";
                                break;
                            case "Hoàn thành":
                                statusClass = "badge-success";
                                break;
                            case "Đã hủy":
                                statusClass = "badge-danger";
                                break;
                        }
                        <span class="badge @statusClass">@Model.Status</span>
                    }
                    else
                    {
                        <span class="badge badge-secondary">-</span>
                    }
                </dd>

                <dt class="col-sm-3">Khách hàng:</dt>
                <dd class="col-sm-9">
                    @if (Model.Customer != null)
                    {
                        <div><strong>@Model.Customer.FullName</strong></div>
                        <div>SĐT: @Model.Customer.Phone</div>
                        <div>Email: @Model.Customer.Email</div>
                    }
                    else if (!string.IsNullOrEmpty(Model.CustomerName))
                    {
                        <div><strong>@Model.CustomerName</strong></div>
                        @if (!string.IsNullOrEmpty(Model.CustomerPhone))
                        {
                            <div>SĐT: @Model.CustomerPhone</div>
                        }
                        @if (!string.IsNullOrEmpty(Model.CustomerEmail))
                        {
                            <div>Email: @Model.CustomerEmail</div>
                        }
                    }
                    else
                    {
                        <span class="text-muted">-</span>
                    }
                </dd>

                <dt class="col-sm-3">Dịch vụ:</dt>
                <dd class="col-sm-9">
                    @if (Model.Service != null)
                    {
                        <div><strong>@Model.Service.ServiceName</strong></div>
                        @if (Model.Service.Price.HasValue)
                        {
                            <div>Giá: @Model.Service.Price.Value.ToString("N0") đ</div>
                        }
                    }
                    else if (!string.IsNullOrEmpty(Model.ServiceType))
                    {
                        <span>@Model.ServiceType</span>
                    }
                    else
                    {
                        <span class="text-muted">-</span>
                    }
                </dd>

                <dt class="col-sm-3">Kỹ thuật viên:</dt>
                <dd class="col-sm-9">
                    @if (Model.Technician != null)
                    {
                        <div><strong>@Model.Technician.FullName</strong></div>
                        <div>@Model.Technician.Position</div>
                        <div>SĐT: @Model.Technician.Phone</div>
                    }
                    else
                    {
                        <span class="text-muted">Chưa phân công</span>
                    }
                </dd>

                <dt class="col-sm-3">Ngày giờ hẹn:</dt>
                <dd class="col-sm-9"><strong>@(Model.AppointmentDate.ToString("dd/MM/yyyy HH:mm"))</strong></dd>

                <dt class="col-sm-3">Thời gian ước tính:</dt>
                <dd class="col-sm-9">@(Model.EstimatedDuration.HasValue ? Model.EstimatedDuration.Value + " phút" : "-")</dd>

                <dt class="col-sm-3">Thời gian thực tế:</dt>
                <dd class="col-sm-9">@(Model.ActualDuration.HasValue ? Model.ActualDuration.Value + " phút" : "-")</dd>

                <dt class="col-sm-3">Tổng tiền:</dt>
                <dd class="col-sm-9">
                    @if (Model.TotalPrice.HasValue)
                    {
                        <strong class="text-danger">@Model.TotalPrice.Value.ToString("N0") đ</strong>
                    }
                    else
                    {
                        <span class="text-muted">-</span>
                    }
                </dd>

                <dt class="col-sm-3">Thông tin xe:</dt>
                <dd class="col-sm-9">@(Model.VehicleInfo ?? "-")</dd>

                <dt class="col-sm-3">Ghi chú:</dt>
                <dd class="col-sm-9">@(Model.Notes ?? "-")</dd>

                <dt class="col-sm-3">Ngày tạo:</dt>
                <dd class="col-sm-9">@(Model.CreatedDate?.ToString("dd/MM/yyyy HH:mm") ?? "-")</dd>

                <dt class="col-sm-3">Ngày cập nhật:</dt>
                <dd class="col-sm-9">@(Model.UpdatedDate?.ToString("dd/MM/yyyy HH:mm") ?? "-")</dd>
            </dl>
        </div>
    </div>
</div>


