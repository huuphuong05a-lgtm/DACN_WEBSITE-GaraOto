@model IEnumerable<CarServ.MVC.Models.Appointment>
@using CarServ.MVC.Models

@{
    ViewData["Title"] = "Quản lý lịch hẹn";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    var isTechnician = User.IsInRole(AppConstants.AdminRole.Technician);
    var technicianStatusOptions = new[]
    {
        AppConstants.AppointmentStatus.Assigned,
        AppConstants.AppointmentStatus.Inspecting,
        AppConstants.AppointmentStatus.Repairing,
        AppConstants.AppointmentStatus.WaitingParts
    };
    var quickStatusOptions = AppConstants.AppointmentStatus.All
        .Where(status => status != AppConstants.AppointmentStatus.Completed);
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Quản lý lịch hẹn</h1>
        <div>
            <a href="@Url.Action("Calendar", "Appointment", new { area = "Admin" })" class="btn btn-info">
                <i class="fas fa-calendar-alt"></i> Xem lịch tháng
            </a>
            @if (!isTechnician)
            {
                <a href="@Url.Action("Create", "Appointment", new { area = "Admin" })" class="btn btn-primary">
                    <i class="fas fa-plus"></i> Thêm lịch hẹn
                </a>
            }
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Tìm kiếm và lọc</h6>
        </div>
        <div class="card-body">
            <form asp-action="Index" method="get">
                <div class="row">
                    <div class="col-md-3">
                        <div class="form-group">
                            <label>Tìm kiếm</label>
                            <input type="text" name="searchString" class="form-control" value="@ViewData["CurrentFilter"]" placeholder="Mã, tên khách, SĐT, email..." />
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="form-group">
                            <label>Trạng thái</label>
                            <select name="statusFilter" class="form-control">
                                <option value="">Tất cả</option>
                                @foreach (var status in AppConstants.AppointmentStatus.All)
                                {
                                    <option value="@status" selected="@(ViewData["CurrentStatus"]?.ToString() == status)">@status</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="form-group">
                            <label>Ngày hẹn</label>
                            <input type="date" name="dateFilter" class="form-control" value="@ViewData["CurrentDate"]" />
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="form-group">
                            <label>Sắp xếp</label>
                            <select name="sortOrder" class="form-control">
                                <option value="">Mới tạo gần nhất</option>
                                <option value="date_desc" selected="@(ViewData["CurrentSort"]?.ToString() == "date_desc")">Ngày hẹn gần nhất</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label>&nbsp;</label>
                            <button type="submit" class="btn btn-primary btn-block">
                                <i class="fas fa-search"></i> Lọc
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Danh sách lịch hẹn</h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered" id="dataTable" width="100%" cellspacing="0">
                    <thead>
                        <tr>
                            <th>Mã</th>
                            <th>Khách hàng</th>
                            <th>Xe</th>
                            <th>Dịch vụ</th>
                            <th>Kỹ thuật viên</th>
                            <th>Ngày giờ</th>
                            <th>Ngày đặt</th>
                            <th>Thời lượng</th>
                            <th>Giá</th>
                            <th>Trạng thái</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var statusClass = item.Status switch
                            {
                                AppConstants.AppointmentStatus.Pending => "badge-warning",
                                AppConstants.AppointmentStatus.Confirmed => "badge-info",
                                AppConstants.AppointmentStatus.Assigned => "badge-primary",
                                AppConstants.AppointmentStatus.Inspecting => "badge-secondary",
                                AppConstants.AppointmentStatus.Repairing => "badge-primary",
                                AppConstants.AppointmentStatus.WaitingParts => "badge-warning",
                                AppConstants.AppointmentStatus.InProgress => "badge-primary",
                                AppConstants.AppointmentStatus.Completed => "badge-success",
                                AppConstants.AppointmentStatus.Canceled => "badge-danger",
                                AppConstants.AppointmentStatus.NoShow => "badge-dark",
                                _ => "badge-secondary"
                            };
                            var vehicleName = item.Vehicle == null
                                ? null
                                : string.Join(" ", new[] { item.Vehicle.Brand?.BrandName, item.Vehicle.Model?.ModelName }.Where(value => !string.IsNullOrWhiteSpace(value)));
                            var canComplete = item.VehicleId.HasValue
                                && item.Status != AppConstants.AppointmentStatus.Completed
                                && item.Status != AppConstants.AppointmentStatus.Canceled
                                && item.Status != AppConstants.AppointmentStatus.NoShow;
                            var isClosedAppointment = item.Status == AppConstants.AppointmentStatus.Completed
                                || item.Status == AppConstants.AppointmentStatus.Canceled
                                || item.Status == AppConstants.AppointmentStatus.NoShow;
                            var canUpdateStatus = !isClosedAppointment;

                            <tr>
                                <td><strong>@(item.AppointmentCode ?? "-")</strong></td>
                                <td>
                                    <div>@(item.Customer?.FullName ?? item.CustomerName ?? "-")</div>
                                    <small class="text-muted">@(item.Customer?.Phone ?? item.CustomerPhone ?? "")</small>
                                </td>
                                <td>
                                    @if (item.Vehicle != null)
                                    {
                                        <div><strong>@item.Vehicle.LicensePlate</strong></div>
                                        <small class="text-muted">@vehicleName</small>
                                    }
                                    else if (!string.IsNullOrWhiteSpace(item.VehicleInfo))
                                    {
                                        <span>@item.VehicleInfo</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>@(item.Service?.ServiceName ?? item.ServiceType ?? "-")</td>
                                <td>
                                    @if (item.Technician != null)
                                    {
                                        <span>@item.Technician.FullName</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Chưa phân công</span>
                                    }
                                </td>
                                <td>@item.AppointmentDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td data-order="@item.AppointmentId">@(item.CreatedDate?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                                <td>@(item.EstimatedDuration.HasValue ? item.EstimatedDuration + " phút" : "-")</td>
                                <td>@(item.TotalPrice.HasValue ? item.TotalPrice.Value.ToString("N0") + " đ" : "-")</td>
                                <td><span class="badge @statusClass">@(item.Status ?? "-")</span></td>
                                <td style="min-width: 210px;">
                                    <div class="btn-group btn-group-sm mb-2" role="group">
                                        <a href="@Url.Action("Details", "Appointment", new { area = "Admin", id = item.AppointmentId })" class="btn btn-info" title="Xem">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        @if (!isTechnician)
                                        {
                                            <a href="@Url.Action("Edit", "Appointment", new { area = "Admin", id = item.AppointmentId })" class="btn btn-warning" title="Sửa">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                        }
                                        @if (canComplete)
                                        {
                                            <a href="@Url.Action("Complete", "Appointment", new { area = "Admin", id = item.AppointmentId })" class="btn btn-success" title="Hoàn thành">
                                                <i class="fas fa-check"></i>
                                            </a>
                                        }
                                        @if (!isTechnician)
                                        {
                                            <a href="@Url.Action("Delete", "Appointment", new { area = "Admin", id = item.AppointmentId })" class="btn btn-danger" title="Xóa">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        }
                                    </div>
                                    @if (canUpdateStatus)
                                    {
                                        <form asp-action="UpdateStatus" method="post" class="d-flex">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.AppointmentId" />
                                            <select name="status" class="form-control form-control-sm mr-1">
                                                @foreach (var status in isTechnician ? technicianStatusOptions : quickStatusOptions)
                                                {
                                                    <option value="@status" selected="@(item.Status == status)">@status</option>
                                                }
                                            </select>
                                            <button type="submit" class="btn btn-sm btn-outline-primary" title="Cập nhật">
                                                <i class="fas fa-check"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Đã đóng</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            var currentSort = '@ViewData["CurrentSort"]';
            var defaultOrder = [[6, "desc"]]; // Mới tạo gần nhất (Cột Ngày đặt)
            if (currentSort === 'date_desc') {
                defaultOrder = [[5, "desc"]]; // Ngày hẹn gần nhất (Cột Ngày giờ)
            }

            $('#dataTable').DataTable({
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.10.24/i18n/Vietnamese.json"
                },
                "order": defaultOrder
            });
        });
    </script>
}
