@model IEnumerable<CarServ.MVC.Models.Customer>
@using System.Linq

@{
    ViewData["Title"] = "Quản lý Khách hàng";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Quản lý Khách hàng</h1>
        <a href="@Url.Action("Create", "Customer", new { area = "Admin" })" class="btn btn-primary">
            <i class="fas fa-plus"></i> Thêm Khách hàng Mới
        </a>
    </div>

    <!-- Search and Filter -->
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Tìm kiếm và Lọc</h6>
        </div>
        <div class="card-body">
            <form asp-action="Index" method="get">
                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label>Tìm kiếm:</label>
                            <input type="text" name="searchString" class="form-control" value="@ViewData["CurrentFilter"]" placeholder="Tên, email, SĐT..." />
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="form-group">
                            <label>Trạng thái:</label>
                            <select name="statusFilter" class="form-control">
                                <option value="">Tất cả</option>
                                <option value="Active" selected="@(ViewData["CurrentStatus"]?.ToString() == "Active")">Đang hoạt động</option>
                                <option value="Inactive" selected="@(ViewData["CurrentStatus"]?.ToString() == "Inactive")">Không hoạt động</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="form-group">
                            <label>Sắp xếp:</label>
                            <select name="sortOrder" class="form-control">
                                <option value="">Mới nhất</option>
                                <option value="name_desc" selected="@(ViewData["CurrentSort"]?.ToString() == "name_desc")">Tên (Z→A)</option>
                                <option value="Date" selected="@(ViewData["CurrentSort"]?.ToString() == "Date")">Ngày tạo (cũ nhất)</option>
                                <option value="date_desc" selected="@(ViewData["CurrentSort"]?.ToString() == "date_desc")">Ngày tạo (mới nhất)</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label>&nbsp;</label>
                            <button type="submit" class="btn btn-primary btn-block">
                                <i class="fas fa-search"></i> Tìm
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Customer Table -->
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Danh sách Khách hàng</h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered" id="dataTable" width="100%" cellspacing="0">
                    <thead>
                        <tr>
                            <th>Ảnh đại diện</th>
                            <th>Họ tên</th>
                            <th>Email</th>
                            <th>Số điện thoại</th>
                            <th>Địa chỉ</th>
                            <th>Trạng thái</th>
                            <th>Ngày tạo</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.Avatar))
                                    {
                                        <img src="@item.Avatar" alt="@item.FullName" class="img-thumbnail" style="width: 50px; height: 50px; object-fit: cover;" />
                                    }
                                    else
                                    {
                                        <div class="bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                            <i class="fas fa-user"></i>
                                        </div>
                                    }
                                </td>
                                <td><strong>@item.FullName</strong></td>
                                <td>@(item.Email ?? "-")</td>
                                <td>@(item.Phone ?? "-")</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.Address))
                                    {
                                        <div>@item.Address</div>
                                        <small class="text-muted">
                                            @if (!string.IsNullOrEmpty(item.Ward))
                                            {
                                                <text>@item.Ward, </text>
                                            }
                                            @if (!string.IsNullOrEmpty(item.District))
                                            {
                                                <text>@item.District, </text>
                                            }
                                            @if (!string.IsNullOrEmpty(item.City))
                                            {
                                                <text>@item.City</text>
                                            }
                                        </small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    @if (item.IsActive == true)
                                    {
                                        <span class="badge badge-success">Đang hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-secondary">Không hoạt động</span>
                                    }
                                    @if (item.EmailConfirmed == true)
                                    {
                                        <br /><small class="badge badge-info">Đã xác nhận email</small>
                                    }
                                </td>
                                <td>@(item.CreatedDate?.ToString("dd/MM/yyyy") ?? "-")</td>
                                <td>
                                    <a href="@Url.Action("Details", "Customer", new { area = "Admin", id = item.CustomerId })" class="btn btn-info btn-sm">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a href="@Url.Action("Edit", "Customer", new { area = "Admin", id = item.CustomerId })" class="btn btn-warning btn-sm">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a href="@Url.Action("Delete", "Customer", new { area = "Admin", id = item.CustomerId })" class="btn btn-danger btn-sm">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#dataTable').DataTable({
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.10.24/i18n/Vietnamese.json"
                },
                "order": [[0, "desc"]]
            });
        });
    </script>
}


