@model CarServ.MVC.Models.Customer
@using System.Linq

@{
    ViewData["Title"] = "Xóa Khách hàng";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    var orderCount = ViewBag.OrderCount as int? ?? Model.Orders?.Count() ?? 0;
    var appointmentCount = ViewBag.AppointmentCount as int? ?? Model.Appointments?.Count() ?? 0;
    var invoiceCount = ViewBag.InvoiceCount as int? ?? Model.Invoices?.Count() ?? 0;
    var paymentCount = ViewBag.PaymentCount as int? ?? 0;
    var vehicleCount = ViewBag.VehicleCount as int? ?? Model.Vehicles?.Count() ?? 0;
    var cartCount = ViewBag.CartCount as int? ?? Model.Carts?.Count() ?? 0;
    var testimonialCount = ViewBag.TestimonialCount as int? ?? Model.Testimonials?.Count() ?? 0;
    var hasRelatedData = orderCount > 0
        || appointmentCount > 0
        || invoiceCount > 0
        || paymentCount > 0
        || vehicleCount > 0
        || cartCount > 0
        || testimonialCount > 0;
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Xóa Khách hàng</h1>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3 bg-danger">
            <h6 class="m-0 font-weight-bold text-white">Xác nhận xóa khách hàng</h6>
        </div>
        <div class="card-body">
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-triangle"></i> @TempData["ErrorMessage"]
                </div>
            }

            <h4 class="text-danger">Bạn có chắc chắn muốn xóa khách hàng này?</h4>
            <hr />

            <dl class="row">
                <dt class="col-sm-3">Họ và tên:</dt>
                <dd class="col-sm-9"><strong>@Model.FullName</strong></dd>

                <dt class="col-sm-3">Email:</dt>
                <dd class="col-sm-9">@(Model.Email ?? "-")</dd>

                <dt class="col-sm-3">Số điện thoại:</dt>
                <dd class="col-sm-9">@(Model.Phone ?? "-")</dd>

                <dt class="col-sm-3">Trạng thái:</dt>
                <dd class="col-sm-9">
                    @if (Model.IsActive == true)
                    {
                        <span class="badge badge-success">Đang hoạt động</span>
                    }
                    else
                    {
                        <span class="badge badge-secondary">Không hoạt động</span>
                    }
                </dd>

                <dt class="col-sm-3">Ngày tạo:</dt>
                <dd class="col-sm-9">@(Model.CreatedDate?.ToString("dd/MM/yyyy HH:mm") ?? "-")</dd>

                <dt class="col-sm-3">Số đơn hàng:</dt>
                <dd class="col-sm-9">@orderCount</dd>

                <dt class="col-sm-3">Số lịch hẹn:</dt>
                <dd class="col-sm-9">@appointmentCount</dd>

                <dt class="col-sm-3">Số hóa đơn:</dt>
                <dd class="col-sm-9">@invoiceCount</dd>

                <dt class="col-sm-3">Số thanh toán:</dt>
                <dd class="col-sm-9">@paymentCount</dd>

                <dt class="col-sm-3">Số xe:</dt>
                <dd class="col-sm-9">@vehicleCount</dd>

                <dt class="col-sm-3">Giỏ hàng / đánh giá:</dt>
                <dd class="col-sm-9">@cartCount sản phẩm trong giỏ, @testimonialCount đánh giá</dd>
            </dl>

            @if (hasRelatedData)
            {
                <div class="alert alert-warning">
                    <i class="fas fa-exclamation-triangle"></i> 
                    <strong>Cảnh báo:</strong> Khách hàng này đã phát sinh dữ liệu liên quan trong hệ thống.
                    Không thể xóa trực tiếp vì sẽ làm mất lịch sử nghiệp vụ. Bạn nên chuyển trạng thái khách hàng sang
                    <strong>Không hoạt động</strong> nếu không muốn tài khoản tiếp tục sử dụng.
                </div>
            }

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="CustomerId" />
                <div class="form-group">
                    @if (hasRelatedData)
                    {
                        <button type="submit" class="btn btn-danger" disabled>
                            <i class="fas fa-trash"></i> Xóa (Không thể xóa)
                        </button>
                        <a href="@Url.Action("Edit", "Customer", new { area = "Admin", id = Model.CustomerId })" class="btn btn-warning">
                            <i class="fas fa-user-lock"></i> Khóa / sửa trạng thái
                        </a>
                    }
                    else
                    {
                        <button type="submit" class="btn btn-danger">
                            <i class="fas fa-trash"></i> Xóa
                        </button>
                    }
                    <a href="@Url.Action("Index", "Customer", new { area = "Admin" })" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Hủy
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>


