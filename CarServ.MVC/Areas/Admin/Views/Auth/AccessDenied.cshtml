@{
    Layout = null;
    ViewData["Title"] = "Truy cập bị từ chối";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Truy cập bị từ chối - CarServ Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow-lg border-0">
                    <div class="card-body text-center p-5">
                        <div class="mb-4">
                            <i class="fas fa-lock fa-5x text-danger"></i>
                        </div>
                        <h2 class="mb-3">Truy cập bị từ chối</h2>
                        <p class="mb-4 text-muted">Bạn không có quyền truy cập trang này. Vui lòng liên hệ quản trị viên nếu bạn cần quyền truy cập.</p>
                        <a href="@Url.Action("Login", "Auth", new { area = "Admin" })" class="btn btn-primary me-2">
                            <i class="fas fa-sign-in-alt me-2"></i>Đăng nhập lại
                        </a>
                        <a href="@Url.Action("Index", "Home", new { area = "" })" class="btn btn-secondary">
                            <i class="fas fa-home me-2"></i>Về trang chủ
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>


