@model IEnumerable<CarServ.MVC.Models.Payment>

@{
    ViewData["Title"] = "Quản lý Thanh toán";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Quản lý Thanh toán</h1>
        <a href="@Url.Action("Create", "Payment", new { area = "Admin" })" class="btn btn-primary">
            <i class="fas fa-plus"></i> Thêm Thanh toán Mới
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }

    <!-- Search and Filter -->
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Tìm kiếm và Lọc</h6>
        </div>
        <div class="card-body">
            <form asp-action="Index" method="get">
                <div class="row">
                    <div class="col-md-3">
                        <div class="form-group">
                            <label>Tìm kiếm:</label>
                            <input type="text" name="searchString" class="form-control" value="@(ViewData["CurrentFilter"]?.ToString() ?? "")" placeholder="Mã thanh toán, mã giao dịch, tên KH..." />
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="form-group">
                            <label>Trạng thái:</label>
                            <select name="statusFilter" class="form-control">
                                <option value="">Tất cả trạng thái</option>
                                @if (ViewBag.StatusList != null)
                                {
                                    @foreach (var status in (List<string>)ViewBag.StatusList)
                                    {
                                        var currentStatus = ViewData["CurrentStatus"]?.ToString();
                                        <option value="@status" selected="@(currentStatus == status)">@status</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="form-group">
                            <label>Phương thức:</label>
                            <select name="methodFilter" class="form-control">
                                <option value="">Tất cả</option>
                                @if (ViewBag.MethodList != null)
                                {
                                    @foreach (var method in (List<string>)ViewBag.MethodList)
                                    {
                                        var currentMethod = ViewData["CurrentMethod"]?.ToString();
                                        <option value="@method" selected="@(currentMethod == method)">@method</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="form-group">
                            <label>Sắp xếp:</label>
                            <select name="sortOrder" class="form-control">
                                <option value="">Mới nhất</option>
                                @{
                                    var currentSort = ViewData["CurrentSort"]?.ToString();
                                }
                                <option value="date_desc" selected="@(currentSort == "date_desc")">Ngày (mới nhất)</option>
                                <option value="amount_desc" selected="@(currentSort == "amount_desc")">Số tiền (cao → thấp)</option>
                                <option value="amount" selected="@(currentSort == "amount")">Số tiền (thấp → cao)</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label>&nbsp;</label>
                            <button type="submit" class="btn btn-primary btn-block">
                                <i class="fas fa-search"></i> Tìm
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Payment Table -->
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Danh sách Thanh toán</h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered" id="dataTable" width="100%" cellspacing="0">
                    <thead>
                        <tr>
                            <th>Mã thanh toán</th>
                            <th>Khách hàng</th>
                            <th>Đơn hàng/HĐ</th>
                            <th>Số tiền</th>
                            <th>Phương thức</th>
                            <th>Trạng thái</th>
                            <th>Ngày thanh toán</th>
                            <th>Mã giao dịch</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.PaymentCode</td>
                                <td>
                                    @if (item.Customer != null)
                                    {
                                        <span>@item.Customer.FullName</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    @if (item.Order != null)
                                    {
                                        <span class="badge badge-info">@item.Order.OrderCode</span>
                                    }
                                    else if (item.Invoice != null)
                                    {
                                        <span class="badge badge-success">@item.Invoice.InvoiceCode</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td class="text-right">@item.Amount.ToString("N0") đ</td>
                                <td>@item.PaymentMethod</td>
                                <td>
                                    @{
                                        var statusClass = item.PaymentStatus switch
                                        {
                                            "Đã thanh toán" => "badge-success",
                                            "Chờ thanh toán" => "badge-warning",
                                            "Thất bại" => "badge-danger",
                                            "Đã hủy" => "badge-secondary",
                                            "Hoàn tiền" => "badge-info",
                                            _ => "badge-secondary"
                                        };
                                    }
                                    <span class="badge @statusClass">@item.PaymentStatus</span>
                                </td>
                                <td>@item.PaymentDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.TransactionCode))
                                    {
                                        <small>@item.TransactionCode</small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <a href="@Url.Action("Details", "Payment", new { area = "Admin", id = item.PaymentId })" 
                                           class="btn btn-sm btn-info" title="Chi tiết">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="@Url.Action("Edit", "Payment", new { area = "Admin", id = item.PaymentId })" 
                                           class="btn btn-sm btn-primary" title="Sửa">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a href="@Url.Action("Delete", "Payment", new { area = "Admin", id = item.PaymentId })" 
                                           class="btn btn-sm btn-danger" title="Xóa" 
                                           onclick="return confirm('Bạn có chắc chắn muốn xóa thanh toán này?');">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                    @if (!Model.Any())
                    {
                        <tfoot>
                            <tr>
                                <td colspan="9" class="text-center text-muted py-4">
                                    Không có dữ liệu thanh toán
                                </td>
                            </tr>
                        </tfoot>
                    }
                </table>
            </div>
        </div>
    </div>
</div>

