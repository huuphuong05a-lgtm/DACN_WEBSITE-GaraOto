@model CarServ.MVC.Models.Testimonial

@{
    ViewData["Title"] = "Xóa Đánh giá";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Xóa Đánh giá</h1>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3 bg-danger">
            <h6 class="m-0 font-weight-bold text-white">Xác nhận xóa đánh giá</h6>
        </div>
        <div class="card-body">
            <h4 class="text-danger">Bạn có chắc chắn muốn xóa đánh giá này?</h4>
            <hr />

            <dl class="row">
                <dt class="col-sm-3">Khách hàng:</dt>
                <dd class="col-sm-9"><strong>@(Model.CustomerName ?? Model.Customer?.FullName ?? "-")</strong></dd>

                <dt class="col-sm-3">Đánh giá:</dt>
                <dd class="col-sm-9">
                    @if (Model.Rating.HasValue)
                    {
                        <div>
                            @for (int i = 1; i <= 5; i++)
                            {
                                if (i <= Model.Rating.Value)
                                {
                                    <i class="fas fa-star text-warning"></i>
                                }
                                else
                                {
                                    <i class="far fa-star text-muted"></i>
                                }
                            }
                            <span class="ml-2">(@Model.Rating.Value/5 sao)</span>
                        </div>
                    }
                    else
                    {
                        <span class="text-muted">-</span>
                    }
                </dd>

                <dt class="col-sm-3">Nội dung:</dt>
                <dd class="col-sm-9">
                    <div class="border p-2 bg-light rounded">
                        @if (Model.Content.Length > 200)
                        {
                            <text>@Model.Content.Substring(0, 200)...</text>
                        }
                        else
                        {
                            <text>@Model.Content</text>
                        }
                    </div>
                </dd>

                <dt class="col-sm-3">Trạng thái:</dt>
                <dd class="col-sm-9">
                    @if (Model.IsPublished == true)
                    {
                        <span class="badge badge-success">Đã xuất bản</span>
                    }
                    else
                    {
                        <span class="badge badge-warning">Chưa xuất bản</span>
                    }
                </dd>

                <dt class="col-sm-3">Ngày tạo:</dt>
                <dd class="col-sm-9">@(Model.CreatedDate?.ToString("dd/MM/yyyy HH:mm") ?? "-")</dd>
            </dl>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="TestimonialId" />
                <div class="form-group">
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash"></i> Xóa
                    </button>
                    <a href="@Url.Action("Index", "Testimonial", new { area = "Admin" })" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Hủy
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>


