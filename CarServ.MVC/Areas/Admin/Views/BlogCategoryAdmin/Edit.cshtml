@model CarServ.MVC.Models.BlogCategory

@{
    ViewData["Title"] = "Sửa Chuyên mục Blog";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Sửa Chuyên mục Blog</h1>
        <a href="@Url.Action("Index", "BlogCategoryAdmin", new { area = "Admin" })" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Quay lại
        </a>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Thông tin Chuyên mục</h6>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="Slug" />
                <input type="hidden" asp-for="CreatedDate" />
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group">
                    <label asp-for="Name" class="control-label">Tên chuyên mục <span class="text-danger">*</span></label>
                    <input asp-for="Name" class="form-control" required maxlength="100" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                    <small class="form-text text-muted">Slug sẽ tự động cập nhật khi thay đổi tên</small>
                </div>

                <div class="form-group">
                    <label asp-for="Slug" class="control-label">Slug</label>
                    <input asp-for="Slug" class="form-control" readonly />
                    <small class="form-text text-muted">Slug tự động tạo từ tên chuyên mục</small>
                </div>

                <div class="form-group">
                    <label asp-for="Description" class="control-label">Mô tả</label>
                    <textarea asp-for="Description" class="form-control" rows="3" maxlength="500"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="DisplayOrder" class="control-label">Thứ tự hiển thị</label>
                            <input asp-for="DisplayOrder" class="form-control" type="number" />
                            <span asp-validation-for="DisplayOrder" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <div class="form-check mt-4">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                                <label asp-for="IsActive" class="form-check-label">
                                    Đang hoạt động
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Lưu
                    </button>
                    <a href="@Url.Action("Index", "BlogCategoryAdmin", new { area = "Admin" })" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Hủy
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}


