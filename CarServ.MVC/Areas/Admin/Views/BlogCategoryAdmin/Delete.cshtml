@model CarServ.MVC.Models.BlogCategory

@{
    ViewData["Title"] = "Xóa Chuyên mục Blog";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    var hasPosts = ViewData["HasPosts"] as bool? ?? false;
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Xóa Chuyên mục Blog</h1>
        <a href="@Url.Action("Index", "BlogCategoryAdmin", new { area = "Admin" })" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Quay lại
        </a>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3 bg-danger text-white">
            <h6 class="m-0 font-weight-bold">Xác nhận xóa</h6>
        </div>
        <div class="card-body">
            @if (hasPosts)
            {
                <div class="alert alert-warning">
                    <i class="fas fa-exclamation-triangle"></i> Không thể xóa chuyên mục này vì đang có bài viết. Vui lòng xóa hoặc chuyển các bài viết trước.
                </div>
            }
            else
            {
                <h5 class="text-danger mb-4">Bạn có chắc chắn muốn xóa chuyên mục này?</h5>
            }

            <dl class="row">
                <dt class="col-sm-3">Tên:</dt>
                <dd class="col-sm-9">@Model.Name</dd>

                <dt class="col-sm-3">Slug:</dt>
                <dd class="col-sm-9"><code>@Model.Slug</code></dd>

                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <dt class="col-sm-3">Mô tả:</dt>
                    <dd class="col-sm-9">@Model.Description</dd>
                }

                <dt class="col-sm-3">Thứ tự:</dt>
                <dd class="col-sm-9">@Model.DisplayOrder</dd>

                <dt class="col-sm-3">Trạng thái:</dt>
                <dd class="col-sm-9">
                    @if (Model.IsActive)
                    {
                        <span class="badge badge-success">Đang hoạt động</span>
                    }
                    else
                    {
                        <span class="badge badge-secondary">Không hoạt động</span>
                    }
                </dd>
            </dl>

            @if (!hasPosts)
            {
                <form asp-action="Delete" method="post" class="mt-4">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash"></i> Xác nhận xóa
                    </button>
                    <a href="@Url.Action("Index", "BlogCategoryAdmin", new { area = "Admin" })" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Hủy
                    </a>
                </form>
            }
            else
            {
                <a href="@Url.Action("Index", "BlogCategoryAdmin", new { area = "Admin" })" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Quay lại
                </a>
            }
        </div>
    </div>
</div>


