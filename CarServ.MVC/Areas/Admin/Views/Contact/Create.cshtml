@model CarServ.MVC.Models.Contact

@{
    ViewData["Title"] = "Thêm Liên hệ Mới";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Thêm Liên hệ Mới</h1>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Thông tin Liên hệ</h6>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="FullName" class="control-label">Họ và tên <span class="text-danger">*</span></label>
                            <input asp-for="FullName" class="form-control" required />
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label asp-for="Email" class="control-label">Email</label>
                            <input asp-for="Email" type="email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label asp-for="Phone" class="control-label">Số điện thoại</label>
                            <input asp-for="Phone" class="form-control" />
                            <span asp-validation-for="Phone" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12">
                        <div class="form-group">
                            <label asp-for="Subject" class="control-label">Tiêu đề</label>
                            <input asp-for="Subject" class="form-control" />
                            <span asp-validation-for="Subject" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12">
                        <div class="form-group">
                            <label asp-for="Message" class="control-label">Nội dung tin nhắn <span class="text-danger">*</span></label>
                            <textarea asp-for="Message" class="form-control" rows="5" required></textarea>
                            <span asp-validation-for="Message" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-3">
                        <div class="form-group">
                            <label asp-for="Status" class="control-label">Trạng thái</label>
                            <select asp-for="Status" class="form-control">
                                <option value="Chưa đọc">Chưa đọc</option>
                                <option value="Đã đọc">Đã đọc</option>
                                <option value="Đã trả lời">Đã trả lời</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label class="control-label">Đã đọc</label>
                            <div>
                                <input type="hidden" name="IsRead" value="false" />
                                <input type="checkbox" name="IsRead" value="true" @(Model?.IsRead == true ? "checked" : "") />
                                <label class="ml-2">Đánh dấu đã đọc</label>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label class="control-label">Đã trả lời</label>
                            <div>
                                <input type="hidden" name="IsReplied" value="false" />
                                <input type="checkbox" name="IsReplied" value="true" @(Model?.IsReplied == true ? "checked" : "") />
                                <label class="ml-2">Đánh dấu đã trả lời</label>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label asp-for="Ipaddress" class="control-label">Địa chỉ IP</label>
                            <input asp-for="Ipaddress" class="form-control" />
                            <span asp-validation-for="Ipaddress" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12">
                        <div class="form-group">
                            <label asp-for="ReplyMessage" class="control-label">Nội dung trả lời</label>
                            <textarea asp-for="ReplyMessage" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="ReplyMessage" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="RepliedBy" class="control-label">Người trả lời</label>
                            <input asp-for="RepliedBy" class="form-control" />
                            <span asp-validation-for="RepliedBy" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="RepliedDate" class="control-label">Ngày trả lời</label>
                            <input asp-for="RepliedDate" type="datetime-local" class="form-control" />
                            <span asp-validation-for="RepliedDate" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <a href="@Url.Action("Index", "Contact", new { area = "Admin" })" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Quay lại
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Lưu
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}


