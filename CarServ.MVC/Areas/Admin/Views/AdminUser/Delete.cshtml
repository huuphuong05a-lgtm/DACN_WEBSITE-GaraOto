@model CarServ.MVC.Models.AdminUser
@{
    ViewData["Title"] = "Xóa Quản trị viên";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <h1 class="h3 mb-4 text-gray-800">Xóa Quản trị viên</h1>

    <div class="card shadow mb-4">
        <div class="card-header py-3 bg-danger text-white">
            <h6 class="m-0 font-weight-bold">Xác nhận xóa</h6>
        </div>
        <div class="card-body">
            <h5>Bạn có chắc chắn muốn xóa tài khoản này?</h5>
            <hr />

            <dl class="row">
                <dt class="col-sm-3">ID:</dt>
                <dd class="col-sm-9">@Model.Id</dd>

                <dt class="col-sm-3">Tên đăng nhập:</dt>
                <dd class="col-sm-9">@Model.Username</dd>

                <dt class="col-sm-3">Tên đầy đủ:</dt>
                <dd class="col-sm-9">@(Model.FullName ?? "-")</dd>

                <dt class="col-sm-3">Vai trò:</dt>
                <dd class="col-sm-9">
                    <span class="badge badge-@(Model.Role == "Admin" ? "danger" : "info")">
                        @Model.Role
                    </span>
                </dd>

                <dt class="col-sm-3">Email:</dt>
                <dd class="col-sm-9">@(Model.Email ?? "-")</dd>

                <dt class="col-sm-3">Số điện thoại:</dt>
                <dd class="col-sm-9">@(Model.Phone ?? "-")</dd>

                <dt class="col-sm-3">Trạng thái:</dt>
                <dd class="col-sm-9">
                    @if (Model.IsActive == true)
                    {
                        <span class="badge badge-success">Đang hoạt động</span>
                    }
                    else
                    {
                        <span class="badge badge-secondary">Đã khóa</span>
                    }
                </dd>

                <dt class="col-sm-3">Ngày tạo:</dt>
                <dd class="col-sm-9">@(Model.CreatedDate?.ToString("dd/MM/yyyy HH:mm") ?? "-")</dd>
            </dl>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger">
                    <i class="fas fa-trash"></i> Xóa
                </button>
                <a href="@Url.Action("Index", "AdminUser", new { area = "Admin" })" class="btn btn-secondary">
                    <i class="fas fa-times"></i> Hủy
                </a>
            </form>
        </div>
    </div>
</div>


